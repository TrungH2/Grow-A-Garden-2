local function _himonoClampNumber(value, default, minValue, maxValue)
    value = tonumber(value)
    if value == nil then value = default end
    if minValue ~= nil and value < minValue then value = minValue end
    if maxValue ~= nil and value > maxValue then value = maxValue end
    return value
end

local function _himonoFirstOption(value, fallback)
    if type(value) == "table" then
        return value[1] ~= nil and value[1] or fallback
    end
    if value == nil or value == "" then return fallback end
    return value
end

local function _himonoTrimString(value)
    return tostring(value or ""):match("^%s*(.-)%s*$") or ""
end

local function _himonoLower(value)
    return string.lower(_himonoTrimString(value))
end

local function _himonoCompactKey(value)
    return (_himonoLower(value):gsub("[^%w]", ""))
end

local function _himonoTruthy(value, default)
    if value == nil then return default == true end
    if type(value) == "boolean" then return value end
    if type(value) == "number" then return value == value and value ~= 0 end
    if type(value) == "string" then
        local text = _himonoLower(value)
        if text == "true" or text == "1" or text == "yes" or text == "on" or text == "enabled" then return true end
        if text == "false" or text == "0" or text == "no" or text == "off" or text == "disabled" or text == "" then return false end
        return default == true
    end
    return true
end

local function _himonoFindChildAny(parent, names, recursive)
    if typeof(parent) ~= "Instance" then return nil end
    if type(names) == "string" then names = { names } end
    if type(names) ~= "table" then return nil end
    for _, name in ipairs(names) do
        local wanted = _himonoTrimString(name)
        if wanted ~= "" then
            local found = parent:FindFirstChild(wanted, recursive == true)
            if found then return found end
        end
    end
    local wantedSet = {}
    local compactSet = {}
    for _, name in ipairs(names) do
        local wanted = _himonoLower(name)
        if wanted ~= "" then wantedSet[wanted] = true end
        local compact = _himonoCompactKey(name)
        if compact ~= "" then compactSet[compact] = true end
    end
    local children = recursive == true and parent:GetDescendants() or parent:GetChildren()
    for _, child in ipairs(children) do
        if wantedSet[_himonoLower(child.Name)] or compactSet[_himonoCompactKey(child.Name)] then return child end
    end
    return nil
end

local function _himonoChoice(value, choices, fallback)
    local wanted = _himonoLower(value)
    for _, choice in ipairs(choices) do
        if _himonoLower(choice) == wanted then return choice end
    end
    return fallback
end

local function _himonoLookup(tableValue, key)
    if type(tableValue) ~= "table" or key == nil then return nil end
    local direct = tableValue[key]
    if direct ~= nil then return direct end
    local wanted = _himonoLower(key)
    if wanted == "" then return nil end
    local compactWanted = _himonoCompactKey(key)
    for currentKey, value in pairs(tableValue) do
        if _himonoLower(currentKey) == wanted or (compactWanted ~= "" and _himonoCompactKey(currentKey) == compactWanted) then
            return value
        end
    end
    return nil
end

local function _himonoLookupNumber(tableValue, key, default)
    local value = _himonoLookup(tableValue, key)
    if type(value) == "table" then
        value = value.BaseValue or value.SellValue or value.Value or value.Price
            or value.PriceMultiplier or value.Multiplier
    end
    local numeric = tonumber(value)
    if numeric == nil then return default or 0 end
    return numeric
end

