Modules.GenericEventCollector = {}
do
    local EventCollector = Modules.GenericEventCollector
    EventCollector._running = false
    EventCollector._thread = nil
    EventCollector._connections = {}
    EventCollector._cooldownUntil = setmetatable({}, { __mode = "k" })
    EventCollector._stats = { collected = 0, scanned = 0, errors = 0 }

    function EventCollector._isCandidate(prompt, eventConfig)
        if not prompt or not prompt:IsA("ProximityPrompt") or not prompt.Enabled then return false end
        local map = _himonoFindChildAny(workspace, { "Map", "World" })
        if not map or not prompt:IsDescendantOf(map) then return false end
        local seedPackFolder = _himonoFindChildAny(map, { "SeedPackSpawnServerLocations", "SeedPackSpawns", "SeedPackSpawnLocations", "SeedPacks" })
        local wildPetFolder = _himonoFindChildAny(map, { "WildPetRef", "WildPetRefs", "WildPetsRef" })
        local wildPetSpawns = _himonoFindChildAny(map, { "WildPetSpawns", "WildPets", "WildPetSpawnLocations" })
        if (seedPackFolder and prompt:IsDescendantOf(seedPackFolder))
            or (wildPetFolder and prompt:IsDescendantOf(wildPetFolder))
            or (wildPetSpawns and prompt:IsDescendantOf(wildPetSpawns)) then return false end

        local action = _himonoLower(prompt.ActionText or "")
        for _, word in ipairs(type(eventConfig.ActionWords) == "table" and eventConfig.ActionWords or {}) do
            local wanted = _himonoLower(word)
            if wanted ~= "" and string.find(action, wanted, 1, true) then return true end
        end
        return false
    end

    function EventCollector._targetPart(prompt)
        local parent = prompt and prompt.Parent
        if parent and parent:IsA("Attachment") then parent = parent.Parent end
        if parent and parent:IsA("BasePart") then return parent end
        return prompt and prompt:FindFirstAncestorWhichIsA("BasePart") or nil
    end

    function EventCollector._attempt(prompt, config, Utils)
        local eventConfig = config.EventCollector or {}
        if not EventCollector._running or not EventCollector._isCandidate(prompt, eventConfig) then return false end
        if (EventCollector._cooldownUntil[prompt] or 0) > os.clock() then return false end
        local target = EventCollector._targetPart(prompt)
        local root = Utils.getHumanoidRootPart()
        if not target or not root then return false end

        EventCollector._cooldownUntil[prompt] = os.clock() + 5
        local original = root.CFrame
        _himonoRememberMovement("GenericEventCollector", root)
        local moved = Utils.tweenRootTo(root, target.CFrame * CFrame.new(0, 3, 0), eventConfig.TweenSpeed, eventConfig.MaxTweenTime)
        if not EventCollector._running then
            _himonoForgetMovement("GenericEventCollector")
            return false
        end
        if moved then
            pcall(function()
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                else
                    prompt:InputHoldBegin()
                    task.wait(math.max(0.1, prompt.HoldDuration + 0.05))
                    if prompt.Parent then prompt:InputHoldEnd() end
                end
            end)
            task.wait(0.35)
        end
        if not EventCollector._running then
            _himonoForgetMovement("GenericEventCollector")
            return false
        end

        local collected = moved and ((not prompt.Parent) or not prompt.Enabled
            or (target and (not target.Parent or _himonoTruthy(target:GetAttribute("Claimed"), false)
                or _himonoTruthy(target:GetAttribute("Collected"), false))))
        if eventConfig.ReturnAfterCollect ~= false and root.Parent then
            Utils.tweenRootTo(root, original, eventConfig.TweenSpeed, eventConfig.MaxTweenTime)
        end
        _himonoForgetMovement("GenericEventCollector")

        if collected then
            EventCollector._cooldownUntil[prompt] = os.clock() + 60
            EventCollector._stats.collected = EventCollector._stats.collected + 1
        else
            EventCollector._stats.errors = EventCollector._stats.errors + 1
        end
        return collected
    end

    function EventCollector._scan(config, Utils)
        EventCollector._stats.scanned = EventCollector._stats.scanned + 1
        local map = _himonoFindChildAny(workspace, { "Map", "World" })
        if not map then return end
        local eventConfig = config.EventCollector or {}
        local candidates = {}
        local root = Utils.getHumanoidRootPart()
        if not root then return end
        for _, desc in ipairs(map:GetDescendants()) do
            if EventCollector._isCandidate(desc, eventConfig)
                and (EventCollector._cooldownUntil[desc] or 0) <= os.clock() then
                local part = EventCollector._targetPart(desc)
                if part then table.insert(candidates, { prompt = desc, distance = (part.Position - root.Position).Magnitude }) end
            end
        end
        table.sort(candidates, function(a, b) return a.distance < b.distance end)
        local maximum = math.floor(_himonoClampNumber(eventConfig.MaxPerCycle, 5, 1, 20))
        for index = 1, math.min(#candidates, maximum) do
            if not EventCollector._running then break end
            _himonoWithLock("movement", "GenericEventCollector", 0.5, function()
                EventCollector._attempt(candidates[index].prompt, config, Utils)
            end)
        end
    end

    function EventCollector.start(config, Net, Utils)
        if EventCollector._running then return end
        EventCollector._running = true
        local watchedMaps = setmetatable({}, { __mode = "k" })
        local function attachMap(map)
            local mapName = _himonoLower(map and map.Name or "")
            if not EventCollector._running or not map or (mapName ~= "map" and mapName ~= "world") or watchedMaps[map] then return end
            watchedMaps[map] = true
            table.insert(EventCollector._connections, map.DescendantAdded:Connect(function(desc)
                if not EventCollector._running or not desc:IsA("ProximityPrompt") then return end
                task.delay(0.15, function()
                    if not EventCollector._running or not desc.Parent then return end
                    _himonoWithLock("movement", "GenericEventCollector", 0.1, function()
                        EventCollector._attempt(desc, config, Utils)
                    end)
                end)
            end))
        end
        table.insert(EventCollector._connections, workspace.ChildAdded:Connect(attachMap))
        attachMap(_himonoFindChildAny(workspace, { "Map", "World" }))
        EventCollector._thread = task.spawn(function()
            while EventCollector._running do
                runModuleStep("GenericEventCollector", EventCollector, function()
                    EventCollector._scan(config, Utils)
                end)
                task.wait(_himonoClampNumber(config.EventCollector and config.EventCollector.ScanInterval, 0.5, 0.25, 30))
            end
        end)
    end

    function EventCollector.stop()
        EventCollector._running = false
        EventCollector._thread = _himonoCancelThread(EventCollector._thread)
        EventCollector._connections = _himonoDisconnectList(EventCollector._connections)
        _himonoRestoreMovement("GenericEventCollector")
    end

    function EventCollector.getStats()
        return EventCollector._stats
    end
end

