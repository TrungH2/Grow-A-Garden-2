---------------------------------------------------------------
-- OPTIMIZE LOGIC
---------------------------------------------------------------

function Inventory._isFruitTool(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local itemType = tool:GetAttribute("ItemType")
    local mainCategory = tool:GetAttribute("MainCategory")
    local itemTypeLower = _himonoLower(itemType)
    local mainCategoryLower = _himonoLower(mainCategory)
    return tool:GetAttribute("FruitName") ~= nil
        or tool:GetAttribute("FruitTool") ~= nil
        or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
        or mainCategoryLower == "fruit"
        or mainCategoryLower == "fruits"
        or itemTypeLower == "harvestedfruit"
        or itemTypeLower == "fruit"
        or itemTypeLower == "fruits"
end

function Inventory._estimateFruitToolValue(tool, config)
    if not Inventory._isFruitTool(tool) then return nil end
    local direct = tonumber(tool:GetAttribute("SellValue") or tool:GetAttribute("Value") or tool:GetAttribute("Price") or tool:GetAttribute("Worth"))
    if direct then return direct end
    local fruitName = tool:GetAttribute("FruitName")
        or tool:GetAttribute("SeedName")
        or tool:GetAttribute("ItemName")
        or tool.Name
    if type(fruitName) == "string" then
        fruitName = fruitName:gsub("%s*%b[]", ""):gsub("^%s*(.-)%s*$", "%1")
    end

    local baseValue = Inventory._getBaseValue(fruitName)
    if baseValue <= 0 and type(fruitName) == "string" then
        local withoutDisplaySuffix = fruitName:gsub("%s+Fruit$", "")
        if withoutDisplaySuffix ~= fruitName then
            fruitName = withoutDisplaySuffix
            baseValue = Inventory._getBaseValue(fruitName)
        end
    end
    if not baseValue or baseValue <= 0 then return nil end

    local size = tonumber(tool:GetAttribute("SizeMultiplier")
        or tool:GetAttribute("Size")
        or tool:GetAttribute("Weight")
        or tool:GetAttribute("Kg")) or 1
    if size <= 0 then size = 1 end
    local mutation = tool:GetAttribute("Mutation") or tool:GetAttribute("MutationName") or ""
    return math.floor(baseValue * (size ^ 2.65) * Inventory._getMutationMult(mutation, config))
end

function Inventory._shouldFavoriteRare(tool, invConfig)
    if invConfig.FavoriteRare ~= true then return false end
    local mutationText = _himonoLower(tool:GetAttribute("Mutation")
        or tool:GetAttribute("MutationName") or tool:GetAttribute("Mutations") or "")
    for _, mutationName in ipairs(type(invConfig.FavoriteMutations) == "table" and invConfig.FavoriteMutations or {}) do
        local wanted = _himonoLower(mutationName)
        if wanted ~= "" and string.find(mutationText, wanted, 1, true) then return true end
    end

    local size = tonumber(tool:GetAttribute("SizeMultiplier") or tool:GetAttribute("Size")) or 0
    local weight = tonumber(tool:GetAttribute("Weight") or tool:GetAttribute("Kg")) or 0
    local minSize = math.max(tonumber(invConfig.MinFavoriteSize) or 5, 0)
    local minWeight = math.max(tonumber(invConfig.MinFavoriteWeight) or 5, 0)
    return (minSize > 0 and size >= minSize) or (minWeight > 0 and weight >= minWeight)
end

function Inventory._optimize(invConfig, Net, Utils)
    Inventory._stats.scanned = Inventory._stats.scanned + 1
    local LP = Utils.getLocalPlayer()
    local backpack = LP and LP:FindFirstChild("Backpack")
    if not backpack then return end

    local processed = 0
    local maxPerCycle = math.floor(_himonoClampNumber(invConfig.MaxPerCycle, 50, 1, 200))
    for _, tool in ipairs(backpack:GetChildren()) do
        if Inventory._isFruitTool(tool) then
            if processed >= maxPerCycle then break end
            processed = processed + 1

        local estimatedValue = Inventory._estimateFruitToolValue(tool, Config)
        local alreadyFavorite = _himonoTruthy(tool:GetAttribute("Favorite"), false)
            or _himonoTruthy(tool:GetAttribute("IsFavorite"), false)
        local rareFavorite = Inventory._shouldFavoriteRare(tool, invConfig)

        if invConfig.ClearFavoritesForAutoSell == true and Config.Sell.Mode == "all" and alreadyFavorite and not rareFavorite then
            if _himonoRemoteOk(Net, "Backpack.SetFruitFavorite", tool.Name, false) then
                Inventory._favoritedTools[tool] = nil
                Inventory._stats.unfavorited = Inventory._stats.unfavorited + 1
                alreadyFavorite = false
            end
        end

        -- AUTO-FAVORITE high value fruits
        local clearingForSellAll = invConfig.ClearFavoritesForAutoSell == true and Config.Sell.Mode == "all"
        local shouldFavorite = rareFavorite or (not clearingForSellAll and invConfig.AutoFavorite == true and
            estimatedValue and estimatedValue >= (tonumber(invConfig.FavoriteThreshold) or 500))
        if shouldFavorite then
            if alreadyFavorite then
                Inventory._favoritedTools[tool] = true
            elseif not Inventory._favoritedTools[tool] then
                local ok = _himonoRemoteOk(Net, "Backpack.SetFruitFavorite", tool.Name, true)
                if ok then
                    Inventory._favoritedTools[tool] = true
                    Inventory._stats.favorited = Inventory._stats.favorited + 1
                end
            end
        end

        -- Unknown-value items are always preserved. Auto-drop only applies to recognized fruits.
        local dropped = false
        local dropThreshold = tonumber(invConfig.DropThreshold) or 0
        if invConfig.AutoDrop == true and not rareFavorite and not alreadyFavorite and estimatedValue and
           dropThreshold > 0 and estimatedValue < dropThreshold then
            local ok = _himonoRemoteOk(Net, "DroppedItem.RequestDrop", tool.Name, 1)
            if ok then
                Inventory._stats.dropped = Inventory._stats.dropped + 1
                dropped = true
            end
        end

        -- AUTO-PROMOTE fruits to inventory once per tool instance.
        if not dropped and invConfig.AutoPromote and not Inventory._promotedTools[tool] then
            local ok = _himonoRemoteOk(Net, "Backpack.PromoteFruit", tool.Name)
            if ok then
                Inventory._promotedTools[tool] = true
                Inventory._stats.promoted = Inventory._stats.promoted + 1
            end
        end
        end
    end
end

