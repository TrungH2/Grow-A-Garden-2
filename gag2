-- STOP / STATUS
---------------------------------------------------------------

function Mutation.stop()
    Mutation._running = false
    Mutation._thread = _himonoCancelThread(Mutation._thread)
    Mutation._connections = _himonoDisconnectList(Mutation._connections)
    Mutation._lastMutationByEntity = {}
end

function Mutation.getStats()
    return Mutation._stats
end

end

