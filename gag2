Modules.AutoJoinServer = {}
do
    local M = Modules.AutoJoinServer
    local TS = game:GetService("TeleportService")
    M._running = false
    M._thread = nil
    M._connections = {}
    M._autoRejoinSetup = false
    M._retrying = false
    M._uiToggle = nil
    M._stats = { teleports = 0, errors = 0 }

    function M.start(config, Net, Utils)
        if M._running then return end
        M._running = true

        local serverConfig = config.Server or {}
        local targetJobId = _himonoTrimString(serverConfig.TargetJobId)
        local autoRejoin = serverConfig.AutoRejoin ~= false
        local rejoinDelay = _himonoClampNumber(serverConfig.RejoinDelay, 5, 1, 120)
        local maxRetries = math.floor(_himonoClampNumber(serverConfig.MaxRetries, 10, 1, 50))

        if targetJobId == "" then
            warn("[himono Hub] AutoJoinServer: no TargetJobId set - set Config.Server.TargetJobId first")
            M._running = false
            return
        end
        queueKaitunAfterTeleport(config)

        -- If already on target server, just enable auto-rejoin
        if game.JobId == targetJobId then
            print("[himono Hub] Already on target server:", targetJobId)
            if autoRejoin then
                M._setupAutoRejoin(config, Utils)
            else
                M._running = false
            end
            return
        end

        -- Teleport to target server
        M._thread = task.spawn(function()
            local LP = Utils.getLocalPlayer()
            local retries = 0

            while M._running and retries < maxRetries do
                retries = retries + 1
                print("[himono Hub] AutoJoinServer: teleporting to", targetJobId, "(attempt " .. retries .. ")")

                local ok, err = pcall(function()
                    TS:TeleportToPlaceInstance(game.PlaceId, targetJobId, LP)
                end)

                if ok then
                    M._stats.teleports = M._stats.teleports + 1
                    print("[himono Hub] AutoJoinServer: teleport initiated")
                    -- Wait for teleport to process
                    task.wait(10)
                    if game.JobId == targetJobId then break end
                    -- If still here, teleport may have failed
                    if game.JobId ~= targetJobId then
                        warn("[himono Hub] AutoJoinServer: still on old server, retrying...")
                    end
                else
                    M._stats.errors = M._stats.errors + 1
                    warn("[himono Hub] AutoJoinServer: teleport error:", err)
                end

                task.wait(rejoinDelay)
            end

            if M._running and game.JobId ~= targetJobId and retries >= maxRetries then
                warn("[himono Hub] AutoJoinServer: max retries reached")
                Config.Notify("Server Join Failed", "Could not join target server after " .. maxRetries .. " attempts", 10)
                M._running = false
                Running.AutoJoinServer = false
                Config.Features.AutoJoinServer = false
                M._connections = _himonoDisconnectList(M._connections)
                M._autoRejoinSetup = false
                task.defer(function()
                    if M._uiToggle and M._uiToggle.Set then M._uiToggle:Set(false) end
                end)
            end
        end)

        -- Setup auto-rejoin if enabled
        if autoRejoin then
            M._setupAutoRejoin(config, Utils)
        end

        print("[himono Hub] AutoJoinServer started -> JobId:", targetJobId)
    end

    function M._setupAutoRejoin(config, Utils)
        if M._autoRejoinSetup then return end
        if AntiAfk and AntiAfk._rejoinRunning then return end
        M._autoRejoinSetup = true
        local serverConfig = config.Server or {}
        local targetJobId = _himonoTrimString(serverConfig.TargetJobId)
        local rejoinDelay = _himonoClampNumber(serverConfig.RejoinDelay, 5, 1, 120)

        -- On teleport failure (kicked/disconnected), rejoin target server
        table.insert(M._connections, TS.TeleportInitFailed:Connect(function(player, teleportResult, errorMessage)
            if not M._running then return end
            local eventPlayer = Utils.getLocalPlayer()
            if player and eventPlayer and player ~= eventPlayer then return end
            if targetJobId == "" then return end
            if M._retrying then return end
            M._retrying = true

            warn("[himono Hub] TeleportInitFailed:", teleportResult, errorMessage, "- rejoining in", rejoinDelay, "s")
            task.wait(rejoinDelay)
            if not M._running or not M._autoRejoinSetup or config.Server.AutoRejoin == false then
                M._retrying = false
                return
            end

            local LP = Utils.getLocalPlayer()
            local retries = 0
            while M._running and M._autoRejoinSetup and config.Server.AutoRejoin ~= false and retries < 5 do
                retries = retries + 1
                local ok = pcall(function()
                    TS:TeleportToPlaceInstance(game.PlaceId, targetJobId, LP)
                end)
                if ok then break end
                task.wait(rejoinDelay)
            end
            M._retrying = false
        end))

        -- On character respawn (server change), check if we need to rejoin
        local LP = Utils.getLocalPlayer()
        table.insert(M._connections, LP.CharacterAdded:Connect(function()
            task.wait(5) -- wait for game to load
            if not M._running or not M._autoRejoinSetup or config.Server.AutoRejoin == false then return end
            if targetJobId == "" then return end

            -- Check if we're on wrong server after respawn
            if game.JobId ~= targetJobId then
                print("[himono Hub] AutoJoinServer: respawned on wrong server, rejoining target...")
                task.wait(rejoinDelay)
                pcall(function()
                    TS:TeleportToPlaceInstance(game.PlaceId, targetJobId, LP)
                end)
            end
        end))
    end

    function M.stop()
        M._running = false
        M._thread = _himonoCancelThread(M._thread)
        M._connections = _himonoDisconnectList(M._connections)
        M._autoRejoinSetup = false
        M._retrying = false
    end

    function M.setAutoRejoin(enabled, config, Utils)
        M._connections = _himonoDisconnectList(M._connections)
        M._autoRejoinSetup = false
        M._retrying = false
        if enabled and M._running then
            M._setupAutoRejoin(config, Utils)
        end
    end

    function M.getStats()
        return M._stats
    end

    -- Helper: get current JobId for sharing
    function M.getCurrentJobId()
        return game.JobId
    end

    -- Helper: set target and start
    function M.setTargetAndStart(jobId, config, Net, Utils)
        local targetJobId = _himonoTrimString(jobId)
        if targetJobId == "" then return end
        config.Server.TargetJobId = targetJobId
        if M._running then M.stop() end
        task.wait(0.5)
        M.start(config, Net, Utils)
    end
end
