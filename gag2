Modules.StealBot = {}
do
    local M = Modules.StealBot
    local Steal = M
    Steal._running = false
    Steal._thread  = nil
    Steal._connections = {}
    Steal._stats = { attempts = 0, stolen = 0, returned = 0, errors = 0, nightCycles = 0, skipped = 0 }

    ---------------------------------------------------------------
    -- GET MY PLOT ID
    ---------------------------------------------------------------

    function Steal._getMyPlotId()
        local lp = Players.LocalPlayer
        return lp and tonumber(lp:GetAttribute("PlotId")) or nil
    end

    ---------------------------------------------------------------
    -- CHECK IF GARDEN IS UNLOCKED (owner left plot)
    -- Checks: attribute Locked, BoolValue Locked, owner proximity
    -- Returns true if garden is STEALABLE (unlocked)
    ---------------------------------------------------------------

    function Steal._isGardenUnlocked(garden)
        local lockedAttr = garden:GetAttribute("Locked")
        local lockedValue = garden:FindFirstChild("Locked")
        if lockedAttr == true or (lockedValue and lockedValue:IsA("BoolValue") and lockedValue.Value) then
            return false
        end

        -- Check: owner player inside plot -> locked
        local ownerUserId = garden:GetAttribute("OwnerUserId")
            or garden:GetAttribute("Owner")
        if ownerUserId then
            local numericOwnerId = tonumber(ownerUserId)
            local owner = numericOwnerId and Players:GetPlayerByUserId(numericOwnerId)
                or (type(ownerUserId) == "string" and Players:FindFirstChild(ownerUserId))
            if owner then
                if owner and owner.Character then
                    local ownerHRP = owner.Character:FindFirstChild("HumanoidRootPart")
                    if ownerHRP then
                        -- Check if owner position is inside any PlantArea part
                        for _, part in ipairs(garden:GetDescendants()) do
                            if part:IsA("BasePart") then
                                local relPos = part.CFrame:PointToObjectSpace(ownerHRP.Position)
                                local halfSize = part.Size / 2
                                if math.abs(relPos.X) <= halfSize.X
                                    and math.abs(relPos.Y) <= halfSize.Y + 10
                                    and math.abs(relPos.Z) <= halfSize.Z then
                                    return false -- owner inside plot boundary -> locked
                                end
                            end
                        end
                    end
                end
            end
        end

        return true -- owner not found or not in plot -> unlocked -> stealable
    end

    ---------------------------------------------------------------
    -- FIND STEALABLE PROMPTS ON OTHER PLAYERS' GARDENS
    -- Matching decompiled u87 guard logic:
    --   gate: Night.Value == true
    --   prompt.Enabled == true
    --   prompt:GetAttribute("Collected") != true
    --   StealPrompt + HoldDuration > 0 -> SKIP (Bamboo)
    --   garden must be UNLOCKED (owner left plot)
    --   get PlantId/FruitId from parent fruit Model
    ---------------------------------------------------------------

    function Steal._findStealablePrompts(myPlotId)
        local results = {}
        local gardens = _himonoFindChildAny(workspace, { "Gardens", "GardenPlots", "Plots", "Garden" })
        if not gardens then return results end

        for _, garden in ipairs(gardens:GetChildren()) do
            local plotNum = tonumber(garden.Name:match("Plot(%d+)"))
            if plotNum and plotNum ~= myPlotId then
                -- Gate: only steal from unlocked gardens
                if Steal._isGardenUnlocked(garden) then
                    local plantsFolder = _himonoFindChildAny(garden, { "Plants", "Plant", "GardenPlants" })
                    if plantsFolder then
                        for _, plantModel in ipairs(plantsFolder:GetChildren()) do
                            local fruitsFolder = _himonoFindChildAny(plantModel, { "Fruits", "Fruit", "Produce", "Harvestables" })
                            if fruitsFolder then
                                for _, fruitModel in ipairs(fruitsFolder:GetChildren()) do
                                    local prompt = fruitModel:FindFirstChild("StealPrompt", true)
                                    local promptOk = prompt
                                        and prompt:IsA("ProximityPrompt")
                                        and prompt.Enabled
                                        and not _himonoTruthy(prompt:GetAttribute("Collected"), false)
                                        and prompt.HoldDuration <= 0

                                    if promptOk then
                                        -- Read attrs from fruit MODEL (not prompt)
                                        local userId = tonumber(fruitModel:GetAttribute("UserId"))
                                        local plantId = fruitModel:GetAttribute("PlantId")
                                        local fruitId = fruitModel:GetAttribute("FruitId")
                                        local seedName = fruitModel:GetAttribute("SeedName")
                                            or fruitModel:GetAttribute("FruitName")
                                            or plantModel:GetAttribute("SeedName")
                                            or plantModel.Name
                                        local size = fruitModel:GetAttribute("SizeMultiplier")
                                            or fruitModel:GetAttribute("Size")
                                            or 1
                                        local mutation = fruitModel:GetAttribute("Mutation")

                                        if userId and plantId then
                                            table.insert(results, {
                                                prompt   = prompt,
                                                userId   = userId,
                                                plantId  = plantId,
                                                fruitId  = fruitId or "",
                                                seedName = seedName,
                                                mutation = mutation,
                                                estimatedValue = Steal._estimateValue(seedName, size, mutation),
                                                gardenName = garden.Name,
                                            })
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        return results
    end

    ---------------------------------------------------------------
    -- START
    ---------------------------------------------------------------

    function Steal.start(config, Net, Utils)
        if Steal._running then return end
        Steal._running = true

        local stealConfig = config.Steal or {}

        -- Listen for server steal confirmation events
        local startedConn = Net.on("Steal.StealStarted", function(fruitInstance)
            if not Steal._running then return end
            print("[himono Hub] StealStarted confirmed by server:", fruitInstance and fruitInstance.Name or "?")
        end)
        local cancelledConn = Net.on("Steal.StealCancelled", function(fruitInstance)
            if not Steal._running then return end
            print("[himono Hub] StealCancelled by server:", fruitInstance and fruitInstance.Name or "?")
        end)
        if startedConn then table.insert(Steal._connections, startedConn) end
        if cancelledConn then table.insert(Steal._connections, cancelledConn) end

        Steal._thread = task.spawn(function()
            local wasNight = false
            while Steal._running do
                runModuleStep("StealBot", Steal, function()
                    local isNight = Utils.isNight()
                    if isNight and not wasNight then
                        Steal._stats.nightCycles = Steal._stats.nightCycles + 1
                        Steal._stats.attempts = 0 -- reset per night
                        print("[himono Hub] Night cycle started - Steal Bot active")
                    end
                    if isNight then
                        _himonoWithLock("movement", "StealBot", 0.5, function()
                            Steal._stealLoop(stealConfig, Net, Utils)
                        end)
                    elseif wasNight then
                        print("[himono Hub] Day started - Steal Bot sleeping")
                    end
                    wasNight = isNight
                end)
                task.wait(_himonoClampNumber(config.Timings.StealInterval, 1.5, 1, 30))
            end
        end)

        print("[himono Hub] Steal Bot started (waits for night)")
    end

    ---------------------------------------------------------------
    -- STEAL LOOP
    ---------------------------------------------------------------

    function Steal._stealLoop(stealConfig, Net, Utils)
        local LP = Players.LocalPlayer

        -- If already carrying -> return to plot first
        local carrying = LP:GetAttribute("CarryingStolenFruit")
        if carrying then
            Steal._returnFruit(Net, Utils)
            return
        end

        -- Max attempts guard
        local maxAttempts = math.floor(_himonoClampNumber(stealConfig.MaxAttemptsPerNight, 20, 1, 500))
        if Steal._stats.attempts >= maxAttempts then return end

        local myPlotId = Steal._getMyPlotId()
        if not myPlotId then return end

        local entries = Steal._findStealablePrompts(myPlotId)
        if #entries == 0 then return end

        -- Sort by value descending (high value first)
        local minValue = _himonoClampNumber(stealConfig.MinFruitValue, 0, 0, math.huge)
        table.sort(entries, function(a, b)
            if stealConfig.PreferMutations ~= false then
                local aMutated = a.mutation ~= nil and a.mutation ~= ""
                local bMutated = b.mutation ~= nil and b.mutation ~= ""
                if aMutated ~= bMutated then return aMutated end
            end
            return (a.estimatedValue or 0) > (b.estimatedValue or 0)
        end)

        for _, entry in ipairs(entries) do
            if not Steal._running then break end
            if Steal._stats.attempts >= maxAttempts then break end

            -- Value filter
            local sellValue = entry.estimatedValue or 0
            if minValue > 0 and sellValue < minValue then
                Steal._stats.skipped = Steal._stats.skipped + 1
            else
                -- Teleport to fruit -> fire prompt -> teleport back
                local success = Steal._attemptSteal(entry, Net, Utils)
                if success then
                    Steal._stats.stolen = Steal._stats.stolen + 1
                    print("[himono Hub] Stolen from", entry.gardenName, "plant:", entry.plantId, "value:", sellValue)
                    return
                end

                task.wait(0.5)
                return
            end
        end
    end

    ---------------------------------------------------------------
    -- ATTEMPT STEAL (teleport flow)
    -- 1. Get HRP + save old CFrame
    -- 2. Teleport to fruit position (near prompt)
    -- 3. Fire proximity prompt (HoldDuration=0)
    -- 4. Wait for CarryingStolenFruit
    -- 5. Teleport back to own plot
    ---------------------------------------------------------------

    function Steal._getReturnCFrame(garden)
        if not garden then return nil end
        local spawn = garden:FindFirstChild("SpawnPoint", true)
        if spawn and spawn:IsA("BasePart") then
            return spawn.CFrame + spawn.CFrame.UpVector * (spawn.Size.Y / 2 + 3)
        elseif spawn and spawn:IsA("Attachment") then
            return CFrame.new(spawn.WorldPosition + Vector3.new(0, 3, 0))
        elseif garden:IsA("Model") then
            return garden:GetPivot() + Vector3.new(0, 3, 0)
        end
        return nil
    end

    function Steal._attemptSteal(entry, Net, Utils)
        local prompt = entry.prompt
        if not prompt or not prompt.Parent then return false end
        if not prompt.Enabled then return false end
        if _himonoTruthy(prompt:GetAttribute("Collected"), false) then return false end

        Steal._stats.attempts = Steal._stats.attempts + 1

        local hrp = Utils.getHumanoidRootPart()
        if not hrp then return false end

        -- Save position so cancellation or a runtime error cannot strand the player.
        local savedCFrame = hrp.CFrame

        -- Get fruit position (parent of prompt)
        local fruitPart = prompt.Parent
        if not fruitPart or not fruitPart:IsA("BasePart") then
            fruitPart = prompt:FindFirstAncestorWhichIsA("BasePart")
                or (prompt.Parent and prompt.Parent:FindFirstChildWhichIsA("BasePart", true))
        end
        if not fruitPart then return false end

        -- Step 1: Teleport to fruit
        _himonoRememberMovement("StealBot", hrp)
        local moved = Utils.tweenRootTo(hrp, fruitPart.CFrame + Vector3.new(0, 3, 0),
            Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
        if not moved then
            Utils.tweenRootTo(hrp, savedCFrame, Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
            _himonoForgetMovement("StealBot")
            return false
        end
        task.wait(0.8) -- wait for server to register position

        -- Step 2: Fire proximity prompt
        local triggered = false
        pcall(function()
            if fireproximityprompt then
                fireproximityprompt(prompt)
                triggered = true
            else
                -- Fallback: InputHoldBegin/End
                prompt:InputHoldBegin()
                task.wait(math.max(0.09, prompt.HoldDuration + 0.1))
                if prompt and prompt:IsDescendantOf(workspace) then
                    prompt:InputHoldEnd()
                end
                triggered = true
            end
        end)

        if not triggered then
            -- Restore position on failure
            Utils.tweenRootTo(hrp, savedCFrame, Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
            _himonoForgetMovement("StealBot")
            return false
        end

        -- Step 3: Wait for server to confirm carrying
        local carrying = nil
        local confirmDeadline = os.clock() + 2
        repeat
            task.wait(0.1)
            carrying = Players.LocalPlayer:GetAttribute("CarryingStolenFruit")
        until carrying or os.clock() >= confirmDeadline

        -- Step 4: Teleport back to own plot (base)
        local garden = Utils.getMyGarden()
        local returnCFrame = Steal._getReturnCFrame(garden)
        if returnCFrame then
            Utils.tweenRootTo(hrp, returnCFrame, Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
        else
            -- Fallback: restore old position
            Utils.tweenRootTo(hrp, savedCFrame, Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
        end
        _himonoForgetMovement("StealBot")

        if carrying then
            local waited = 0
            while Players.LocalPlayer:GetAttribute("CarryingStolenFruit") and waited < 2 do
                task.wait(0.1)
                waited = waited + 0.1
            end
            if not Players.LocalPlayer:GetAttribute("CarryingStolenFruit") then
                Steal._stats.returned = Steal._stats.returned + 1
                print("[himono Hub] Stolen + returned to base")
            end
        end

        return carrying and true or false
    end

    ---------------------------------------------------------------
    -- RETURN FRUIT TO OWN PLOT
    ---------------------------------------------------------------

    function Steal._returnFruit(Net, Utils)
        local LP = Players.LocalPlayer
        local carrying = LP:GetAttribute("CarryingStolenFruit")
        if not carrying then return end
        local garden = Utils.getMyGarden()
        if not garden then return end
        local hrp = Utils.getHumanoidRootPart()
        local returnCFrame = Steal._getReturnCFrame(garden)
        if hrp and returnCFrame then
            _himonoRememberMovement("StealBot", hrp)
            Utils.tweenRootTo(hrp, returnCFrame, Config.Steal.TweenSpeed, Config.Steal.MaxTweenTime)
            task.wait(1)
            _himonoForgetMovement("StealBot")
        end
        if not LP:GetAttribute("CarryingStolenFruit") then
            Steal._stats.returned = Steal._stats.returned + 1
            print("[himono Hub] Returned stolen fruit to plot")
            return true
        end
        return false
    end

    ---------------------------------------------------------------
    -- ESTIMATE FRUIT VALUE
    ---------------------------------------------------------------

    function Steal._estimateValue(seedName, size, mutation)
        local baseValue = _himonoLookupNumber(Resources.SellValues, seedName, 0)
        local numericSize = tonumber(size) or 1
        if numericSize <= 0 then numericSize = 1 end
        local mutationMult = 1
        if mutation and Config.Mutation and Config.Mutation.PriceMultipliers then
            mutationMult = _himonoLookupNumber(Config.Mutation.PriceMultipliers, mutation, 1)
        end
        return math.floor(baseValue * (numericSize ^ 2.65) * mutationMult)
    end

    ---------------------------------------------------------------
    -- STOP / STATUS
    ---------------------------------------------------------------

    function Steal.stop()
        Steal._running = false
        Steal._thread = _himonoCancelThread(Steal._thread)
        Steal._connections = _himonoDisconnectList(Steal._connections)
        _himonoRestoreMovement("StealBot")
    end

    function Steal.getStats()
        return Steal._stats
    end
end

