local function buildStartupProgressText()
    local pct = 0
    if StartupProgress.total and StartupProgress.total > 0 then
        pct = math.min(100, math.floor((StartupProgress.done / StartupProgress.total) * 100))
    end
    local lines = {
        "STARTUP PROGRESS",
        string.format("  Mode: OneClick %s", Config.Kaitun.OneClick and "ON" or "OFF"),
        string.format("  State: %s", tostring(StartupProgress.state or "")),
        string.format("  Progress: %d/%d (%d%%)", StartupProgress.done or 0, StartupProgress.total or 0, pct),
        string.format("  Current: %s", tostring(StartupProgress.current or "")),
    }
    if #StartupProgress.log > 0 then
        table.insert(lines, "")
        table.insert(lines, "Recent:")
        for i = 1, math.min(#StartupProgress.log, 8) do
            table.insert(lines, "  " .. StartupProgress.log[i])
        end
    end
    return table.concat(lines, "\n")
end

local function getSortedModuleNames()
    local names = {}
    for name in pairs(Modules) do table.insert(names, name) end
    table.sort(names)
    return names
end

local function getFullStatus()
    local lines = {"himono Hub STATUS", "Sheckles: " .. Utils.formatNumber(Utils.getSheckles()), ""}
    lines[#lines + 1] = "  " .. (AntiAfk._running and "ON" or "OFF") .. " AntiAfk"
    lines[#lines + 1] = "  " .. (AntiAfk._rejoinRunning and "ON" or "OFF") .. " AutoRejoin"
    lines[#lines + 1] = "  " .. (Performance._boostEnabled and "ON" or "OFF") .. " BoostFPS"
    lines[#lines + 1] = "  " .. (Performance._screenEnabled and "ON" or "OFF") .. " PerformanceScreen"
    for _, name in ipairs(getSortedModuleNames()) do
        local st = Running[name] and "ON" or "OFF"
        local info = ""
        if name == "RestockSniper" then
            local t = Config.Restock.TargetSeeds or {}
            info = "targets: " .. tostring(#t)
        elseif name == "GearBuyer" then
            local t = Config.Gear.TargetGears or {}
            info = "targets: " .. tostring(#t)
        elseif name == "AutoPlant" then
            info = (Config.Plant.PlantOrder or "Top") .. " | " .. (Config.Plant.PreferSeed ~= "" and Config.Plant.PreferSeed or "any")
        elseif name == "AutoBuyPet" then
            info = "min: " .. (Config.Pet.MinRarity or "Rare")
        elseif name == "MutationTracker" then
            info = "alerts: " .. tostring(#(Config.Mutation.AlertMutations or {}))
        elseif name == "AutoSell" then
            info = "mode: " .. tostring(Config.Sell.Mode or "all")
        elseif name == "AutoWater" then
            info = Config.Water.WaterAll and "all" or "dry only"
        elseif name == "StealBot" then
            info = Config.Features.StealBot and "night mode" or "off"
        elseif name == "ServerHop" then
            info = "every " .. tostring(Config.Server.HopInterval or 600) .. "s"
        end
        local err = ModuleErrors[name]
        if err then info = (info ~= "" and (info .. " | ") or "") .. "ERR: " .. tostring(err) end
        lines[#lines+1] = "  " .. st .. " " .. name .. ": " .. info
    end
    return table.concat(lines, "\n")
end

