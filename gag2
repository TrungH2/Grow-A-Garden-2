local function serializeConfigForQueue(value, seen, depth)
    local valueType = type(value)
    if valueType == "nil" then return "nil" end
    if valueType == "boolean" then return value and "true" or "false" end
    if valueType == "string" then return string.format("%q", value) end
    if valueType == "number" then
        if value ~= value or value == math.huge or value == -math.huge then return "0" end
        return tostring(value)
    end
    if valueType ~= "table" or (depth or 0) >= 20 then return "nil" end
    seen = seen or {}
    if seen[value] then return "nil" end
    seen[value] = true

    local keys = {}
    for key in pairs(value) do
        if type(key) == "string" or type(key) == "number" then table.insert(keys, key) end
    end
    table.sort(keys, function(a, b)
        if type(a) == type(b) then return tostring(a) < tostring(b) end
        return type(a) < type(b)
    end)
    local entries = {}
    for _, key in ipairs(keys) do
        local encodedValue = serializeConfigForQueue(value[key], seen, (depth or 0) + 1)
        if encodedValue ~= "nil" then
            table.insert(entries, "[" .. serializeConfigForQueue(key, nil, 0) .. "]=" .. encodedValue)
        end
    end
    seen[value] = nil
    return "{" .. table.concat(entries, ",") .. "}"
end

local function queueKaitunAfterTeleport(config)
    if AntiAfk._loaderQueued then return true end
    if not config.Loader or config.Loader.QueueOnTeleport == false then return false end
    local configUrl = _himonoTrimString(config.Loader.ConfigUrl)
    local coreUrl = _himonoTrimString(config.Loader.CoreUrl)
    if not configUrl:match("^https?://") and not coreUrl:match("^https?://") then return false end

    local queueFunction = nil
    pcall(function()
        local environment = type(getgenv) == "function" and getgenv() or _G
        queueFunction = rawget(environment, "queue_on_teleport") or rawget(environment, "queueonteleport")
        if type(queueFunction) ~= "function" then
            local synapse = rawget(environment, "syn")
            if type(synapse) == "table" then queueFunction = synapse.queue_on_teleport end
        end
        if type(queueFunction) ~= "function" then
            local fluxus = rawget(environment, "fluxus")
            if type(fluxus) == "table" then queueFunction = fluxus.queue_on_teleport end
        end
    end)
    if type(queueFunction) ~= "function" then return false end
    local source
    if configUrl:match("^https?://") then
        source = "loadstring(game:HttpGet(" .. string.format("%q", configUrl) .. "))()"
    else
        local queuedConfig = config
        source = "local e=type(getgenv)=='function' and getgenv() or _G;"
            .. "e.HimonoKaitunConfig=" .. serializeConfigForQueue(queuedConfig) .. ";"
            .. "loadstring(game:HttpGet(" .. string.format("%q", coreUrl) .. "))()"
    end
    local ok = pcall(queueFunction, source)
    if ok then AntiAfk._loaderQueued = true end
    return ok
end

function AntiAfk._scheduleRejoin(config, reason)
    if not AntiAfk._rejoinRunning or AntiAfk._rejoinPending then return end
    local serverConfig = config.Server or {}
    local now = os.clock()
    local resetSeconds = _himonoClampNumber(serverConfig.RejoinRetryReset, 120, 30, 900)
    if AntiAfk._lastRejoinSchedule == 0 or now - AntiAfk._lastRejoinSchedule >= resetSeconds then
        AntiAfk._rejoinAttempts = 0
    end
    AntiAfk._lastRejoinSchedule = now
    local maxRetries = math.floor(_himonoClampNumber(serverConfig.MaxRetries, 10, 1, 50))
    if AntiAfk._rejoinAttempts >= maxRetries then
        AntiAfk._stats.exhausted = AntiAfk._stats.exhausted + 1
        warn("[himono Hub] Auto-Rejoin retry limit reached")
        AntiAfk._rejoinPending = true
        AntiAfk._rejoinThread = task.spawn(function()
            task.wait(resetSeconds)
            AntiAfk._rejoinPending = false
            AntiAfk._rejoinAttempts = 0
            AntiAfk._lastRejoinSchedule = 0
            if AntiAfk._rejoinRunning then
                AntiAfk._scheduleRejoin(config, "retry window reset")
            end
        end)
        return
    end

    AntiAfk._rejoinAttempts = AntiAfk._rejoinAttempts + 1
    AntiAfk._rejoinPending = true
    AntiAfk._stats.lastReason = tostring(reason or "disconnect")
    local baseDelay = _himonoClampNumber(serverConfig.RejoinDelay, 5, 3, 60)
    local delaySeconds = math.min(60, baseDelay * (2 ^ math.min(AntiAfk._rejoinAttempts - 1, 3)))

    AntiAfk._rejoinThread = task.spawn(function()
        task.wait(delaySeconds)
        if not AntiAfk._rejoinRunning then
            AntiAfk._rejoinPending = false
            return
        end

        AntiAfk._stats.rejoins = AntiAfk._stats.rejoins + 1
        local targetJobId = _himonoTrimString(serverConfig.TargetJobId)
        local originalJobId = game.JobId
        queueKaitunAfterTeleport(config)
        local teleportService = game:GetService("TeleportService")
        local ok, err = pcall(function()
            if targetJobId ~= "" then
                teleportService:TeleportToPlaceInstance(game.PlaceId, targetJobId, LP)
            else
                teleportService:Teleport(game.PlaceId, LP)
            end
        end)
        AntiAfk._rejoinPending = false
        if not ok then
            AntiAfk._stats.rejoinErrors = AntiAfk._stats.rejoinErrors + 1
            warn("[himono Hub] Auto-Rejoin call failed:", err)
            if AntiAfk._rejoinRunning then
                task.defer(AntiAfk._scheduleRejoin, config, "teleport call failed")
            end
        else
            local attemptTimeout = _himonoClampNumber(serverConfig.RejoinAttemptTimeout, 20, 10, 120)
            task.delay(attemptTimeout, function()
                if AntiAfk._rejoinRunning and game.JobId == originalJobId and LP.Parent == Players then
                    AntiAfk._scheduleRejoin(config, "teleport timeout")
                end
            end)
        end
    end)
end

function AntiAfk.stopAutoRejoin()
    AntiAfk._rejoinRunning = false
    AntiAfk._rejoinPending = false
    AntiAfk._rejoinAttempts = 0
    AntiAfk._lastRejoinSchedule = 0
    AntiAfk._rejoinThread = _himonoCancelThread(AntiAfk._rejoinThread)
    AntiAfk._rejoinConnections = _himonoDisconnectList(AntiAfk._rejoinConnections)
end

function AntiAfk.startAutoRejoin(config)
    if not config.Server or config.Server.AutoRejoin == false then return end
    if AntiAfk._rejoinRunning then return end
    AntiAfk._rejoinRunning = true
    AntiAfk._rejoinAttempts = 0
    AntiAfk._lastRejoinSchedule = 0

    pcall(function()
        local coreGui = game:GetService("CoreGui")
        local watchedPromptGuis = setmetatable({}, { __mode = "k" })
        local function watchPromptGui(promptGui)
            if not promptGui or watchedPromptGuis[promptGui] then return end
            watchedPromptGuis[promptGui] = true
            table.insert(AntiAfk._rejoinConnections, promptGui.DescendantAdded:Connect(function(descendant)
                if descendant and descendant.Name == "ErrorPrompt" then
                    AntiAfk._scheduleRejoin(config, "disconnect prompt")
                end
            end))
            if promptGui:FindFirstChild("ErrorPrompt", true) then
                AntiAfk._scheduleRejoin(config, "existing error prompt")
            end
        end

        table.insert(AntiAfk._rejoinConnections, coreGui.DescendantAdded:Connect(function(descendant)
            if not descendant then return end
            if descendant.Name == "ErrorPrompt" then
                task.defer(AntiAfk._scheduleRejoin, config, "error prompt")
            elseif descendant.Name == "RobloxPromptGui" then
                watchPromptGui(descendant)
            end
        end))

        watchPromptGui(coreGui:FindFirstChild("RobloxPromptGui", true))
        if coreGui:FindFirstChild("ErrorPrompt", true) then
            AntiAfk._scheduleRejoin(config, "existing error prompt")
        end
    end)

    pcall(function()
        table.insert(AntiAfk._rejoinConnections, GuiService.ErrorMessageChanged:Connect(function(message)
            if type(message) == "string" and _himonoTrimString(message) ~= "" then
                AntiAfk._scheduleRejoin(config, message)
            end
        end))
    end)

    local teleportService = game:GetService("TeleportService")
    table.insert(AntiAfk._rejoinConnections, teleportService.TeleportInitFailed:Connect(function(player, result, message)
        if player == LP then
            AntiAfk._stats.rejoinErrors = AntiAfk._stats.rejoinErrors + 1
            AntiAfk._scheduleRejoin(config, tostring(result) .. ": " .. tostring(message))
        end
    end))
    print("[himono Hub] Auto-Rejoin enabled")
end

function AntiAfk.getStats()
    return AntiAfk._stats
end


