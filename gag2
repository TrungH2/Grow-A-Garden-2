Modules.AutoWater = {}
do
    local M = Modules.AutoWater
    local Water = M
Water._running = false
Water._thread  = nil
Water._connections = {}
Water._stats = { watered = 0, sprinklers = 0, scans = 0, errors = 0, noCan = 0 }
Water._nextSprinklerAt = 0
Water._debug = false -- enable only when debugging watering issues

---------------------------------------------------------------
-- FIND WATERING CAN TOOL IN BACKPACK/CHARACTER
-- Tool attribute: "WateringCan" = can name string
-- Can types: "Common Watering Can", "Super Watering Can"
---------------------------------------------------------------

function Water._findCan(requiredCan)
    local LP = Players.LocalPlayer
    if not LP then
        if Water._debug then warn("[Water][DEBUG] No LocalPlayer") end
        return nil, nil
    end

    -- Normalize: trim whitespace
    local function trim(s)
        if type(s) ~= "string" then return "" end
        return s:match("^%s*(.-)%s*$") or ""
    end

    local reqNorm = trim(requiredCan)
    if Water._debug then
        warn("[Water][DEBUG] RequiredCan raw:", string.format("%q", tostring(requiredCan or "")),
             "| norm:", string.format("%q", reqNorm),
             "| type:", type(requiredCan),
             "| len:", #reqNorm)
    end

    -- If no specific can required, use first found
    local matchFn = function(canName)
        if reqNorm == "" then return true end
        return _himonoLower(canName) == _himonoLower(reqNorm)
    end

    local function scanContainer(container, label)
        if not container then return nil end
        local tools = container:GetChildren()
        if Water._debug then
            warn("[Water][DEBUG] Scanning", label, "- items:", #tools)
        end
        for _, tool in ipairs(tools) do
            if tool:IsA("Tool") then
                local wcAttr = tool:GetAttribute("WateringCan")
                if Water._debug then
                    warn("[Water][DEBUG] Tool:", tool.Name,
                         "| WateringCan attr:", string.format("%q", tostring(wcAttr)),
                         "| attr type:", type(wcAttr),
                         "| Class:", tool.ClassName)
                end
                -- WateringCan attribute = flag for watering can tools
                if wcAttr ~= nil and wcAttr ~= false then
                    local attrName = type(wcAttr) == "string" and trim(wcAttr) or ""
                    local canName = attrName ~= "" and attrName or trim(tool.Name:gsub("%s*%b[]", ""))
                    local matched = matchFn(canName)
                    if Water._debug then
                        warn("[Water][DEBUG] Found can:", string.format("%q", canName),
                             "| match:", matched,
                             "| compare:", string.format("%q", trim(canName)), "==", string.format("%q", reqNorm))
                    end
                    if matched then
                        return tool, canName
                    end
                end
            end
        end
        return nil
    end

    -- Check character first (already equipped)
    local char = LP.Character
    local tool, canName = scanContainer(char, "Character")
    if tool then return tool, canName end

    -- Check backpack
    local backpack = LP:FindFirstChild("Backpack")
    tool, canName = scanContainer(backpack, "Backpack")

    if not tool and Water._debug then
        warn("[Water][DEBUG] No watering can found! RequiredCan:", string.format("%q", tostring(requiredCan or "")))
    end

    return tool, canName
end

---------------------------------------------------------------
-- EQUIP WATERING CAN
---------------------------------------------------------------

function Water._equipCan(tool)
    local LP = Players.LocalPlayer
    local char = LP and LP.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        if Water._debug then warn("[Water][DEBUG] No humanoid for equip") end
        return false
    end

    -- Already in character?
    if tool.Parent == char then
        if Water._debug then warn("[Water][DEBUG] Can already equipped:", tool.Name) end
        return true
    end

    if Water._debug then warn("[Water][DEBUG] Equipping:", tool.Name, "from:", tool.Parent and tool.Parent.Name) end
    pcall(function() humanoid:EquipTool(tool) end)
    task.wait(0.2)
    local success = tool.Parent == char
    if Water._debug then warn("[Water][DEBUG] Equip result:", success, "parent:", tool.Parent and tool.Parent.Name) end
    return success
end

---------------------------------------------------------------
-- START
---------------------------------------------------------------

function Water.start(config, Net, Utils)
    if Water._running then return end
    Water._running = true
    Water._nextSprinklerAt = 0

    Water._thread = task.spawn(function()
        while Water._running do
            runModuleStep("AutoWater", Water, function()
                _himonoWithLock("tool", "AutoWater", 0.5, function()
                    Water._waterPlants(config, Net, Utils)
                end)
            end)
            task.wait(_himonoClampNumber(config.Timings.WaterInterval, 3, 1, 60))
        end
    end)

    print("[himono Hub] Auto-Water started")
end

---------------------------------------------------------------
-- WATER PLANTS
-- Reference: Controllers_WateringcanController.TryWater()
-- Remote: WateringCan.UseWateringCan(position, canName, toolInstance)
---------------------------------------------------------------

function Water._waterPlants(config, Net, Utils)
    local garden = Utils.getMyGarden()
    if not garden then
        if Water._debug then warn("[Water][DEBUG] No garden found") end
        return
    end

    Water._stats.scans = Water._stats.scans + 1

    if config.Water.AutoSprinkler == true and os.clock() >= Water._nextSprinklerAt then
        Water._nextSprinklerAt = os.clock() + _himonoClampNumber(config.Water.SprinklerCooldown, 30, 10, 600)
        Water._placeAutomaticSprinkler(config, Net, Utils, garden)
    end

    -- 1. Find + equip watering can
    local canTool, canName = Water._findCan(config.Water.RequiredCan)
    if not canTool then
        Water._stats.noCan = Water._stats.noCan + 1
        if Water._debug then warn("[Water][DEBUG] noCan, scan:", Water._stats.scans) end
        return
    end

    local equipped = Water._equipCan(canTool)
    if not equipped then
        Water._stats.errors = Water._stats.errors + 1
        if Water._debug then warn("[Water][DEBUG] Failed to equip can") end
        return
    end

    -- 2. Scan plants
    local plants = Utils.getPlantsInGarden(garden)
    table.sort(plants, function(a, b)
        local aName = a:GetAttribute("SeedName") or a.Name
        local bName = b:GetAttribute("SeedName") or b.Name
        local aValue = _himonoLookupNumber(Resources.SellValues, aName, 0)
        local bValue = _himonoLookupNumber(Resources.SellValues, bName, 0)
        return aValue > bValue
    end)
    local waterFullyGrown = config.Water.WaterFullyGrown or false
    if Water._debug then
        warn("[Water][DEBUG] Garden:", garden.Name, "| Plants:", #plants,
             "| WaterAll:", tostring(config.Water.WaterAll),
             "| WaterFullyGrown:", tostring(waterFullyGrown),
             "| RequiredCan:", tostring(config.Water.RequiredCan))
    end

    local wateredThisRound = 0
    local attemptedThisRound = 0
    local maxPerCycle = math.floor(_himonoClampNumber(config.Water.MaxPerCycle, 20, 1, 100))
    for _, plant in ipairs(plants) do
        if not Water._running then break end
        if attemptedThisRound >= maxPerCycle then break end

        local info = Utils.getPlantInfo(plant)
        if not info then
            if Water._debug then warn("[Water][DEBUG] No info for plant:", plant.Name) end
        else
            -- Skip fully grown unless toggle enabled
            local growth = tonumber(info.Growth) or 0
            local isFullyGrown = growth >= 1
            local shouldWater = true
            if isFullyGrown and not waterFullyGrown then
                shouldWater = false
                if Water._debug then warn("[Water][DEBUG] Skip fully grown:", info.Name, "growth:", growth) end
            end

            -- Prefer an explicit water-state attribute; growth is only a compatibility fallback.
            local needsWater = info.NeedsWater
            if needsWater == nil then needsWater = growth < 1 end
            if shouldWater and config.Water.WaterAll ~= true and not needsWater then
                shouldWater = false
                if Water._debug then warn("[Water][DEBUG] Skip no-water-need:", info.Name, "growth:", growth) end
            end

            -- 3. Get plant position
            local rootPart = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
            if shouldWater and not rootPart then
                shouldWater = false
                if Water._debug then warn("[Water][DEBUG] No BasePart for plant:", info.Name) end
            end

            if shouldWater then
                -- 4. Fire UseWateringCan(position, canName, toolInstance)
                -- Position offset -0.3 Y like decompiled TryWater
                local pos = rootPart.Position - Vector3.new(0, 0.3, 0)
                if Water._debug then
                    warn("[Water][DEBUG] Watering:", info.Name,
                         "| pos:", tostring(pos),
                         "| can:", canName)
                end
                local ok = _himonoRemoteOk(Net, "WateringCan.UseWateringCan", pos, canName, canTool)
                attemptedThisRound = attemptedThisRound + 1

                if ok then
                    Water._stats.watered = Water._stats.watered + 1
                    wateredThisRound = wateredThisRound + 1
                else
                    Water._stats.errors = Water._stats.errors + 1
                    if Water._debug then warn("[Water][DEBUG] Fire failed for:", info.Name) end
                end
            end
        end

        task.wait(0.5) -- cooldown between plants (match TryWater 0.5s cooldown)
    end

    if Water._debug and wateredThisRound > 0 then
        warn("[Water][DEBUG] Round done. Watered:", wateredThisRound,
             "| Total:", Water._stats.watered,
             "| Errors:", Water._stats.errors)
    end
end

function Water._findOwnedSprinkler(targets)
    local lp = Players.LocalPlayer
    local function findIn(container, wanted)
        if not container then return nil end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local toolType = tool:GetAttribute("Sprinkler") or tool:GetAttribute("GearName")
                    or tool:GetAttribute("ItemName") or tool.Name:gsub("%s*%b[]", "")
                if _himonoLower(toolType) == _himonoLower(wanted) then return tool end
            end
        end
        return nil
    end
    for _, sprinklerType in ipairs(type(targets) == "table" and targets or {}) do
        local wanted = _himonoTrimString(sprinklerType)
        if wanted ~= "" then
            local tool = findIn(lp and lp.Character, wanted) or findIn(lp and lp:FindFirstChild("Backpack"), wanted)
            if tool then return tool, wanted end
        end
    end
    return nil, nil
end

function Water._countPlacedSprinklers(garden)
    local count = 0
    local seen = setmetatable({}, { __mode = "k" })
    for _, desc in ipairs(garden and garden:GetDescendants() or {}) do
        local isSprinkler = string.find(_himonoLower(desc.Name), "sprinkler", 1, true) ~= nil
            or _himonoLower(desc:GetAttribute("ItemType")) == "sprinkler"
        if isSprinkler then
            local root = desc:IsA("Model") and desc or desc:FindFirstAncestorWhichIsA("Model") or desc
            if not seen[root] then
                seen[root] = true
                count = count + 1
            end
        end
    end
    return count
end

function Water._placeAutomaticSprinkler(config, Net, Utils, garden)
    local sprinklerTool, sprinklerType = Water._findOwnedSprinkler(config.Water.TargetSprinklers)
    if not sprinklerType then return false end

    local bestPosition
    local bestValue = -1
    for _, plant in ipairs(Utils.getPlantsInGarden(garden)) do
        local root = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
        if root then
            local seedName = plant:GetAttribute("SeedName") or plant.Name
            local value = _himonoLookupNumber(Resources.SellValues, seedName, 0)
            if value > bestValue then
                bestValue = value
                bestPosition = root.Position
            end
        end
    end
    if not bestPosition then return false end

    local beforeCount = Water._countPlacedSprinklers(garden)
    local sent = Water.placeSprinkler(Net, Utils, sprinklerType, bestPosition)
    local confirmed = false
    if sent then
        local deadline = os.clock() + 2
        repeat
            task.wait(0.1)
            confirmed = not sprinklerTool.Parent or Water._countPlacedSprinklers(garden) > beforeCount
        until confirmed or os.clock() >= deadline
    end
    if confirmed then Water._stats.sprinklers = Water._stats.sprinklers + 1 else Water._stats.errors = Water._stats.errors + 1 end
    return confirmed
end

---------------------------------------------------------------
-- PLACE SPRINKLER (utility)
---------------------------------------------------------------

function Water.placeSprinkler(Net: any, Utils: any, sprinklerType: any, targetPosition: any): boolean
    local garden = Utils.getMyGarden()
    if not garden then return false end

    local spawnPoint = garden:FindFirstChild("SpawnPoint", true)
    local position: any = typeof(targetPosition) == "Vector3" and targetPosition or nil
    if not position then
        if spawnPoint and spawnPoint:IsA("BasePart") then
            position = spawnPoint.Position
        elseif spawnPoint and spawnPoint:IsA("Attachment") then
            position = spawnPoint.WorldPosition
        elseif garden:IsA("Model") then
            position = garden:GetPivot().Position
        end
    end
    if not position then return false end

    local ok = _himonoRemoteOk(Net, "Place.PlaceSprinkler", position, sprinklerType or "Common Sprinkler")
    return ok
end

