function Utils.formatNumber(n)
    n = tonumber(n) or 0
    local sign = n < 0 and "-" or ""
    local absolute = math.abs(n)
    if absolute >= 1e12 then return sign .. string.format("%.1fT", absolute / 1e12) end
    if absolute >= 1e9  then return sign .. string.format("%.1fB", absolute / 1e9) end
    if absolute >= 1e6  then return sign .. string.format("%.1fM", absolute / 1e6) end
    if absolute >= 1e3  then return sign .. string.format("%.1fK", absolute / 1e3) end
    return sign .. tostring(absolute)
end

function Utils.formatTime(seconds)
    seconds = math.max(0, tonumber(seconds) or 0)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    if h > 0 then return string.format("%dh %dm %ds", h, m, s) end
    if m > 0 then return string.format("%dm %ds", m, s) end
    return string.format("%ds", s)
end

