---------------------------------------------------------------
-- AUTO PLANT LOGIC
-- Flow: equip seed from backpack -> fill all empty spots -> unequip
---------------------------------------------------------------

function Plant._autoPlant(plantConfig, Net, Utils)
    Plant._stats.scans = Plant._stats.scans + 1

    local preferSeed = plantConfig.PreferSeed -- optional: preferred seed name

    -- Step 1: USE SEED - equip from backpack before planting
    local seedName, toolInstance = Plant._equipSeed(preferSeed, plantConfig)
    if not seedName then
        Plant._stats.noSeeds = Plant._stats.noSeeds + 1
        return
    end

    -- Step 2: Get plot
    local myPlot = Plant._getMyPlot()
    if not myPlot then
        Plant._unequipTool()
        return
    end
    local maxPlants = math.floor(_himonoClampNumber(plantConfig.MaxPlants, 200, 1, 1000))
    local currentPlants = Plant._getPlantCount(myPlot)
    if currentPlants >= maxPlants then
        Plant._shovelWeakPlants(plantConfig, Net, Utils, myPlot, false)
        Plant._unequipTool()
        return
    end

    -- Step 3: Find empty spots - grid scan across all PlantArea parts
    local spacing = plantConfig.GridSpacing or 3
    local sortMode = plantConfig.PlantOrder or "Top"
    local maxPerCycle = math.min(math.floor(_himonoClampNumber(plantConfig.MaxPerCycle, 10, 1, 50)), maxPlants - currentPlants)
    local spots = nil
    if plantConfig.SingleSpot then
        local fixedSpot = Plant._getSingleSpot(myPlot)
        spots = {}
        if fixedSpot then
            for _ = 1, maxPerCycle do table.insert(spots, fixedSpot) end
        end
    else
        spots = Plant._findEmptySpots(myPlot, spacing, sortMode)
    end
    if #spots == 0 then
        Plant._shovelWeakPlants(plantConfig, Net, Utils, myPlot, true)
        Plant._unequipTool()
        return
    end

    print("[himono Hub] Found", #spots, "empty spots in plot")

    -- Step 4: plant a bounded batch so other automation can use the equipped tool.
    local planted = 0
    local attempted = 0
    for _, pos in ipairs(spots) do
        if not Plant._running then break end
        if attempted >= maxPerCycle then break end
        if Plant._getPlantCount(myPlot) >= maxPlants then break end
        attempted = attempted + 1

        -- Verify still equipped before each fire
        local curSn, curTool = Plant._getEquippedSeed()
        if not curSn then
            -- Re-equip if tool got consumed
            seedName, toolInstance = Plant._equipSeed(preferSeed, plantConfig)
            if not seedName then break end
        else
            seedName, toolInstance = curSn, curTool
        end

        local plantPos = pos
        local canPlant = true
        if not plantConfig.SingleSpot then
            local jitter = _himonoClampNumber(plantConfig.RandomJitter, 1.25, 0, math.max(0, spacing * 0.4))
            if jitter > 0 then
                plantPos = plantPos + Vector3.new((math.random() * 2 - 1) * jitter, 0, (math.random() * 2 - 1) * jitter)
            end
            -- Earlier plants in this same batch may make a precomputed spot invalid.
            if not Plant._isPosEmpty(plantPos, myPlot, 2.5) then
                plantPos = pos
                if not Plant._isPosEmpty(plantPos, myPlot, 2.5) then canPlant = false end
            end
        end
        if canPlant then
            local beforeCount = Plant._getPlantCount(myPlot)
            local ok = _himonoRemoteOk(Net, "Plant.PlantSeed", plantPos, seedName, toolInstance)

            if ok and Plant._confirmPlanted(plantPos, myPlot, beforeCount) then
                planted = planted + 1
                Plant._stats.planted = Plant._stats.planted + 1
                print("[himono Hub] Planted:", seedName, "at", tostring(plantPos))
            else
                Plant._stats.errors = Plant._stats.errors + 1
            end

            task.wait(0.3) -- small delay between plants
        end
    end

    -- Step 5: Unequip after planting
    Plant._unequipTool()

    if planted > 0 then
        print("[himono Hub] Auto-Plant cycle: planted", planted, seedName)
    end
end

