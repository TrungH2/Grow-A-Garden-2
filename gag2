Modules.RestockSniper = {}
do
    local M = Modules.RestockSniper
    local Restock = M
Restock._running = false
Restock._thread  = nil
Restock._connections = {}
Restock._stats = { bought = 0, scanned = 0, moneySpent = 0, errors = 0, skipped = 0 }
Restock._stockFolder = nil
Restock._lastStockFolderCheck = 0

-- Seed prices loaded from Resources (resources.lua via loadstring)
local SeedPrices = Resources.SeedPrices or {}

---------------------------------------------------------------
-- GET STOCK VALUES
---------------------------------------------------------------

function Restock._getStockFolder()
    if Restock._stockFolder and Restock._stockFolder.Parent then
        return Restock._stockFolder
    end

    -- Throttle missing-folder checks; otherwise one poll can wait once per target seed.
    local now = os.clock()
    if now - (Restock._lastStockFolderCheck or 0) < 3 then
        return nil
    end
    Restock._lastStockFolderCheck = now

    local ok, folder = pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local stockValues = _himonoFindChildAny(rs, { "StockValues", "Stocks", "Stock" }) or rs:WaitForChild("StockValues", 2)
        local seedShop = stockValues and (_himonoFindChildAny(stockValues, { "SeedShop", "Seeds", "SeedStock" }) or stockValues:WaitForChild("SeedShop", 2))
        local items = seedShop and (_himonoFindChildAny(seedShop, { "Items", "Stock", "Stocks" }) or seedShop:WaitForChild("Items", 2))
        return items
    end)
    Restock._stockFolder = (ok and folder) or nil
    return Restock._stockFolder
end

function Restock._getStock(seedName)
    local folder = Restock._getStockFolder()
    if not folder then return -1 end -- unknown
    local val = _himonoFindChildAny(folder, seedName)
    if not val then return 0 end
    if val:IsA("ValueBase") then return tonumber(val.Value) or 0 end
    -- might be a NumberValue / IntValue directly
    return 0
end

function Restock._waitForStockDecrease(seedName, previousStock, timeout)
    local newStock = previousStock
    local deadline = os.clock() + timeout
    repeat
        task.wait(0.1)
        newStock = Restock._getStock(seedName)
    until newStock < previousStock or newStock < 0 or os.clock() >= deadline
    return newStock
end

function Restock._getRestockTime()
    local ok, val = pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local stockValues = _himonoFindChildAny(rs, { "StockValues", "Stocks", "Stock" }) or rs:WaitForChild("StockValues", 5)
        local seedShop = stockValues and (_himonoFindChildAny(stockValues, { "SeedShop", "Seeds", "SeedStock" }) or stockValues:WaitForChild("SeedShop", 5))
        local unix = seedShop and (_himonoFindChildAny(seedShop, { "UnixNextRestock", "NextRestock", "RestockTime" }) or seedShop:WaitForChild("UnixNextRestock", 5))
        return unix.Value or 0
    end)
    return ok and val or 0
end

