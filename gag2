Modules.AutoHarvest = {}
do
    local M = Modules.AutoHarvest
    local Harvest = M
    Harvest._running = false
    Harvest._thread  = nil
    Harvest._connections = {}
    Harvest._stats = { harvested = 0, scans = 0, errors = 0 }
    Harvest._pending = {}

    ---------------------------------------------------------------
    -- GET MY PLOT (dynamic)
    ---------------------------------------------------------------

    function Harvest._getMyPlot()
        return Utils.getMyGarden()
    end

    function Harvest._isAlive()
        local lp = Players.LocalPlayer
        if not lp then return false end
        local char = lp.Character
        if not char then return false end
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        return hum and hum.Health > 0
    end

    function Harvest._findHarvestPrompt(target)
        if not target or not target.Parent then return nil end
        for _, desc in ipairs(target:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local action = _himonoLower(desc.ActionText or "")
                if desc.Name == "HarvestPrompt" or action == "harvest" then return desc end
            end
        end
        return nil
    end

    function Harvest._isHarvestable(fruitModel)
        if not fruitModel or not fruitModel.Parent then return false end
        if _himonoTruthy(fruitModel:GetAttribute("PlantGrowthReady"), true) == false then return false end
        return Harvest._findHarvestPrompt(fruitModel) ~= nil
    end

    function Harvest._confirmCollected(fruitModel)
        local deadline = os.clock() + 0.8
        repeat
            task.wait(0.08)
            if (not fruitModel) or (not fruitModel.Parent) or (not Harvest._isHarvestable(fruitModel)) then return true end
        until os.clock() >= deadline
        return false
    end

    function Harvest._findFruitById(plantId, fruitId)
        local plot = Harvest._getMyPlot()
        if not plot then return nil end
        local plantsFolder = _himonoFindChildAny(plot, { "Plants", "Plant", "GardenPlants" })
        if not plantsFolder then return nil end
        local wantedPlantId = tostring(plantId or "")
        local wantedFruitId = tostring(fruitId or "")
        for _, plantModel in ipairs(plantsFolder:GetChildren()) do
            local parentPlantId = tostring(plantModel:GetAttribute("PlantId") or "")
            if wantedFruitId == "" and parentPlantId == wantedPlantId then return plantModel end
            local fruitsFolder = _himonoFindChildAny(plantModel, { "Fruits", "Fruit", "Produce", "Harvestables" })
            if fruitsFolder then
                for _, fruitModel in ipairs(fruitsFolder:GetChildren()) do
                    local fruitPlantId = tostring(fruitModel:GetAttribute("PlantId") or parentPlantId)
                    local currentFruitId = tostring(fruitModel:GetAttribute("FruitId") or "")
                    if fruitPlantId == wantedPlantId and currentFruitId == wantedFruitId then
                        return fruitModel
                    end
                end
            end
        end
        return nil
    end

    function Harvest._collectOne(Net, plantId, fruitId, target)
        local plantKey = tostring(plantId or "")
        local fruitKey = tostring(fruitId or "")
        if plantKey == "" then return false, "invalid_id" end
        local key = plantKey .. "|" .. fruitKey
        if Harvest._pending[key] then return false, "pending" end
        Harvest._pending[key] = true

        local sent = _himonoRemoteOk(Net, "Garden.CollectFruit", plantKey, fruitKey)
        local collected = false
        if sent then
            if target then
                collected = Harvest._confirmCollected(target)
            else
                local deadline = os.clock() + 0.8
                repeat
                    task.wait(0.08)
                    local current = Harvest._findFruitById(plantKey, fruitKey)
                    collected = not current or not Harvest._isHarvestable(current)
                until collected or os.clock() >= deadline
            end
        end
        Harvest._pending[key] = nil
        return collected, sent and "not_confirmed" or "send_failed"
    end

    ---------------------------------------------------------------
    -- COLLECT ALL FRUITS ON MY PLOT (direct remote, no prompt)
    -- Two harvest paths:
    --   Multi: Plant -> Fruits -> FruitModel(HarvestPart.HarvestPrompt) -> CollectFruit(plantId, fruitId)
    --   Single: Plant -> HarvestPart.HarvestPrompt (no Fruits folder) -> CollectFruit(plantId, "")
    ---------------------------------------------------------------

    function Harvest._collectAll(Net, harvestConfig)
        if not Harvest._isAlive() then return 0 end

        local plot = Harvest._getMyPlot()
        if not plot then return 0 end
        local count = 0
        local attempted = 0
        local maxPerCycle = math.floor(_himonoClampNumber(harvestConfig and harvestConfig.MaxPerCycle, 50, 1, 200))
        local plantsFolder = _himonoFindChildAny(plot, { "Plants", "Plant", "GardenPlants" })
        if not plantsFolder then return 0 end

        local candidates = {}
        local function estimateValue(target, plantModel)
            local seedName = target:GetAttribute("SeedName") or target:GetAttribute("FruitName")
                or plantModel:GetAttribute("SeedName") or plantModel.Name
            local base = _himonoLookupNumber(Resources.SellValues, seedName, 0)
            local size = tonumber(target:GetAttribute("SizeMultiplier") or target:GetAttribute("Size") or target:GetAttribute("Weight")) or 1
            local mutation = target:GetAttribute("Mutation") or target:GetAttribute("MutationName")
            local multiplier = mutation and _himonoLookupNumber(Config.Mutation.PriceMultipliers, mutation, 1) or 1
            return math.floor(base * (math.max(size, 0.01) ^ 2.65) * (tonumber(multiplier) or 1))
        end

        for _, plantModel in ipairs(plantsFolder:GetChildren()) do
            local parentPlantId = tostring(plantModel:GetAttribute("PlantId") or "")
            local fruitsFolder = _himonoFindChildAny(plantModel, { "Fruits", "Fruit", "Produce", "Harvestables" })
            if fruitsFolder then
                for _, fruitModel in ipairs(fruitsFolder:GetChildren()) do
                    if Harvest._isHarvestable(fruitModel) then
                        local plantId = tostring(fruitModel:GetAttribute("PlantId") or parentPlantId)
                        local fruitId = tostring(fruitModel:GetAttribute("FruitId") or "")
                        if plantId ~= "" and fruitId ~= "" then
                            table.insert(candidates, {
                                plantId = plantId, fruitId = fruitId, target = fruitModel,
                                value = estimateValue(fruitModel, plantModel),
                            })
                        end
                    end
                end
            end

            if not fruitsFolder and parentPlantId ~= "" and Harvest._isHarvestable(plantModel) then
                table.insert(candidates, {
                    plantId = parentPlantId, fruitId = "", target = plantModel,
                    value = estimateValue(plantModel, plantModel),
                })
            end
        end

        table.sort(candidates, function(a, b)
            if a.value == b.value then return a.fruitId < b.fruitId end
            return a.value > b.value
        end)

        for _, candidate in ipairs(candidates) do
            if not Harvest._running or attempted >= maxPerCycle or Utils.isFruitInventoryFull() then break end
            attempted = attempted + 1
            local collected, reason = Harvest._collectOne(Net, candidate.plantId, candidate.fruitId, candidate.target)
            if collected then
                count = count + 1
            elseif reason ~= "pending" then
                Harvest._stats.errors = Harvest._stats.errors + 1
            end
            task.wait(0.05)
        end
        return count
    end

    ---------------------------------------------------------------
    -- START
    ---------------------------------------------------------------

    function Harvest.start(config, Net, Utils)
        if Harvest._running then return end
        Harvest._running = true

        -- [METHOD 1] Listen for new fruits and collect immediately
        local fruitAddedConn = Net.on("Garden.FruitAdded", function(plantId, fruitId, fruitName, data)
            if not Harvest._running then return end
            if not Harvest._isAlive() then return end
            if Utils.isFruitInventoryFull() then return end
            task.wait(0.15)
            if not Harvest._running or not Harvest._isAlive() then return end
            if Utils.isFruitInventoryFull() then return end
            local plantKey = tostring(plantId or "")
            local fruitKey = tostring(fruitId or "")
            if fruitKey == "" then return end
            local targetFruit = Harvest._findFruitById(plantKey, fruitKey)
            if not targetFruit or not Harvest._isHarvestable(targetFruit) then return end
            local collected, reason = Harvest._collectOne(Net, plantKey, fruitKey, targetFruit)
            if collected then
                Harvest._stats.harvested = Harvest._stats.harvested + 1
            elseif reason ~= "pending" then
                Harvest._stats.errors = Harvest._stats.errors + 1
            end
        end)
        if fruitAddedConn then
            table.insert(Harvest._connections, fruitAddedConn)
        end

        -- [METHOD 2] Periodic scan - walk garden tree, fire CollectFruit directly
        Harvest._thread = task.spawn(function()
            while Harvest._running do
                runModuleStep("AutoHarvest", Harvest, function()
                    Harvest._stats.scans = Harvest._stats.scans + 1
                    local count = Harvest._collectAll(Net, config.Harvest)
                    Harvest._stats.harvested = Harvest._stats.harvested + count
                end)
                task.wait(_himonoClampNumber(config.Timings.HarvestInterval, 0.5, 0.1, 10))
            end
        end)

        print("[himono Hub] Auto-Harvest started")
    end

    ---------------------------------------------------------------
    -- STOP / STATUS
    ---------------------------------------------------------------

    function Harvest.stop()
        Harvest._running = false
        Harvest._thread = _himonoCancelThread(Harvest._thread)
        Harvest._connections = _himonoDisconnectList(Harvest._connections)
        Harvest._pending = {}
    end

    function Harvest.getStats()
        return Harvest._stats
    end
end

