-- Get elapsed time since start
function Stats.getElapsed()
    return os.clock() - Stats.startTime
end

-- Calculate profit/loss since start
function Stats.getProfit()
    return Utils.getSheckles() - Stats.startSheckles
end

-- Count plants in my garden
function Stats.getPlantCount()
    local garden = Utils.getMyGarden()
    if not garden then return 0 end
    return #Utils.getPlantsInGarden(garden)
end

-- Calculate approximate garden value (all fruits on all plants)
-- Uses SellValueData * size^2.65 as base estimate
function Stats.getGardenValue()
    local garden = Utils.getMyGarden()
    if not garden then return 0 end
    local total = 0
    local plants = _himonoFindChildAny(garden, { "Plants", "Plant", "GardenPlants" })
    if not plants then return 0 end
    for _, plantModel in ipairs(plants:GetChildren()) do
        local seedName = plantModel:GetAttribute("SeedName")
        if seedName then
            local baseEntry = _himonoLookup(Stats._sellData, seedName)
            local baseVal = tonumber(baseEntry)
            if type(baseEntry) == "table" then
                baseVal = tonumber(baseEntry.BaseValue or baseEntry.SellValue or baseEntry.Value or baseEntry.Price)
            end
            if not baseVal then baseVal = _himonoLookupNumber(Resources.SellValues, seedName, 0) end
            baseVal = baseVal or 0
            local fruitsFolder = _himonoFindChildAny(plantModel, { "Fruits", "Fruit", "Produce", "Harvestables" })
            if fruitsFolder then
                for _, fruitModel in ipairs(fruitsFolder:GetChildren()) do
                    local size = tonumber(fruitModel:GetAttribute("SizeMultiplier") or fruitModel:GetAttribute("Size")) or 1
                    local mutation = fruitModel:GetAttribute("Mutation")
                    local mutationData = Stats._mutData
                    if mutation and _himonoLookup(mutationData, mutation) == nil then mutationData = Config.Mutation.PriceMultipliers end
                    total = total + Utils.calculateFruitValue(seedName, size, mutation, { [seedName] = baseVal }, mutationData)
                end
            else
                -- Single-harvest: plant itself has value
                local size = tonumber(plantModel:GetAttribute("SizeMultiplier") or plantModel:GetAttribute("Size")) or 1
                local mutation = plantModel:GetAttribute("Mutation")
                local mutationData = Stats._mutData
                if mutation and _himonoLookup(mutationData, mutation) == nil then mutationData = Config.Mutation.PriceMultipliers end
                total = total + Utils.calculateFruitValue(seedName, size, mutation, { [seedName] = baseVal }, mutationData)
            end
        end
    end
    return total
end

-- Count backpack items and estimate seed value
function Stats.getBackpackInfo()
    local lp = Players and Players.LocalPlayer
    local bp = lp and lp:FindFirstChild("Backpack")
    if not bp then return 0, 0, 0 end
    local totalItems = 0
    local seedCount = 0
    local fruitCount = 0
    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") then
            totalItems = totalItems + 1
            if _himonoGetSeedName(tool) then
                seedCount = seedCount + 1
            else
                local itemTypeLower = _himonoLower(tool:GetAttribute("ItemType"))
                local mainCategoryLower = _himonoLower(tool:GetAttribute("MainCategory"))
                if tool:GetAttribute("FruitName") or tool:GetAttribute("FruitTool")
                    or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
                    or mainCategoryLower == "fruit" or mainCategoryLower == "fruits"
                    or itemTypeLower == "harvestedfruit" or itemTypeLower == "fruit" or itemTypeLower == "fruits" then
                    fruitCount = fruitCount + 1
                end
            end
        end
    end
    return totalItems, seedCount, fruitCount
end

-- Count active modules
function Stats.getActiveModules()
    local count = 0
    local names = {}
    if AntiAfk._running then
        count = count + 1
        table.insert(names, "AntiAfk")
    end
    if AntiAfk._rejoinRunning then
        count = count + 1
        table.insert(names, "AutoRejoin")
    end
    if Performance._boostEnabled then
        count = count + 1
        table.insert(names, "BoostFPS")
    end
    if Performance._screenEnabled then
        count = count + 1
        table.insert(names, "PerformanceScreen")
    end
    for name, active in pairs(Running) do
        if active then
            count = count + 1
            table.insert(names, name)
        end
    end
    return count, names
