local KaitunController = {
    _watchdogThread = nil,
    _nextNetworkRefresh = 0,
    readiness = "booting",
}

local function getKaitunReadiness()
    local missing = {}
    local lp = Players.LocalPlayer
    if not lp then table.insert(missing, "player") end
    if lp and not lp:FindFirstChild("Backpack") then table.insert(missing, "backpack") end
    if not _himonoFindChildAny(workspace, { "Gardens", "GardenPlots", "Plots", "Garden" }) then table.insert(missing, "gardens") end
    if not Utils.getMyGarden() then table.insert(missing, "plot") end
    if not Utils.getHumanoidRootPart() then table.insert(missing, "character") end
    if not Networking._module then table.insert(missing, "network") end
    return #missing == 0, #missing == 0 and "ready" or table.concat(missing, ", ")
end

local function waitForKaitunReadiness()
    local timeout = _himonoClampNumber(Config.Kaitun.ReadinessTimeout, 90, 10, 300)
    local deadline = os.clock() + timeout
    local nextReport = 0
    while Config.Kaitun.OneClick and os.clock() < deadline do
        local ready, state = getKaitunReadiness()
        KaitunController.readiness = state
        if ready then
            pushStartupProgress("Ready", "Player, plot, character and network are ready")
            return true
        end
        if os.clock() >= nextReport then
            pushStartupProgress("Waiting", state)
            nextReport = os.clock() + 10
        end
        if not Networking._module and os.clock() >= KaitunController._nextNetworkRefresh then
            KaitunController._nextNetworkRefresh = os.clock() + 30
            pcall(function() Networking.refreshCache() end)
        end
        task.wait(0.5)
    end
    local _, state = getKaitunReadiness()
    KaitunController.readiness = state
    pushStartupProgress("Degraded", "Starting recoverable loops while waiting for: " .. state)
    return false
end

ensureOneClickModules = function()
    if not Config.Kaitun.OneClick then return end
    if shouldForceOneClickPreset() then
        forceOneClickFeaturePolicy(false, true)
    end
    if not Config.Kaitun.OneClick then return end
    if Config.Features.AntiAfk and not AntiAfk._running then
        local ok, err = pcall(function() AntiAfk.start(Config) end)
        if not ok then ModuleErrors.AntiAfk = tostring(err) end
    end
    if Config.Server.AutoRejoin and not AntiAfk._rejoinRunning then
        local ok, err = pcall(function() AntiAfk.startAutoRejoin(Config) end)
        if not ok then ModuleErrors.AutoRejoin = tostring(err) end
    end
    if Performance._boostEnabled ~= (Config.Performance.BoostFPS == true) then
        Performance.setBoost(Config.Performance.BoostFPS)
    end
    if Performance._screenEnabled ~= (Config.Performance.ScreenEnabled == true) then
        Performance.setScreen(Config.Performance.ScreenEnabled)
    end
    local webhookShouldRun = Config.Webhook.Enabled == true and Config.Webhook.ProfileReport == true
    if Webhook._running ~= webhookShouldRun then Webhook.start() end

    if not Networking._module and os.clock() >= KaitunController._nextNetworkRefresh then
        KaitunController._nextNetworkRefresh = os.clock() + 30
        pcall(function() Networking.refreshCache() end)
    end

    for _, name in ipairs(OneClickFeatures) do
        local mod = Modules[name]
        if Config.Features[name] and (not Running[name] or (mod and mod._running ~= nil and mod._running ~= true)) then
            startModule(name)
        end
    end
end

stopOneClickWatchdog = function()
    KaitunController._watchdogThread = _himonoCancelThread(KaitunController._watchdogThread)
end

startOneClickWatchdog = function()
    stopOneClickWatchdog()
    KaitunController._watchdogThread = task.spawn(function()
        while Config.Kaitun.OneClick do
            ensureOneClickModules()
            local _, state = getKaitunReadiness()
            KaitunController.readiness = state
            task.wait(_himonoClampNumber(Config.Kaitun.WatchdogInterval, 10, 3, 60))
        end
    end)
end

