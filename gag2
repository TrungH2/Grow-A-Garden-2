---------------------------------------------------------------
-- POLL AND BUY - DRAIN STOCK
-- For each target seed: buy in loop until stock == 0
---------------------------------------------------------------

function Restock._pollAndBuy(restockConfig, Net, Utils)
    Restock._stats.scanned = Restock._stats.scanned + 1

    local targets = restockConfig.TargetSeeds or {}
    if #targets == 0 then return end

    -- OneClick buys the next seed only after the current seed tool has been planted.
    -- This prevents cheap seeds from draining the balance forever on a full plot.
    if Config.Kaitun and Config.Kaitun.OneClick and Config.Features.AutoPlant then
        local plantModule = Modules.AutoPlant
        local pendingSeedScore = 0
        if plantModule and type(plantModule._getBestAvailableSeed) == "function" then
            local _, score = plantModule._getBestAvailableSeed(Config.Plant)
            pendingSeedScore = tonumber(score) or 0
        elseif Utils.countSeedTools(Config.Plant) > 0 then
            pendingSeedScore = 1
        end
        if pendingSeedScore > 0 then
            Restock._stats.skipped = Restock._stats.skipped + 1
            return
        end
    end

    local blacklist = {}
    for _, name in ipairs(restockConfig.BlacklistedSeeds or {}) do
        blacklist[name] = true
    end

    local reserve = _himonoClampNumber(restockConfig.ReserveSheckles, 0, 0, math.huge)
    local sheckles = Utils.getSheckles()
    local minSeedPrice = 0
    if restockConfig.WealthScaling ~= false then
        for _, tier in ipairs(restockConfig.WealthTiers or {}) do
            if type(tier) == "table" then
                local balance = tonumber(tier.Balance) or math.huge
                if sheckles >= balance then
                    minSeedPrice = math.max(minSeedPrice, tonumber(tier.MinSeedPrice) or 0)
                end
            end
        end
    end
    local candidates = {}
    local seenTargets = {}
    for index, seedName in ipairs(targets) do
        if type(seedName) == "string" and seedName ~= "" and not seenTargets[seedName] and not blacklist[seedName] then
            seenTargets[seedName] = true
            local price = _himonoLookupNumber(SeedPrices, seedName, 0)
            local stock = Restock._getStock(seedName)
            local meetsWealthTier = price <= 0 or price >= minSeedPrice
            if stock > 0 and meetsWealthTier and (price <= 0 or sheckles - price >= reserve) then
                table.insert(candidates, { name = seedName, price = price, stock = stock, index = index })
            else
                Restock._stats.skipped = Restock._stats.skipped + 1
            end
        end
    end
    if #candidates == 0 then return end

    if restockConfig.PreferHighestAffordable ~= false then
        table.sort(candidates, function(a, b)
            if a.price ~= b.price then return a.price > b.price end
            return a.index > b.index
        end)
    else
        table.sort(candidates, function(a, b)
            if a.price ~= b.price then return a.price < b.price end
            return a.index < b.index
        end)
    end

    local totalBought = 0
    local maxTotal = math.floor(_himonoClampNumber(restockConfig.MaxTotalBuysPerCycle, 1, 1, 20))
    for _, candidate in ipairs(candidates) do
        if not Restock._running or totalBought >= maxTotal then break end
        local seedName, price, stock = candidate.name, candidate.price, candidate.stock
        local buyCount = 0
        local maxBuys = math.min(math.floor(stock), math.floor(_himonoClampNumber(restockConfig.MaxBuysPerItem, 1, 1, 100)), maxTotal - totalBought)
        for i = 1, maxBuys do
            if not Restock._running then break end

            -- Re-check affordability inside loop
            if price > 0 and Utils.getSheckles() - price < reserve then break end

            local prevStock = Restock._getStock(seedName)
            if prevStock < 0 then
                Restock._stats.skipped = Restock._stats.skipped + 1
                break
            end
            local acquired, boughtOk, newStock = _himonoWithLock("movement", "RestockSniper", 0.5, function()
                local root = Utils.getHumanoidRootPart()
                if root then _himonoRememberMovement("RestockSniper", root) end
                local movedToShop = _himonoRequestTeleport(Net, { "Seeds", "SeedShop", "Shop" })
                if movedToShop then task.wait(0.5) end
                local sent = Restock._running and Restock._buySeed(Net, seedName) or false
                local currentStock = sent and Restock._waitForStockDecrease(seedName, prevStock, 2) or prevStock
                if movedToShop then _himonoRequestTeleport(Net, { "Garden", "Gardens", "Plot", "Home" }) end
                _himonoForgetMovement("RestockSniper")
                return sent, currentStock
            end)
            if not acquired then
                Restock._stats.skipped = Restock._stats.skipped + 1
                break
            end
            if not boughtOk then break end
            newStock = tonumber(newStock) or prevStock
            if newStock < 0 then
                Restock._stats.skipped = Restock._stats.skipped + 1
                break
            end

            if newStock < prevStock then
                buyCount = buyCount + 1
                totalBought = totalBought + 1
                Restock._stats.bought = Restock._stats.bought + 1
                Restock._stats.moneySpent = Restock._stats.moneySpent + price
            else
                Restock._stats.errors = Restock._stats.errors + 1
                break -- stock didn't change, buy failed
            end
        end

        if buyCount > 0 then
            print("[himono Hub] Progression seed bought:", seedName, "x" .. buyCount, "(stock was:", stock .. ")")
        end
    end
end

---------------------------------------------------------------
-- BUY SEED (actual remote) - returns ok, price
---------------------------------------------------------------

function Restock._buySeed(Net, seedName)
    local acquired, ok = _himonoWithLock("shop", "RestockSniper", 0.5, function()
        return _himonoRemoteOk(Net, "SeedShop.PurchaseSeed", seedName)
    end)
    if not acquired then return false, 0 end
    if ok then
        return true, 0
    end
    Restock._stats.errors = Restock._stats.errors + 1
    return false, 0
end

---------------------------------------------------------------
-- STOP / STATUS
---------------------------------------------------------------

function Restock.stop()
    Restock._running = false
    Restock._thread = _himonoCancelThread(Restock._thread)
    Restock._connections = _himonoDisconnectList(Restock._connections)
    _himonoRestoreMovement("RestockSniper")
end

function Restock.getStats()
    return Restock._stats
end
end

