local Performance = {
    _boostEnabled = false,
    _screenEnabled = false,
    _screenGui = nil,
    _screenToggle = nil,
    _syncingScreenToggle = false,
    _boostConnections = {},
    _inputConnection = nil,
    _saved = setmetatable({}, { __mode = "k" }),
    _savedQualityLevel = nil,
    _qualitySaved = false,
    _generation = 0,
    _stats = { optimized = 0, restored = 0 },
}

local PerformancePropertyRules = {
    BasePart = { CastShadow = false },
    Decal = { Transparency = 1 },
    Texture = { Transparency = 1 },
    ParticleEmitter = { Enabled = false },
    Trail = { Enabled = false },
    Beam = { Enabled = false },
    Smoke = { Enabled = false },
    Fire = { Enabled = false },
    Sparkles = { Enabled = false },
    PointLight = { Enabled = false },
    SpotLight = { Enabled = false },
    SurfaceLight = { Enabled = false },
    Highlight = { Enabled = false },
    PostEffect = { Enabled = false },
}

local function saveAndSetPerformanceProperty(instance, property, value)
    local savedProperties = Performance._saved[instance]
    if not savedProperties then
        savedProperties = {}
        Performance._saved[instance] = savedProperties
    end
    if savedProperties[property] == nil then
        local readOk, original = pcall(function() return instance[property] end)
        if not readOk then return false end
        savedProperties[property] = { value = original }
    end
    local writeOk = pcall(function() instance[property] = value end)
    return writeOk
end

local function optimizePerformanceInstance(instance)
    if not Performance._boostEnabled or not instance then return end
    if Config.Performance.MuteSounds == true and instance:IsA("Sound") then
        if saveAndSetPerformanceProperty(instance, "Volume", 0) then Performance._stats.optimized = Performance._stats.optimized + 1 end
    end
    if Config.Performance.HideOtherPlayers == true and instance:IsA("BasePart") then
        local ancestor = instance.Parent
        while ancestor and ancestor ~= workspace do
            if ancestor:IsA("Model") then
                local owner = Players:GetPlayerFromCharacter(ancestor)
                if owner and owner ~= Players.LocalPlayer then
                    if saveAndSetPerformanceProperty(instance, "LocalTransparencyModifier", 1) then
                        Performance._stats.optimized = Performance._stats.optimized + 1
                    end
                    break
                end
            end
            ancestor = ancestor.Parent
        end
    end
    for className, properties in pairs(PerformancePropertyRules) do
        if instance:IsA(className) then
            for property, value in pairs(properties) do
                if saveAndSetPerformanceProperty(instance, property, value) then
                    Performance._stats.optimized = Performance._stats.optimized + 1
                end
            end
            break
        end
    end
end

local function restorePerformanceProperties()
    for instance, properties in pairs(Performance._saved) do
        if instance and instance.Parent then
            for property, original in pairs(properties) do
                if pcall(function() instance[property] = original.value end) then
                    Performance._stats.restored = Performance._stats.restored + 1
                end
            end
        end
    end
    Performance._saved = setmetatable({}, { __mode = "k" })
end

function Performance.setBoost(enabled)
    enabled = enabled == true
    Config.Performance.BoostFPS = enabled
    if Performance._boostEnabled == enabled then return end
    Performance._boostEnabled = enabled
    Performance._generation = Performance._generation + 1
    local generation = Performance._generation

    if not enabled then
        Performance._boostConnections = _himonoDisconnectList(Performance._boostConnections)
        restorePerformanceProperties()
        if Performance._qualitySaved then
            pcall(function() settings().Rendering.QualityLevel = Performance._savedQualityLevel end)
            Performance._savedQualityLevel = nil
            Performance._qualitySaved = false
        end
        return
    end

    local lighting = game:GetService("Lighting")
    local soundService = game:GetService("SoundService")
    local playerGui = Players.LocalPlayer and Players.LocalPlayer:FindFirstChildOfClass("PlayerGui")
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    saveAndSetPerformanceProperty(lighting, "GlobalShadows", false)
    saveAndSetPerformanceProperty(lighting, "EnvironmentDiffuseScale", 0)
    saveAndSetPerformanceProperty(lighting, "EnvironmentSpecularScale", 0)
    saveAndSetPerformanceProperty(lighting, "ShadowSoftness", 0)
    if terrain then
        saveAndSetPerformanceProperty(terrain, "WaterWaveSize", 0)
        saveAndSetPerformanceProperty(terrain, "WaterWaveSpeed", 0)
        saveAndSetPerformanceProperty(terrain, "WaterReflectance", 0)
    end
    if Config.Performance.LowQuality == true then
        pcall(function()
            Performance._savedQualityLevel = settings().Rendering.QualityLevel
            Performance._qualitySaved = true
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        end)
    end

    table.insert(Performance._boostConnections, game.DescendantAdded:Connect(optimizePerformanceInstance))
    task.spawn(function()
        local processed = 0
        for _, root in ipairs({ workspace, lighting, soundService, playerGui }) do
            if root then
                for _, instance in ipairs(root:GetDescendants()) do
                    if not Performance._boostEnabled or Performance._generation ~= generation then return end
                    optimizePerformanceInstance(instance)
                    processed = processed + 1
                    if processed % 400 == 0 then task.wait() end
                end
            end
        end
    end)
end

function Performance.refreshBoost()
    if not Performance._boostEnabled then return end
    Performance.setBoost(false)
    Performance.setBoost(true)
end

local function getPerformanceScreenColor()
    if _himonoLower(Config.Performance.ScreenColor or "Black") == "white" then
        return Color3.new(1, 1, 1), Color3.new(0, 0, 0)
    end
    return Color3.new(0, 0, 0), Color3.new(1, 1, 1)
end

local function ensurePerformanceScreen()
    if Performance._screenGui and Performance._screenGui.Parent then
        return Performance._screenGui
    end
    local playerGui = Players.LocalPlayer and Players.LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return nil end
    local old = playerGui:FindFirstChild("himonoPerformanceScreen")
    if old then old:Destroy() end

    local backgroundColor, textColor = getPerformanceScreenColor()
    local gui = Instance.new("ScreenGui")
    gui.Name = "himonoPerformanceScreen"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 1000000
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local background = Instance.new("Frame")
    background.Name = "Background"
    background.Size = UDim2.fromScale(1, 1)
    background.BackgroundColor3 = backgroundColor
    background.BorderSizePixel = 0
    background.Parent = gui

    local status = Instance.new("TextLabel")
    status.Name = "Status"
    status.AnchorPoint = Vector2.new(0.5, 0.5)
    status.Position = UDim2.fromScale(0.5, 0.5)
    status.Size = UDim2.fromOffset(320, 42)
    status.BackgroundTransparency = 1
    status.Text = "himono OneClick is running"
    status.TextColor3 = textColor
    status.TextSize = 18
    status.Font = Enum.Font.SourceSansSemibold
    status.Parent = background

    local close = Instance.new("TextButton")
    close.Name = "Close"
    close.AnchorPoint = Vector2.new(1, 0)
    close.Position = UDim2.new(1, -14, 0, 14)
    close.Size = UDim2.fromOffset(36, 36)
    close.BackgroundColor3 = textColor
    close.BackgroundTransparency = 0.85
    close.BorderSizePixel = 0
    close.Text = "X"
    close.TextColor3 = backgroundColor
    close.TextSize = 16
    close.Font = Enum.Font.SourceSansBold
    close.Parent = background
    close.Activated:Connect(function()
        Performance.setScreen(false)
    end)

    gui.Parent = playerGui
    Performance._screenGui = gui
    return gui
end

function Performance.setScreen(enabled)
    enabled = enabled == true
    Config.Performance.ScreenEnabled = enabled
    Performance._screenEnabled = enabled
    if Performance._screenToggle and not Performance._syncingScreenToggle then
        Performance._syncingScreenToggle = true
        pcall(function() Performance._screenToggle:Set(enabled) end)
        Performance._syncingScreenToggle = false
    end
    local gui = ensurePerformanceScreen()
    if gui then
        local backgroundColor, textColor = getPerformanceScreenColor()
        local background = gui:FindFirstChild("Background")
        if background then
            background.BackgroundColor3 = backgroundColor
            local status = background:FindFirstChild("Status")
            if status then status.TextColor3 = textColor end
            local close = background:FindFirstChild("Close")
            if close then
                close.BackgroundColor3 = textColor
                close.TextColor3 = backgroundColor
            end
        end
        gui.Enabled = enabled
    end
    local renderEnabled = not (enabled and Config.Performance.Disable3DRendering ~= false)
    pcall(function()
        game:GetService("RunService"):Set3dRenderingEnabled(renderEnabled)
    end)
end

function Performance.setScreenColor(colorName)
    local normalized = _himonoLower(colorName or "Black") == "white" and "White" or "Black"
    Config.Performance.ScreenColor = normalized
    if Performance._screenGui then Performance.setScreen(Performance._screenEnabled) end
end

function Performance.start()
    Performance.setBoost(Config.Performance.BoostFPS)
    Performance.setScreen(Config.Performance.ScreenEnabled)
    if Performance._inputConnection then
        pcall(function() Performance._inputConnection:Disconnect() end)
        Performance._inputConnection = nil
    end
    local keyCode = Enum.KeyCode[tostring(Config.Performance.ToggleKey or "F8")]
    if keyCode then
        local inputService = game:GetService("UserInputService")
        Performance._inputConnection = inputService.InputBegan:Connect(function(input, processed)
            if not processed and input.KeyCode == keyCode then
                Performance.setScreen(not Performance._screenEnabled)
            end
        end)
    end
end

function Performance.stop()
    Performance.setScreen(false)
    Performance.setBoost(false)
    if Performance._inputConnection then
        pcall(function() Performance._inputConnection:Disconnect() end)
        Performance._inputConnection = nil
    end
    if Performance._screenGui then
        pcall(function() Performance._screenGui:Destroy() end)
        Performance._screenGui = nil
    end
end

function Performance.getStats()
    return Performance._stats
end


