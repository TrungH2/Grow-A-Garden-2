do
    local M = Modules.AutoBuyPet
    local Pet = M
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
Pet._running = false
Pet._thread  = nil
Pet._connections = {}
Pet._stats = { hatched = 0, kept = 0, sold = 0, errors = 0, noEggs = 0, metadataWaits = 0 }

-- Rarity priority (lower = more common)
local RARITY_ORDER = {
    Common = 1, Uncommon = 2, Rare = 3,
    Epic = 4, Legendary = 5, Mythic = 6, Super = 7,
    Divine = 8, Prismatic = 9,
}

local function getRarityRank(value)
    local text = tostring(value or "")
    local direct = RARITY_ORDER[text]
    if direct then return direct end
    local wanted = _himonoLower(text)
    for name, rank in pairs(RARITY_ORDER) do
        if _himonoLower(name) == wanted then return rank end
    end
    return nil
end

-- Load PetData in the background. Only auto-sell pauses while metadata is unavailable.
local PetData = nil
Pet._petDataLoaded = false
Pet._petDataLoadStarted = false
Pet._nextPetDataLoadAt = 0
Pet._petDataWarningShown = false

function Pet._ensurePetDataLoaded()
    if Pet._petDataLoaded then return true end
    if Pet._petDataLoadStarted or os.clock() < Pet._nextPetDataLoadAt then return false end
    Pet._petDataLoadStarted = true
    task.spawn(function()
        local ok, result = pcall(function()
            local sharedData = ReplicatedStorage:FindFirstChild("SharedData") or ReplicatedStorage:WaitForChild("SharedData", 10)
            local petDataModule = sharedData and (sharedData:FindFirstChild("PetData") or sharedData:WaitForChild("PetData", 10))
            if petDataModule then
                return require(petDataModule)
            end
            return nil
        end)

        if ok and type(result) == "table" then
            PetData = result
            Pet._petDataLoaded = true
            Pet._petDataWarningShown = false
            print("[himono Hub] PetData loaded")
        else
            Pet._nextPetDataLoadAt = os.clock() + 5
            if not Pet._petDataWarningShown then
                Pet._petDataWarningShown = true
                warn("[himono Hub] PetData unavailable; eggs will open but pets are kept until rarity data loads:", result)
            end
        end
        Pet._petDataLoadStarted = false
    end)
    return false
end
Pet._ensurePetDataLoaded()

-- Get rarity of a pet species from PetData
function Pet._getSpeciesRarity(petName)
    local entry = PetData and PetData[petName]
    if type(entry) == "table" then
        return entry.Rarity
    end
    return nil
end

-- Check if a pet passes the rarity filter
function Pet._passesFilter(petName, size, minRarity)
    local speciesRarity = Pet._getSpeciesRarity(petName)
    if not speciesRarity then return nil end
    local gotRank = getRarityRank(speciesRarity)
    local wantRank = getRarityRank(minRarity) or RARITY_ORDER.Rare
    if not gotRank then return nil end
    if gotRank < wantRank then return false end
    return true
end

