-- FIND EGG TOOLS IN BACKPACK / CHARACTER
-- Tools with "Egg" attribute = egg name
---------------------------------------------------------------

function Pet._findEggTools()
    local lp = Players.LocalPlayer
    local backpack = lp and lp:FindFirstChild("Backpack")
    local eggs = {}
    local seen = setmetatable({}, { __mode = "k" })
    local function scan(container)
        if not container then return end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") and not seen[tool] then
                local eggName = tool:GetAttribute("Egg")
                if eggName and eggName ~= "" then
                    seen[tool] = true
                    table.insert(eggs, { tool = tool, eggName = eggName })
                end
            end
        end
    end
    scan(backpack)
    scan(lp and lp.Character)
    return eggs
end

---------------------------------------------------------------
-- HATCH ONE EGG
-- 1. Listen for ReplicateOpenEgg once
-- 2. Fire Egg.OpenEgg(eggName)
-- 3. Wait for result (petName, size, type)
-- 4. Fire Egg.ConfirmEgg(eggName, petName, size)
---------------------------------------------------------------

function Pet._hatchEgg(eggName, Net)
    local result = nil
    local done = false
    local conn = nil

    local function disconnectListener()
        if conn then pcall(function() conn:Disconnect() end) end
        local index = conn and table.find(Pet._connections, conn)
        if index then table.remove(Pet._connections, index) end
        conn = nil
    end

    -- Hook ReplicateOpenEgg once
    conn = Net.on("Egg.ReplicateOpenEgg", function(player, eName, petName, size, pos, petType, extra)
        if player == Players.LocalPlayer and eName == eggName then
            result = { petName = petName, size = size, petType = petType }
            done = true
            disconnectListener()
        end
    end)
    if not conn then return nil end
    table.insert(Pet._connections, conn)

    -- Fire OpenEgg
    local fireOk = _himonoRemoteOk(Net, "Egg.OpenEgg", eggName)

    if not fireOk then
        disconnectListener()
        return nil
    end

    -- Wait for result (max 5s)
    local t = 0
    while not done and t < 5 do
        task.wait(0.1)
        t = t + 0.1
    end

    disconnectListener()

    if not result then return nil end

    -- Confirm the egg
    if not _himonoRemoteOk(Net, "Egg.ConfirmEgg", eggName, result.petName, result.size or "") then
        return nil
    end

    return result
end

