---------------------------------------------------------------
-- AUTO SELL LOGIC
---------------------------------------------------------------

function Sell._autoSell(sellConfig, Net, Utils)
    -- Guard: skip if no fruits in backpack
    local lp = Players.LocalPlayer
    local bp = lp and lp:FindFirstChild("Backpack")
    local beforeFruitCount = lp and tonumber(lp:GetAttribute("FruitCount")) or nil
    local beforeSheckles = Utils.getSheckles()
    local hasFruit = beforeFruitCount ~= nil and beforeFruitCount > 0
    local trackedFruitTools = {}
    if bp then
        for _, tool in ipairs(bp:GetChildren()) do
            local itemType = tool:GetAttribute("ItemType")
            local itemTypeLower = _himonoLower(itemType)
            local mainCategoryLower = _himonoLower(tool:GetAttribute("MainCategory"))
            if tool:IsA("Tool") and (tool:GetAttribute("FruitName") or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
                or tool:GetAttribute("FruitTool") or mainCategoryLower == "fruit" or mainCategoryLower == "fruits"
                or itemTypeLower == "harvestedfruit" or itemTypeLower == "fruit" or itemTypeLower == "fruits") then
                hasFruit = true
                table.insert(trackedFruitTools, tool)
            end
        end
    end
    -- Also check character (equipped tool)
    if not hasFruit and lp and lp.Character then
        for _, tool in ipairs(lp.Character:GetChildren()) do
            local itemType = tool:GetAttribute("ItemType")
            local itemTypeLower = _himonoLower(itemType)
            local mainCategoryLower = _himonoLower(tool:GetAttribute("MainCategory"))
            if tool:IsA("Tool") and (tool:GetAttribute("FruitName") or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
                or tool:GetAttribute("FruitTool") or mainCategoryLower == "fruit" or mainCategoryLower == "fruits"
                or itemTypeLower == "harvestedfruit" or itemTypeLower == "fruit" or itemTypeLower == "fruits") then
                hasFruit = true
                table.insert(trackedFruitTools, tool)
            end
        end
    end
    if not hasFruit then return end

    local mode = sellConfig.Mode or "all"
    local function withSellLocation(callback)
        return _himonoWithLock("movement", "AutoSell", 0.5, function()
            local root = Utils.getHumanoidRootPart()
            if root then _himonoRememberMovement("AutoSell", root) end
            local movedToSell = _himonoRequestTeleport(Net, { "Sell", "Steven", "NPCS" })
            if movedToSell then task.wait(0.5) end
            local result = callback()
            if movedToSell then _himonoRequestTeleport(Net, { "Garden", "Gardens", "Plot", "Home" }) end
            _himonoForgetMovement("AutoSell")
            return result
        end)
    end

    if mode == "all" then
        local function waitForSellConfirmation(timeout)
            local deadline = os.clock() + timeout
            repeat
                task.wait(0.1)
                local currentFruitCount = tonumber(lp:GetAttribute("FruitCount"))
                if beforeFruitCount ~= nil and currentFruitCount ~= nil and currentFruitCount < beforeFruitCount then
                    return true
                end
                if Utils.getSheckles() > beforeSheckles then return true end
                if beforeFruitCount == nil and #trackedFruitTools > 0 then
                    local anyTracked = false
                    for _, tool in ipairs(trackedFruitTools) do
                        if tool and tool.Parent then
                            anyTracked = true
                            break
                        end
                    end
                    if not anyTracked then return true end
                end
            until os.clock() >= deadline
            return false
        end

        local sent = _himonoRemoteOk(Net, "NPCS.SellAll")
        local confirmed = sent and waitForSellConfirmation(1.5) or false
        if not confirmed then
            local acquired, fallbackConfirmed = withSellLocation(function()
                local sold = false
                if Sell._running and _himonoRemoteOk(Net, "NPCS.SellAll") then
                    sold = waitForSellConfirmation(2)
                end
                return sold
            end)
            confirmed = acquired and fallbackConfirmed == true
        end
        if confirmed then
            Sell._stats.sold = Sell._stats.sold + 1
        else
            Sell._stats.errors = Sell._stats.errors + 1
        end

    elseif mode == "below_threshold" then
        -- Individual NPC actions are performed at Steven's stand.
        local acquired = withSellLocation(function()
            Sell._sellBelowThreshold(sellConfig, Net, Utils)
            return true
        end)
        if not acquired then Sell._stats.errors = Sell._stats.errors + 1 end

    elseif mode == "keep_best" then
        local acquired = withSellLocation(function()
            Sell._sellKeepBest(sellConfig, Net, Utils)
            return true
        end)
        if not acquired then Sell._stats.errors = Sell._stats.errors + 1 end
    end

    -- Use daily deal if configured
    if sellConfig.UseDailyDeal then
        local acquired, used = withSellLocation(function()
            return _himonoRemoteOk(Net, "NPCS.UseDailyDealAll")
        end)
        if not acquired or not used then Sell._stats.errors = Sell._stats.errors + 1 end
    end
end

local function _sellGetFruitToolValue(tool: any): any
    if not tool then return nil end
    local direct = tool:GetAttribute("SellValue") or tool:GetAttribute("Value") or tool:GetAttribute("Price") or tool:GetAttribute("Worth")
    local directValue = tonumber(direct)
    if directValue then return directValue end

    local fruitName = tool:GetAttribute("FruitName")
        or tool:GetAttribute("SeedName")
        or tool:GetAttribute("ItemName")
        or tool.Name
    if type(fruitName) == "string" then
        fruitName = fruitName:gsub("%s*%b[]", ""):gsub("^%s*(.-)%s*$", "%1")
    end

    local base = Resources.SellValues and _himonoLookup(Resources.SellValues, fruitName)
    if not base and type(fruitName) == "string" then
        local withoutDisplaySuffix = fruitName:gsub("%s+Fruit$", "")
        if withoutDisplaySuffix ~= fruitName then
            fruitName = withoutDisplaySuffix
            base = Resources.SellValues and _himonoLookup(Resources.SellValues, fruitName)
        end
    end
    local numericBase = tonumber(base)
    if not numericBase then return nil end

    local size = tonumber(tool:GetAttribute("SizeMultiplier") or tool:GetAttribute("Size") or tool:GetAttribute("Weight") or tool:GetAttribute("Kg")) or 1
    local mutation = tool:GetAttribute("Mutation") or tool:GetAttribute("MutationName")
    local mult = 1
    if mutation and Config.Mutation and Config.Mutation.PriceMultipliers then
        mult = _himonoLookupNumber(Config.Mutation.PriceMultipliers, mutation, 1)
    end
    return math.floor(numericBase * (size ^ 2.65) * mult)
end

local function _sellCollectFruitTools(): {any}
    local result = {}
    local lp = Players.LocalPlayer
    local function scan(container)
        if not container then return end
        for _, tool in ipairs(container:GetChildren()) do
            local itemType = tool:GetAttribute("ItemType")
            local itemTypeLower = _himonoLower(itemType)
            local mainCategoryLower = _himonoLower(tool:GetAttribute("MainCategory"))
            if tool:IsA("Tool") and (tool:GetAttribute("FruitName") or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
                or tool:GetAttribute("FruitTool") or mainCategoryLower == "fruit" or mainCategoryLower == "fruits"
                or itemTypeLower == "harvestedfruit" or itemTypeLower == "fruit" or itemTypeLower == "fruits") then
                table.insert(result, tool)
            end
        end
    end
    scan(lp and lp:FindFirstChild("Backpack"))
    scan(lp and lp.Character)
    return result
end

local function _sellValueBelow(value: any, threshold: any): boolean
    return value ~= nil and value < threshold
end

-- Sell fruits below a certain value threshold.
-- Unknown-value fruits are skipped instead of being sold blindly.
function Sell._sellBelowThreshold(sellConfig: any, Net: any, Utils: any): any
    local threshold = _himonoClampNumber(sellConfig.ValueThreshold, 100, 0, math.huge)
    local processed = 0
    local maxPerCycle = math.floor(_himonoClampNumber(sellConfig.MaxPerCycle, 50, 1, 200))
    for _, tool in ipairs(_sellCollectFruitTools()) do
        if processed >= maxPerCycle then break end
        local value = _sellGetFruitToolValue(tool)
        if _sellValueBelow(value, threshold) then
            processed = processed + 1
            local ok = _himonoRemoteOk(Net, "NPCS.SellFruit", tool.Name)
            if ok then
                Sell._stats.sold = Sell._stats.sold + 1
            else
                Sell._stats.errors = Sell._stats.errors + 1
            end
        end
    end
end

-- Sell known-value fruits below the top N individually. Unknown-value fruits are preserved.
-- This avoids accumulating favorite flags across cycles or touching user favorites.
function Sell._sellKeepBest(sellConfig: any, Net: any, Utils: any): any
    local keepCount = math.floor(_himonoClampNumber(sellConfig.KeepBestCount, 5, 0, 10000))
    local fruits = {}
    for _, tool in ipairs(_sellCollectFruitTools()) do
        local value = _sellGetFruitToolValue(tool)
        if type(value) == "number" then
            table.insert(fruits, { tool = tool, value = value })
        end
    end
    if #fruits == 0 then return end

    table.sort(fruits, function(a, b)
        if a.value == b.value then return a.tool.Name < b.tool.Name end
        return a.value > b.value
    end)

    local processed = 0
    local maxPerCycle = math.floor(_himonoClampNumber(sellConfig.MaxPerCycle, 50, 1, 200))
    for i = keepCount + 1, #fruits do
        if processed >= maxPerCycle then break end
        local tool = fruits[i].tool
        if tool and tool.Parent then
            processed = processed + 1
            if _himonoRemoteOk(Net, "NPCS.SellFruit", tool.Name) then
                Sell._stats.sold = Sell._stats.sold + 1
            else
                Sell._stats.errors = Sell._stats.errors + 1
            end
            task.wait(0.05)
        end
    end
end

