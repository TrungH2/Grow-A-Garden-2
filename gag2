-- SELL PET (find pet tool in backpack by species, sell via NPCS.SellPet)
-- Pet tool attributes: "Pet" = species name, "PetId" = unique ID
---------------------------------------------------------------

function Pet._snapshotPetIds()
    local ids = {}
    local lp = Players.LocalPlayer
    local backpack = lp and lp:FindFirstChild("Backpack")
    local char = lp and lp.Character

    local function scan(container)
        if not container then return end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local petId = tool:GetAttribute("PetId")
                if petId ~= nil then ids[tostring(petId)] = true end
            end
        end
    end
    scan(backpack)
    scan(char)
    return ids
end

function Pet._findAndSellPet(petName, expectedSize, existingPetIds, Net)
    local lp = Players.LocalPlayer
    local backpack = lp and lp:FindFirstChild("Backpack")
    if not backpack then return false end

    -- Also check character (might be equipped)
    local char = lp.Character
    local function scanContainer(container)
        if not container then return nil end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local toolPetName = tool:GetAttribute("Pet")
                if toolPetName == petName then
                    local petId = tool:GetAttribute("PetId")
                    local toolSize = tool:GetAttribute("Size") or tool:GetAttribute("PetSize")
                    local isNewPet = petId ~= nil and not existingPetIds[tostring(petId)]
                    local sizeMatches = expectedSize == nil or toolSize == nil
                        or tostring(toolSize) == tostring(expectedSize)
                    if isNewPet and sizeMatches then
                        return { tool = tool, petId = petId }
                    end
                end
            end
        end
        return nil
    end

    local found = nil
    local waited = 0
    while not found and waited < 5 do
        found = scanContainer(backpack) or scanContainer(char)
        if not found then
            task.wait(0.1)
            waited = waited + 0.1
        end
    end
    if not found then
        warn("[himono Hub] Sell skipped: newly hatched pet could not be identified safely:", petName)
        return false
    end

    -- Equip the tool first (NPC sell requires holding it)
    if char then
        pcall(function()
            local humanoid = char:FindFirstChildWhichIsA("Humanoid")
            if humanoid then humanoid:EquipTool(found.tool) else found.tool.Parent = char end
        end)
        task.wait(0.3)
    end

    -- Fire NPCS.SellPet(petId) - invoke for response
    local ok, result = _himonoInvokeOk(Net, "NPCS.SellPet", found.petId)

    local success = result == true or (type(result) == "table" and result.Success == true)
    if ok and success then
        local sellPrice = type(result) == "table" and result.SellPrice or "?"
        print("[himono Hub] Sold pet:", petName, "for", tostring(sellPrice))
        return true
    end

    pcall(function()
        if found.tool and found.tool.Parent == char and backpack then found.tool.Parent = backpack end
    end)

    return false
end

---------------------------------------------------------------
-- AUTO HATCH LOOP
---------------------------------------------------------------

function Pet._autoHatch(petConfig, Net, Utils)
    local minRarity = petConfig.MinRarity or "Rare"
    local autoSell = petConfig.AutoSellUnwanted or false

    -- Continue opening eggs when metadata is late, but keep every unclassified pet.
    if autoSell and not Pet._petDataLoaded then
        Pet._stats.metadataWaits = Pet._stats.metadataWaits + 1
        Pet._ensurePetDataLoaded()
    end

    -- Find egg tools in backpack
    local eggs = Pet._findEggTools()
    if #eggs == 0 then
        Pet._stats.noEggs = Pet._stats.noEggs + 1
        return
    end

    -- Hatch one egg per cycle
    local egg = eggs[1]
    local existingPetIds = Pet._snapshotPetIds()
    local result = Pet._hatchEgg(egg.eggName, Net)

    if not result then
        Pet._stats.errors = Pet._stats.errors + 1
        return
    end

    Pet._stats.hatched = Pet._stats.hatched + 1
    local speciesRarity = Pet._getSpeciesRarity(result.petName)
    local passes = Pet._passesFilter(result.petName, result.size, minRarity)

    local sizeStr = result.size and (" [" .. tostring(result.size) .. "]") or ""
    print("[himono Hub] Hatched:", result.petName, sizeStr, "(" .. tostring(speciesRarity or "Unknown") .. ")")
    Webhook.notifyRarePet(result.petName, speciesRarity or "Unknown", 0, "Egg hatch")

    if passes == nil then
        Pet._stats.kept = Pet._stats.kept + 1
        warn("[himono Hub] Pet kept because rarity metadata is missing:", result.petName)
    elseif passes then
        Pet._stats.kept = Pet._stats.kept + 1
        print("[himono Hub] KEPT - matches rarity filter:", minRarity .. "+")
    else
        if autoSell then
            local sold = Pet._findAndSellPet(result.petName, result.size, existingPetIds, Net)
            if sold then
                Pet._stats.sold = Pet._stats.sold + 1
                print("[himono Hub] SOLD - below rarity filter")
            end
        else
            print("[himono Hub] Below filter (" .. minRarity .. "+), kept in inventory")
        end
    end
end

