Modules.GearBuyer = {}
do
    local Gear = Modules.GearBuyer
    Gear._running = false
    Gear._thread = nil
    Gear._stats = { scanned = 0, bought = 0, skipped = 0, errors = 0, moneySpent = 0 }
    Gear._stockFolder = nil
    Gear._lastStockFolderCheck = 0

    -- Gear prices loaded from Resources (resources.lua via loadstring)
    local GearCosts = Resources.GearPrices or {}

    function Gear._getGearStockFolder()
        if Gear._stockFolder and Gear._stockFolder.Parent then
            return Gear._stockFolder
        end

        -- Throttle missing-folder checks; otherwise one poll can wait once per target gear.
        local now = os.clock()
        if now - (Gear._lastStockFolderCheck or 0) < 3 then
            return nil
        end
        Gear._lastStockFolderCheck = now

    local ok, folder = pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local stockValues = _himonoFindChildAny(rs, { "StockValues", "Stocks", "Stock" }) or rs:WaitForChild("StockValues", 2)
        local gearShop = stockValues and (_himonoFindChildAny(stockValues, { "GearShop", "Gears", "GearStock" }) or stockValues:WaitForChild("GearShop", 2))
        local items = gearShop and (_himonoFindChildAny(gearShop, { "Items", "Stock", "Stocks" }) or gearShop:WaitForChild("Items", 2))
        return items
    end)
        Gear._stockFolder = (ok and folder) or nil
        return Gear._stockFolder
    end

    function Gear._getStock(gearName)
        local folder = Gear._getGearStockFolder()
        if not folder then return -1 end
        local val = _himonoFindChildAny(folder, gearName)
        if not val then return 0 end
        if val:IsA("ValueBase") then return tonumber(val.Value) or 0 end
        return 0
    end

    function Gear._waitForStockDecrease(gearName, previousStock, timeout)
        local newStock = previousStock
        local deadline = os.clock() + timeout
        repeat
            task.wait(0.1)
            newStock = Gear._getStock(gearName)
        until newStock < previousStock or newStock < 0 or os.clock() >= deadline
        return newStock
    end

    function Gear._buyGear(Net, gearName)
        local acquired, ok = _himonoWithLock("shop", "GearBuyer", 0.5, function()
            return _himonoRemoteOk(Net, "GearShop.PurchaseGear", gearName)
        end)
        if not acquired then return false, 0 end
        if ok then
            return true, 0
        end
        Gear._stats.errors = Gear._stats.errors + 1
        return false, 0
    end

    function Gear._pollAndBuy(gearConfig, Net, Utils)
        Gear._stats.scanned = Gear._stats.scanned + 1

        local targets = gearConfig.TargetGears or {}
        if #targets == 0 then return end

        local seenTargets = {}
        for _, gearName in ipairs(targets) do
            if not Gear._running then break end
            if type(gearName) == "string" and gearName ~= "" and not seenTargets[gearName] then
                seenTargets[gearName] = true
                local skipGear = false

                if gearConfig.SkipOwned ~= false and Utils.ownsTool(gearName) then
                    Gear._stats.skipped = Gear._stats.skipped + 1
                    skipGear = true
                end

                local stock = 0
                if not skipGear then
                    stock = Gear._getStock(gearName)
                    if stock < 0 then
                        -- Stock folder has not replicated or path is unavailable; skip to avoid blind-buy spam.
                        Gear._stats.skipped = Gear._stats.skipped + 1
                        skipGear = true
                    elseif stock == 0 then
                        Gear._stats.skipped = Gear._stats.skipped + 1
                        skipGear = true
                    end
                end

                local cost = _himonoLookupNumber(GearCosts, gearName, 0)
                local sheckles = Utils.getSheckles()
                local reserve = _himonoClampNumber(gearConfig.ReserveSheckles, 1, 0, math.huge)
                if not skipGear and cost > 0 and sheckles - cost < reserve then
                    Gear._stats.skipped = Gear._stats.skipped + 1
                    skipGear = true
                end

                if not skipGear then
                    local buyCount = 0
                    local maxBuys = math.min(math.floor(stock), math.floor(_himonoClampNumber(gearConfig.MaxBuysPerItem, 2, 1, 50)))
                    for i = 1, maxBuys do
                        if not Gear._running then break end

                        -- Re-check affordability inside loop
                        if cost > 0 and Utils.getSheckles() - cost < reserve then break end

                        local prevStock = Gear._getStock(gearName)
                        if prevStock < 0 then
                            Gear._stats.skipped = Gear._stats.skipped + 1
                            break
                        end
                        local acquired, ok, newStock = _himonoWithLock("movement", "GearBuyer", 0.5, function()
                            local root = Utils.getHumanoidRootPart()
                            if root then _himonoRememberMovement("GearBuyer", root) end
                            local movedToShop = _himonoRequestTeleport(Net, { "Gears", "Gear", "GearShop", "Shop", "Seeds" })
                            if movedToShop then task.wait(0.5) end
                            local sent = Gear._running and Gear._buyGear(Net, gearName) or false
                            local currentStock = sent and Gear._waitForStockDecrease(gearName, prevStock, 2) or prevStock
                            if movedToShop then _himonoRequestTeleport(Net, { "Garden", "Gardens", "Plot", "Home" }) end
                            _himonoForgetMovement("GearBuyer")
                            return sent, currentStock
                        end)
                        if not acquired then
                            Gear._stats.skipped = Gear._stats.skipped + 1
                            break
                        end
                        if ok then
                            newStock = tonumber(newStock) or prevStock
                            if newStock < 0 then
                                Gear._stats.skipped = Gear._stats.skipped + 1
                                break
                            end
                            if newStock < prevStock then
                                buyCount = buyCount + 1
                                Gear._stats.bought = Gear._stats.bought + 1
                                Gear._stats.moneySpent = Gear._stats.moneySpent + cost
                            else
                                Gear._stats.errors = Gear._stats.errors + 1
                                break -- stock didn't change, buy failed
                            end
                        else
                            break
                        end
                    end

                    if buyCount > 0 then
                        print("[himono Hub] Gear bought:", gearName, "x" .. buyCount)
                    end
                end
            end
        end
    end
    function Gear.start(config, Net, Utils)
        if Gear._running then return end
        Gear._running = true

        local gearConfig = config.Gear or {}
        Gear._thread = task.spawn(function()
            while Gear._running do
                runModuleStep("GearBuyer", Gear, function()
                    Gear._pollAndBuy(gearConfig, Net, Utils)
                end)
                task.wait(_himonoClampNumber(config.Gear.PollInterval, 5, 1, 120))
            end
        end)

        print("[himono Hub] Gear Buyer started")
    end

    function Gear.stop()
        Gear._running = false
        Gear._thread = _himonoCancelThread(Gear._thread)
        _himonoRestoreMovement("GearBuyer")
    end

    function Gear.getStats()
        return Gear._stats
    end
end
