Modules.ServerHop = {}
do
    local M = Modules.ServerHop
    M._running = false
    M._thread = nil
    M._hopping = false
    M._visited = { [game.JobId] = os.clock() }
    M._stats = { scans = 0, teleports = 0, errors = 0, noServers = 0 }

    local TS = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")
    local LocalPlayer = Players.LocalPlayer
    local PlaceId = game.PlaceId

    local function httpGet(url)
        local ok, result = pcall(function()
            return game:HttpGet(url)
        end)
        if ok and type(result) == "string" and result ~= "" then return result end
        ok, result = pcall(function()
            return HttpService:GetAsync(url)
        end)
        if ok and type(result) == "string" and result ~= "" then return result end
        return nil
    end

    local function fetchServers(serverConfig)
        local allServers = {}
        local cursor = ""
        local pages = 0
        local maxPages = math.floor(_himonoClampNumber(serverConfig.MaxPages, 5, 1, 10))
        while pages < maxPages do
            local url = string.format(
                "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100%s",
                PlaceId,
                cursor ~= "" and ("&cursor=" .. HttpService:UrlEncode(cursor)) or ""
            )
            local raw = httpGet(url)
            if not raw then break end
            local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
            if not ok or type(data) ~= "table" then break end
            local servers = data.data
            if type(servers) ~= "table" or #servers == 0 then break end
            for _, s in ipairs(servers) do
                if type(s) == "table" then table.insert(allServers, s) end
            end
            pages = pages + 1
            cursor = type(data.nextPageCursor) == "string" and data.nextPageCursor or ""
            if cursor == "" then break end
            task.wait(0.5)
        end
        return allServers
    end

    local function pickRandomServer(servers, serverConfig)
        local candidates = {}
        local minPlayers = math.floor(_himonoClampNumber(serverConfig.MinPlayers, 1, 0, 100))
        local maxPlayers = math.floor(_himonoClampNumber(serverConfig.MaxPlayers, 0, 0, 100))
        if maxPlayers > 0 and maxPlayers < minPlayers then maxPlayers = minPlayers end
        local now = os.clock()
        for id, visitedAt in pairs(M._visited) do
            if now - visitedAt > 3600 then M._visited[id] = nil end
        end

        for _, s in ipairs(servers) do
            local id = type(s.id) == "string" and s.id or ""
            local playing = tonumber(s.playing)
            local capacity = tonumber(s.maxPlayers)
            local validServer = id ~= ""
                and id ~= game.JobId
                and playing ~= nil
                and capacity ~= nil
                and capacity > 0
                and playing < capacity
                and playing >= minPlayers
                and (maxPlayers <= 0 or playing <= maxPlayers)
                and (serverConfig.AvoidVisited == false or not M._visited[id])
            if validServer then
                table.insert(candidates, s)
            end
        end
        if #candidates == 0 then return nil end
        return candidates[math.random(1, #candidates)]
    end

    function M.hop(config)
        if M._hopping then return false, "hop already in progress" end
        M._hopping = true
        M._stats.scans = M._stats.scans + 1
        print("[himono Hub] Hop triggered...")
        local serverConfig = (config or Config).Server or {}
        local operationOk, success, reason = xpcall(function()
            local maxRetries = math.floor(_himonoClampNumber(serverConfig.HopRetries, 3, 1, 10))
            local lastReason = "no valid servers"
            for attempt = 1, maxRetries do
                local servers = fetchServers(serverConfig)
                local target = pickRandomServer(servers, serverConfig)
                if target then
                    print("[himono Hub] Hopping to " .. target.id)
                    M._visited[target.id] = os.clock()
                    queueKaitunAfterTeleport(config or Config)
                    local ok, err = pcall(function()
                        TS:TeleportToPlaceInstance(PlaceId, target.id, LocalPlayer)
                    end)
                    if ok then
                        M._stats.teleports = M._stats.teleports + 1
                        return true
                    end
                    M._visited[target.id] = nil
                    M._stats.errors = M._stats.errors + 1
                    lastReason = tostring(err)
                    warn("[himono Hub] Server hop failed:", err)
                end
                if attempt < maxRetries then task.wait(3) end
            end
            return false, lastReason
        end, debug.traceback)
        M._hopping = false
        if not operationOk then
            M._stats.errors = M._stats.errors + 1
            warn("[himono Hub] Server hop error:", success)
            return false, tostring(success)
        end
        if not success then
            if reason == "no valid servers" then M._stats.noServers = M._stats.noServers + 1 end
            warn("[himono Hub] Server hop exhausted retries:", reason)
        end
        return success, reason
    end

    function M.start(config, Net, Utils)
        if M._running then return end
        M._running = true

        local interval = _himonoClampNumber(config.Server.HopInterval, 600, 60, 3600)
        M._thread = task.spawn(function()
            while M._running do
                task.wait(_himonoClampNumber(config.Server.HopInterval, 600, 60, 3600))
                if M._running then
                    runModuleStep("ServerHop", M, function() M.hop(config) end)
                end
            end
        end)
        print("[himono Hub] Auto Server Hop started (every " .. interval .. "s)")
    end

    function M.stop()
        M._running = false
        M._thread = _himonoCancelThread(M._thread)
        M._hopping = false
    end

    function M.getStats()
        return M._stats
    end
end

