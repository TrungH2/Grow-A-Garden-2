        SeedPack._thread = _himonoCancelThread(SeedPack._thread)
        SeedPack._connections = _himonoDisconnectList(SeedPack._connections)
        _himonoRestoreMovement("SeedPackClaimer")
        SeedPack._claiming = setmetatable({}, { __mode = "k" })
    end

    function SeedPack.getStats()
        return SeedPack._stats
    end
