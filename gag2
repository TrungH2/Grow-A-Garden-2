        return
    end

    task.spawn(function()
        local statsFolder = lp and (lp:FindFirstChild("leaderstats") or lp:WaitForChild("leaderstats", 15))
        local sheckles = statsFolder and (statsFolder:FindFirstChild("Sheckles") or statsFolder:WaitForChild("Sheckles", 15))
        if sheckles then
            Stats.startSheckles = tonumber(sheckles.Value) or 0
            Stats.startTime = os.clock()
        end
