Modules.AutoPetCatch = {}
do
    local M = Modules.AutoPetCatch
    M._running = false
    M._thread = nil
    M._connections = {}
    M._stats = { caught = 0, scanned = 0, errors = 0, skipped = 0 }
    M._tamed = setmetatable({}, { __mode = "k" })
    M._catching = setmetatable({}, { __mode = "k" })

    -- Rarity priority: higher = better
    local RARITY_ORDER = {
        Common = 1, Uncommon = 2, Rare = 3, Epic = 4, Legendary = 5,
        Mythic = 6, Super = 7, Divine = 8, Prismatic = 9,
    }

    local function getRarityRank(value)
        local wanted = _himonoLower(value)
        for name, rank in pairs(RARITY_ORDER) do
            if _himonoLower(name) == wanted then return rank end
        end
        return nil
    end

    function M._passesFilter(refPart, petCatchConfig)
        if not refPart then return false end
        local rarity = tostring(refPart:GetAttribute("Rarity") or "")
        local ownerUserId = tonumber(refPart:GetAttribute("OwnerUserId")) or 0
        local state = _himonoLower(refPart:GetAttribute("State") or "")

        -- Skip if already owned
        if ownerUserId ~= 0 then return false end
        -- Skip if not wandering
        if state ~= "" and state ~= "wandering" then return false end
        -- Rarity filter
        local minRarity = petCatchConfig.MinRarity or "Common"
        local petRarityVal = getRarityRank(rarity)
        local minRarityVal = getRarityRank(minRarity) or RARITY_ORDER.Common
        if not petRarityVal then return false end
        if petRarityVal < minRarityVal then return false end

        return true
    end

    function M._extractUuid(model)
        if not model then return nil end
        local attributeId = model:GetAttribute("UUID") or model:GetAttribute("PetUUID") or model:GetAttribute("WildPetId")
        if attributeId ~= nil and tostring(attributeId) ~= "" then
            return tostring(attributeId)
        end
        return tostring(model.Name):match("^WildPet_.+_WildPet_(.+)$")
            or tostring(model.Name):match("^WildPet_(.+)$")
    end

    function M._getPetRoot(instance)
        if not instance then return nil end
        if instance:IsA("BasePart") then return instance end
        return instance:FindFirstChild("RootPart", true)
            or (instance:IsA("Model") and instance.PrimaryPart)
            or instance:FindFirstChildWhichIsA("BasePart", true)
    end

    function M._getWildPetModels()
        local map = _himonoFindChildAny(workspace, { "Map", "World" })
        if not map then return {} end
        local pets = {}
        local seen = {}
        for _, folderName in ipairs({ "WildPetSpawns", "WildPets", "WildPetSpawnLocations", "WildPetRef", "WildPetRefs", "WildPetsRef" }) do
            local spawnFolder = _himonoFindChildAny(map, folderName)
            for _, model in ipairs(spawnFolder and spawnFolder:GetChildren() or {}) do
                if (model:IsA("Model") or model:IsA("BasePart")) and M._getPetRoot(model) then
                    local uuid = M._extractUuid(model)
                    local key = uuid or model
                    if not seen[key] then
                        seen[key] = true
                        table.insert(pets, {
                            model = model,
                            petName = model:GetAttribute("PetName") or model:GetAttribute("Name") or model.Name,
                            uuid = uuid,
                        })
                    end
                end
            end
        end
        return pets
    end

    function M._getRefPart(uuid)
        if not uuid or uuid == "" then return nil end
        local map = _himonoFindChildAny(workspace, { "Map", "World" })
        local refFolder = map and _himonoFindChildAny(map, { "WildPetRef", "WildPetRefs", "WildPetsRef" })
        if not refFolder then return nil end
        return _himonoFindChildAny(refFolder, { "WildPet_" .. tostring(uuid), tostring(uuid) })
    end

    function M._catchPet(petInfo, petCatchConfig, Net, root)
        if not M._running then return false end
        local model = petInfo.model
        if not model or not model.Parent then return false end
        if M._tamed[model] then return false end
        local catchingAt = M._catching[model]
        if catchingAt and os.clock() - catchingAt < 30 then return false end
        M._catching[model] = nil

        -- Get ref part for attributes
        local refPart = petInfo.uuid and M._getRefPart(petInfo.uuid)
        if not refPart or not M._passesFilter(refPart, petCatchConfig) then
            M._stats.skipped = M._stats.skipped + 1
            return false
        end

        local price = tonumber(refPart:GetAttribute("Price")) or 0
        local reserve = _himonoClampNumber(petCatchConfig.ReserveSheckles, 1, 0, math.huge)
        if price > 0 and Utils.getSheckles() - price < reserve then
            M._stats.skipped = M._stats.skipped + 1
            return false
        end

        local rootPart = M._getPetRoot(model)
        if not rootPart then return false end
        M._catching[model] = os.clock()

        local petName = petInfo.petName or "Unknown"
        local rarity = refPart:GetAttribute("Rarity") or "?"

        -- Save original position
        local origCFrame = root.CFrame
        _himonoRememberMovement("AutoPetCatch", root)

        -- Teleport to pet
        local moved = Utils.tweenRootTo(root, rootPart.CFrame * CFrame.new(0, 5, 0),
            petCatchConfig.TweenSpeed, petCatchConfig.MaxTweenTime)
        if not M._running then
            _himonoForgetMovement("AutoPetCatch")
            M._catching[model] = nil
            return false
        end
        if not moved then
            Utils.tweenRootTo(root, origCFrame, petCatchConfig.TweenSpeed, petCatchConfig.MaxTweenTime)
            _himonoForgetMovement("AutoPetCatch")
            M._catching[model] = nil
            M._stats.errors = M._stats.errors + 1
            return false
        end
        task.wait(0.8)
        if not M._running then
            _himonoForgetMovement("AutoPetCatch")
            M._catching[model] = nil
            return false
        end

        -- Only consider prompts owned by this pet/ref object. Nearby world prompts are unrelated.
        local nearestPrompt = nil
        local nearestDist = math.huge

        local function getPromptPosition(prompt)
            local parent = prompt and prompt.Parent
            if not parent then return nil end
            if parent:IsA("Attachment") then return parent.WorldPosition end
            if parent:IsA("BasePart") then return parent.Position end
            if parent:IsA("Model") then
                local part = parent.PrimaryPart or parent:FindFirstChildWhichIsA("BasePart", true)
                return part and part.Position or nil
            end
            local ancestorPart = parent:FindFirstAncestorWhichIsA("BasePart")
            return ancestorPart and ancestorPart.Position or nil
        end

        local seenPrompts = {}
        local promptRoots = { model }
        if refPart and not refPart:IsDescendantOf(model) then table.insert(promptRoots, refPart) end
        for _, promptRoot in ipairs(promptRoots) do
            for _, desc in ipairs(promptRoot:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Enabled and not seenPrompts[desc] then
                    seenPrompts[desc] = true
                    local promptPosition = getPromptPosition(desc)
                    local dist = promptPosition and (promptPosition - root.Position).Magnitude or math.huge
                    if dist < nearestDist and dist <= desc.MaxActivationDistance then
                        nearestDist = dist
                        nearestPrompt = desc
                    end
                end
            end
        end

        local caught = false
        local lp = Players.LocalPlayer
        local function isConfirmed()
            local freshRef = petInfo.uuid and M._getRefPart(petInfo.uuid)
            local ownerUserId = freshRef and (tonumber(freshRef:GetAttribute("OwnerUserId")) or 0) or 0
            return (not model.Parent)
                or (ownerUserId ~= 0 and lp and ownerUserId == lp.UserId)
        end

        -- Method 1: fire the nearest prompt owned by this pet (primary).
        local promptTriggered = false
        if nearestPrompt then
            local pOk = pcall(function()
                if fireproximityprompt then
                    fireproximityprompt(nearestPrompt)
                else
                    nearestPrompt:InputHoldBegin()
                    task.wait(math.max(0.1, nearestPrompt.HoldDuration + 0.05))
                    if nearestPrompt and nearestPrompt:IsDescendantOf(workspace) then
                        nearestPrompt:InputHoldEnd()
                    end
                end
            end)
            promptTriggered = pOk == true
            if promptTriggered then
                print("[himono Hub] ProximityPrompt triggered for:", petName, "dist:", math.floor(nearestDist))
                task.wait(0.6)
                caught = isConfirmed()
            end
        end

        -- Method 2: WildPetTame remote (backup)
        if M._running and not caught then
            local ok1 = _himonoRemoteOk(Net, "Pets.WildPetTame", model)
            if ok1 then
                print("[himono Hub] WildPetTame fired for:", petName)
                task.wait(0.6)
                caught = isConfirmed()
            else
                warn("[himono Hub] WildPetTame remote failed:", petName)
            end
        end

        -- Method 3: WildPetCollected (backup)
        if M._running and not caught then
            if _himonoRemoteOk(Net, "Pets.WildPetCollected", model) then
                task.wait(0.6)
                caught = isConfirmed()
            end
        end

        if M._running and not caught then
            task.wait(0.5)
            caught = isConfirmed()
        end

        if not M._running then
            _himonoForgetMovement("AutoPetCatch")
            M._catching[model] = nil
            return false
        end

        -- Return to original position
        if petCatchConfig.AutoReturn ~= false then
            task.wait(0.2)
            Utils.tweenRootTo(root, origCFrame, petCatchConfig.TweenSpeed, petCatchConfig.MaxTweenTime)
        end
        _himonoForgetMovement("AutoPetCatch")

        if not caught then
            M._catching[model] = nil
            M._stats.errors = M._stats.errors + 1
            return false
        end

        M._tamed[model] = true
        M._catching[model] = nil

        -- Track stats
        M._stats.caught = M._stats.caught + 1
        local priceStr = Utils.formatNumber and Utils.formatNumber(price) or tostring(price)
        print("[himono Hub] Caught:", petName, rarity, "$" .. priceStr)
        Config.Notify("Pet Caught!", petName .. " (" .. rarity .. ") for $" .. priceStr, 8)

        Webhook.notifyRarePet(petName, rarity, price, "Wild pet catch")

        -- Cleanup after pet despawns
        task.spawn(function()
            local cleanupAt = os.clock() + 120
            while model and model.Parent and os.clock() < cleanupAt do
                task.wait(1)
            end
            M._tamed[model] = nil
        end)

        return true
    end

    function M._scan(petCatchConfig, Net, Utils)
        M._stats.scanned = M._stats.scanned + 1
        local LP = Utils.getLocalPlayer()
        local root = LP and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local petModels = M._getWildPetModels()
        if #petModels == 0 then return end

        -- Build list with ref data, sort by rarity and price descending.
        local candidates = {}
        for _, pet in ipairs(petModels) do
            if not M._tamed[pet.model] and not M._catching[pet.model] then
                local refPart = pet.uuid and M._getRefPart(pet.uuid)
                local rarity = refPart and refPart:GetAttribute("Rarity") or "Common"
                local price = refPart and (tonumber(refPart:GetAttribute("Price")) or 0) or 0
                local ownerUserId = refPart and (tonumber(refPart:GetAttribute("OwnerUserId")) or 0) or 0
                local state = refPart and _himonoLower(refPart:GetAttribute("State") or "") or ""

                if ownerUserId == 0 and (state == "" or state == "wandering") then
                    local petPart = M._getPetRoot(pet.model)
                    local petPos = petPart and petPart.Position or root.Position
                    table.insert(candidates, {
                        pet = pet,
                        rarity = rarity,
                        price = price,
                        rarityVal = getRarityRank(rarity) or 0,
                        dist = (petPos - root.Position).Magnitude,
                    })
                end
            end
        end

        -- Sort: rarity desc, then price desc, then distance asc.
        table.sort(candidates, function(a, b)
            if a.rarityVal ~= b.rarityVal then return a.rarityVal > b.rarityVal end
            if a.price ~= b.price then return a.price > b.price end
            return a.dist < b.dist
        end)

        -- Keep each cycle bounded so other movement modules get a chance to run.
        local processed = 0
        local maxPerCycle = math.floor(_himonoClampNumber(petCatchConfig.MaxPerCycle, 1, 1, 10))
        for _, cand in ipairs(candidates) do
            if not M._running or processed >= maxPerCycle then break end
            if M._passesFilter(cand.pet.uuid and M._getRefPart(cand.pet.uuid) or nil, petCatchConfig) then
                local acquired = _himonoWithLock("movement", "AutoPetCatch", 0.5, function()
                    M._catchPet(cand.pet, petCatchConfig, Net, root)
                end)
                if acquired then processed = processed + 1 end
                task.wait(0.5)
            end
        end
    end

    function M._listenSpawns(petCatchConfig, Net, Utils)
        local function onAdded(model)
            if not M._running then return end
            if not (model:IsA("Model") or model:IsA("BasePart")) then return end

            -- Wait for attributes to replicate
            task.wait(1)
            if not M._running or not model.Parent or not M._getPetRoot(model) then return end

            local petName = model:GetAttribute("PetName") or model.Name
            local uuid = M._extractUuid(model)
            local refPart = uuid and M._getRefPart(uuid)

            if refPart and M._passesFilter(refPart, petCatchConfig) then
                local LP = Utils.getLocalPlayer()
                local root = LP and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    print("[himono Hub] New wild pet spawned:", petName)
                    runModuleStep("AutoPetCatch", M, function()
                        if not M._running then return end
                        _himonoWithLock("movement", "AutoPetCatch", 0.5, function()
                            if not M._running then return end
                            local currentRoot = Utils.getHumanoidRootPart()
                            if not currentRoot then return end
                            M._catchPet({
                                model = model,
                                petName = petName,
                                uuid = uuid,
                            }, petCatchConfig, Net, currentRoot)
                        end)
                    end)
                end
            end
        end

        local listenedFolders = setmetatable({}, { __mode = "k" })
        local listenedMaps = setmetatable({}, { __mode = "k" })
        local function attachFolder(folder)
            if not M._running or not folder or listenedFolders[folder] then return end
            local folderName = _himonoLower(folder.Name)
            if folderName ~= "wildpetspawns" and folderName ~= "wildpets" and folderName ~= "wildpetspawnlocations"
                and folderName ~= "wildpetref" and folderName ~= "wildpetrefs" and folderName ~= "wildpetsref" then return end
            listenedFolders[folder] = true
            table.insert(M._connections, folder.ChildAdded:Connect(onAdded))
        end
        local function attachMap(map)
            if not M._running or not map or listenedMaps[map] then return end
            local mapName = _himonoLower(map.Name)
            if mapName ~= "map" and mapName ~= "world" then return end
            listenedMaps[map] = true
            table.insert(M._connections, map.ChildAdded:Connect(attachFolder))
            attachFolder(_himonoFindChildAny(map, { "WildPetSpawns", "WildPets", "WildPetSpawnLocations" }))
            attachFolder(_himonoFindChildAny(map, { "WildPetRef", "WildPetRefs", "WildPetsRef" }))
        end
        table.insert(M._connections, workspace.ChildAdded:Connect(attachMap))
        attachMap(_himonoFindChildAny(workspace, { "Map", "World" }))
    end

    function M.start(config, Net, Utils)
        if M._running then return end
        M._running = true

        local petCatchConfig = config.PetCatch or {}
        -- Listen for real-time spawns
        M._listenSpawns(petCatchConfig, Net, Utils)

        -- Periodic scan
        M._thread = task.spawn(function()
            while M._running do
                runModuleStep("AutoPetCatch", M, function()
                    M._scan(petCatchConfig, Net, Utils)
                end)
                task.wait(_himonoClampNumber(config.Timings.PetCatchInterval, 3, 1, 60))
            end
        end)

        print("[himono Hub] Auto Pet Catch started")
    end

    function M.stop()
        M._running = false
        M._thread = _himonoCancelThread(M._thread)
        M._connections = _himonoDisconnectList(M._connections)
        _himonoRestoreMovement("AutoPetCatch")
        M._catching = setmetatable({}, { __mode = "k" })
    end

    function M.getStats()
        return M._stats
    end
end

