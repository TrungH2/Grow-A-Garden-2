function AntiAfk.start(config)
    if AntiAfk._running then return end
    AntiAfk._running = true

    local interval = _himonoClampNumber(config.Timings.AntiAfkInterval, 60, 10, 600)

    AntiAfk._thread = task.spawn(function()
        while AntiAfk._running do
            -- Method 1: VirtualUser click (most reliable)
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)

            -- Method 2: Simulate movement
            pcall(function()
                local humanoid = LP.Character
                    and LP.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid then
                    humanoid.Jump = true
                end
            end)

            AntiAfk._stats.actions = AntiAfk._stats.actions + 1
            AntiAfk._stats.lastAction = os.time()
            task.wait(interval)
        end
    end)

    -- Also handle the idle kicked event
    table.insert(AntiAfk._connections, LP.Idled:Connect(function()
        pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end)
    end))

    print("[himono Hub] Anti-AFK started (interval: " .. interval .. "s)")
end

function AntiAfk.stop()
    AntiAfk._running = false
    AntiAfk._thread = _himonoCancelThread(AntiAfk._thread)
    AntiAfk._connections = _himonoDisconnectList(AntiAfk._connections)
    AntiAfk.stopAutoRejoin()
end

