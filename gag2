function Utils.tweenRootTo(root, target, speed, maxTime)
    if not root or not root.Parent or not root:IsA("BasePart") then return false, "missing_root" end
    local targetCFrame = typeof(target) == "CFrame" and target
        or (typeof(target) == "Vector3" and CFrame.new(target))
    if not targetCFrame then return false, "invalid_target" end

    local distance = (root.Position - targetCFrame.Position).Magnitude
    local duration = math.clamp(distance / math.max(tonumber(speed) or 250, 1), 0.05, tonumber(maxTime) or 3)
    local tween
    local finished = false
    local completedConnection
    CancelMovementTween(root)
    local ok, err = pcall(function()
        tween = game:GetService("TweenService"):Create(
            root,
            TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
            { CFrame = targetCFrame }
        )
        completedConnection = tween.Completed:Connect(function() finished = true end)
        ActiveRootTweens[root] = tween
        tween:Play()
    end)
    if not ok then return false, tostring(err) end

    local deadline = os.clock() + duration + 0.35
    while root.Parent and not finished and os.clock() < deadline do task.wait() end
    if completedConnection then completedConnection:Disconnect() end
    if not finished and tween then pcall(function() tween:Cancel() end) end
    if ActiveRootTweens[root] == tween then ActiveRootTweens[root] = nil end
    local arrived = false
    pcall(function()
        if root.Parent then arrived = (root.Position - targetCFrame.Position).Magnitude <= 8 end
    end)
    local result = "timeout"
    if finished then result = "completed" end
    return arrived, result
end

