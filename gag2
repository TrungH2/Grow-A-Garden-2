Modules.AutoCenterPlot = {}
do
    local M = Modules.AutoCenterPlot
    local Center = M
    Center._running = false
    Center._thread = nil
    Center._connections = {}
    Center._stats = { scans = 0, centered = 0, errors = 0, noGarden = 0, noCharacter = 0, lastDistance = 0 }

    local function getPlotCenter(garden)
        if not garden then return nil end
        local CollectionService = game:GetService("CollectionService")
        local weightedPosition = Vector3.new(0, 0, 0)
        local totalWeight = 0
        local seen = setmetatable({}, { __mode = "k" })

        local function addArea(part)
            if not part or not part:IsA("BasePart") or not part:IsDescendantOf(garden) or seen[part] then return end
            seen[part] = true
            local weight = math.max(1, part.Size.X * part.Size.Z)
            local surfacePosition = part.Position + part.CFrame.UpVector * (part.Size.Y / 2)
            weightedPosition = weightedPosition + surfacePosition * weight
            totalWeight = totalWeight + weight
        end

        for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
            addArea(part)
        end

        for _, desc in ipairs(garden:GetDescendants()) do
            if desc:IsA("BasePart") and desc:GetAttribute("PlantArea") then
                addArea(desc)
            end
        end

        if totalWeight == 0 then
            for _, part in ipairs(CollectionService:GetTagged("GardenTotalArea")) do
                addArea(part)
            end
        end

        if totalWeight == 0 then
            addArea(garden:FindFirstChild("PlotSizeReference", true))
        end

        if totalWeight == 0 then
            local spawn = garden:FindFirstChild("SpawnPoint", true)
            if spawn and spawn:IsA("BasePart") then
                return spawn.Position + spawn.CFrame.UpVector * (spawn.Size.Y / 2)
            elseif spawn and spawn:IsA("Attachment") then
                return spawn.WorldPosition
            end
            if garden:IsA("Model") then return garden:GetPivot().Position end
            return nil
        end
        return weightedPosition / totalWeight
    end

    local function centerOnce(config, Utils)
        Center._stats.scans = Center._stats.scans + 1
        local hrp = Utils.getHumanoidRootPart()
        if not hrp then
            Center._stats.noCharacter = Center._stats.noCharacter + 1
            return false, "no character"
        end

        local garden = Utils.getMyGarden()
        if not garden then
            Center._stats.noGarden = Center._stats.noGarden + 1
            return false, "no garden"
        end

        local center = getPlotCenter(garden)
        if not center then
            Center._stats.errors = Center._stats.errors + 1
            return false, "no plot center"
        end

        local target = center + Vector3.new(0, 3, 0)
        local dist = (hrp.Position - target).Magnitude
        Center._stats.lastDistance = math.floor(dist)

        -- Keep centered, but avoid fighting the player every tick when already close.
        local centerCfg = config.CenterPlot or {}
        local threshold = _himonoClampNumber(centerCfg.Distance or config.CenterPlotDistance or 18, 18, 6, 200)
        if dist > threshold then
            local acquired, ok = _himonoWithLock("movement", "AutoCenterPlot", 0, function()
                _himonoRememberMovement("AutoCenterPlot", hrp)
                local moved = Utils.tweenRootTo(hrp, CFrame.new(target) * hrp.CFrame.Rotation,
                    centerCfg.TweenSpeed, centerCfg.MaxTweenTime)
                _himonoForgetMovement("AutoCenterPlot")
                return moved
            end)
            if acquired and ok then
                Center._stats.centered = Center._stats.centered + 1
                return true, "centered"
            elseif not acquired then
                return false, "movement busy"
            else
                Center._stats.errors = Center._stats.errors + 1
                return false, "teleport failed"
            end
        end
        return true, "already centered"
    end

    function Center.start(config, Net, Utils)
        if Center._running then return end
        Center._running = true
        Running.AutoCenterPlot = true

        Center._thread = task.spawn(function()
            task.wait(1)
            while Center._running do
                local ok, err = pcall(function()
                    centerOnce(config, Utils)
                end)
                if not ok then
                    Center._stats.errors = Center._stats.errors + 1
                    ModuleErrors.AutoCenterPlot = tostring(err)
                else
                    ModuleErrors.AutoCenterPlot = nil
                end
                task.wait(_himonoClampNumber(config.Timings.CenterPlotInterval, 5, 1, 120))
            end
        end)
        print("[himono Hub] Auto-Center Plot loop started")
    end

    function Center.stop()
        Center._running = false
        Running.AutoCenterPlot = false
        Center._thread = _himonoCancelThread(Center._thread)
        Center._connections = _himonoDisconnectList(Center._connections)
        _himonoRestoreMovement("AutoCenterPlot")
    end

    function Center.getStats()
        return Center._stats
    end
end

