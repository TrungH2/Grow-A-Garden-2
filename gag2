-- Lightweight helpers used by the compact kaitun status overlay.
function Stats._iterTools(callback)
    local lp = Players and Players.LocalPlayer
    if not lp then return end
    local containers = {}
    local bp = lp:FindFirstChild("Backpack")
    if bp then table.insert(containers, bp) end
    if lp.Character then table.insert(containers, lp.Character) end
    for _, container in ipairs(containers) do
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                callback(item)
            end
        end
    end
end

function Stats._getPlayerAttribute(names, fallback)
    local lp = Players and Players.LocalPlayer
    if not lp then return fallback end
    for _, name in ipairs(names) do
        local value = lp:GetAttribute(name)
        if value ~= nil then return value end
    end
    return fallback
end

function Stats.getFruitCount()
    local count = 0
    Stats._iterTools(function(tool)
        local itemTypeLower = _himonoLower(tool:GetAttribute("ItemType"))
        local mainCategoryLower = _himonoLower(tool:GetAttribute("MainCategory"))
        if tool:GetAttribute("FruitName") or _himonoTruthy(tool:GetAttribute("IsFruit"), false)
            or tool:GetAttribute("FruitTool") or mainCategoryLower == "fruit" or mainCategoryLower == "fruits"
            or itemTypeLower == "harvestedfruit" or itemTypeLower == "fruit" or itemTypeLower == "fruits" then
