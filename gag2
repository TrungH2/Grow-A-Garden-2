end

local function _himonoRemoteOk(Net, path, ...)
    if not Net or type(Net.fire) ~= "function" then return false end
    local args = {...}
    local argc = select("#", ...)
    local ok, result = pcall(function()
        return Net.fire(path, unpack(args, 1, argc))
    end)
    return ok and result == true
end

local function _himonoInvokeOk(Net, path, ...)
    if not Net or type(Net.invoke) ~= "function" then return false, nil end
    local args = {...}
    local argc = select("#", ...)
    local ok, result = pcall(function()
        return Net.invoke(path, unpack(args, 1, argc))
    end)
    if not ok then return false, nil end
    return result ~= nil and result ~= false, result
end

local function _himonoRequestTeleport(Net, destinations)
    if type(destinations) == "string" then destinations = { destinations } end
    if type(destinations) ~= "table" then return false, nil end
    for _, destination in ipairs(destinations) do
        destination = _himonoTrimString(destination)
        if destination ~= "" and _himonoRemoteOk(Net, "TeleportButton.Request", destination) then
            return true, destination
        end
    end
    return false, nil
end

local ActionLocks = {}
local ActiveMovementOrigins = {}
local CancelMovementTween = function() end

local function _himonoRememberMovement(owner, root)
    if ActiveMovementOrigins[owner] or not root or not root.Parent then return end
    ActiveMovementOrigins[owner] = { root = root, cframe = root.CFrame }
end

local function _himonoForgetMovement(owner)
    ActiveMovementOrigins[owner] = nil
end

local function _himonoRestoreMovement(owner)
    local state = ActiveMovementOrigins[owner]
    ActiveMovementOrigins[owner] = nil
    if not state or not state.root or not state.root.Parent then return false end
    CancelMovementTween(state.root)
    return pcall(function()
        state.root.CFrame = state.cframe
    end)
end

local function _himonoReleaseLocks(owner)
    for name, state in pairs(ActionLocks) do
        if state.owner == owner then ActionLocks[name] = nil end
    end
end

local function _himonoWithLock(lockName, owner, timeout, callback)
    local deadline = os.clock() + _himonoClampNumber(timeout, 1, 0, 10)
    local currentThread = coroutine.running()
    while true do
        local state = ActionLocks[lockName]
        if not state or os.clock() - state.acquiredAt > 30 then
            ActionLocks[lockName] = { owner = owner, thread = currentThread, acquiredAt = os.clock() }
            break
        end
        if state.owner == owner and state.thread == currentThread then
            return true, callback()
        end
        if os.clock() >= deadline then return false, "busy" end
        task.wait(0.05)
    end

    local results = table.pack(pcall(callback))
    local state = ActionLocks[lockName]
    if state and state.owner == owner and state.thread == currentThread then ActionLocks[lockName] = nil end
    if not results[1] then error(results[2], 0) end
    return true, unpack(results, 2, results.n)
end

