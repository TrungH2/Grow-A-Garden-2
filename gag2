Modules.AutoPlant = {}
do
    local M = Modules.AutoPlant
    local Plant = M
    local CollectionService = game:GetService("CollectionService")
Plant._running = false
Plant._thread  = nil
Plant._connections = {}
Plant._stats = { planted = 0, shoveled = 0, scans = 0, errors = 0, noSeeds = 0, equipped = 0, shovelSkipped = 0 }
Plant._shovelRemotePath = nil
Plant._nextShovelRemoteProbe = 0

---------------------------------------------------------------
-- GET EQUIPPED SEED TOOL (matching decompiled GetEquippedTool)
-- Must be a Tool with "SeedTool" attribute = seed name
---------------------------------------------------------------

function Plant._getEquippedSeed()
    local lp = Players.LocalPlayer
    local char = lp and lp.Character
    if not char then return nil, nil end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if not tool then return nil, nil end
    local seedName = _himonoGetSeedName(tool)
    if not seedName then return nil, nil end
    return seedName, tool
end

---------------------------------------------------------------
-- FIND SEED TOOLS IN BACKPACK
-- Returns list of {tool, seedName} sorted by seed name
---------------------------------------------------------------

function Plant._shouldSkipSeed(seedName, plantConfig, seedTool)
    if _himonoShouldSkipSeed(seedName, plantConfig, seedTool) then return true end
    plantConfig = plantConfig or {}
    if plantConfig.SkipWeakSeedsByWealth ~= false then
        local minSeedPrice = Plant._getWealthMinSeedPrice()
        local price = _himonoLookupNumber(Resources.SeedPrices, seedName, 0)
        if price > 0 and price < minSeedPrice then return true end
    end
    return false
end

function Plant._getWealthMinSeedPrice()
    local restockConfig = Config.Restock or {}
    if restockConfig.WealthScaling == false then return 0 end
    local sheckles = Utils.getSheckles()
    local minSeedPrice = 0
    for _, tier in ipairs(restockConfig.WealthTiers or {}) do
        if type(tier) == "table" then
            local balance = tonumber(tier.Balance) or math.huge
            if sheckles >= balance then
                minSeedPrice = math.max(minSeedPrice, tonumber(tier.MinSeedPrice) or 0)
            end
        end
    end
    return minSeedPrice
end

function Plant._findSeedsInBackpack(preferSeed, plantConfig)
    local lp = Players.LocalPlayer
    local bp = lp and lp:FindFirstChild("Backpack")
    if not bp then return {} end
    local seeds = {}
    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") then
            local sn = _himonoGetSeedName(tool)
            if type(sn) == "string" and sn ~= "" then
                local include = not Plant._shouldSkipSeed(sn, plantConfig or {}, tool)
                if include then
                    table.insert(seeds, { tool = tool, seedName = sn })
                end
            end
        end
    end
    -- Sort: preferred seed first, then strongest seed by shop price.
    table.sort(seeds, function(a, b)
        if preferSeed and preferSeed ~= "" then
            local wanted = _himonoCompactKey(preferSeed)
            local aMatch = (_himonoCompactKey(a.seedName) == wanted) and 1 or 0
            local bMatch = (_himonoCompactKey(b.seedName) == wanted) and 1 or 0
            if aMatch ~= bMatch then return aMatch > bMatch end
        end
        local aPrice = Plant._getSeedUpgradeScore(a.seedName)
        local bPrice = Plant._getSeedUpgradeScore(b.seedName)
        if aPrice ~= bPrice then return aPrice > bPrice end
        return _himonoLower(a.seedName) < _himonoLower(b.seedName)
    end)
    return seeds
end

---------------------------------------------------------------
-- EQUIP SEED TOOL FROM BACKPACK
-- Uses Humanoid:EquipTool() - same as game's internal flow
-- Returns seedName, toolInstance on success
---------------------------------------------------------------

function Plant._equipSeed(preferSeed, plantConfig)
    local lp = Players.LocalPlayer
    local char = lp and lp.Character
    if not char then return nil, nil end
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return nil, nil end

    plantConfig = plantConfig or {}
    -- Find seed in backpack, sorted by preference and progression value.
    local seeds = Plant._findSeedsInBackpack(preferSeed, plantConfig)
    local target = seeds[1]

    -- Check if already equipped and keep it only when it is not weaker than the best backpack seed.
    local sn, tool = Plant._getEquippedSeed()
    if sn and not Plant._shouldSkipSeed(sn, plantConfig, tool) then
        if not target then return sn, tool end
        local prefer = _himonoCompactKey(preferSeed or "")
        local equippedMatchesPrefer = prefer ~= "" and _himonoCompactKey(sn) == prefer
        local targetMatchesPrefer = prefer ~= "" and _himonoCompactKey(target.seedName) == prefer
        if equippedMatchesPrefer and not targetMatchesPrefer then return sn, tool end
        if equippedMatchesPrefer == targetMatchesPrefer then
            local equippedScore = Plant._getSeedUpgradeScore(sn)
            local targetScore = Plant._getSeedUpgradeScore(target.seedName)
            if equippedScore >= targetScore then return sn, tool end
        end
    end

    if not target then return nil, nil end

    -- Equip first seed (preferred or first available)
    local ok = pcall(function()
        humanoid:EquipTool(target.tool)
    end)
    if not ok then return nil, nil end

    -- Wait for tool to appear in character
    local waited = 0
    while waited < 2 do
        task.wait(0.1)
        waited = waited + 0.1
        if target.tool.Parent == char and _himonoGetSeedName(target.tool) then
            Plant._stats.equipped = Plant._stats.equipped + 1
            return target.seedName, target.tool
        end
    end

    return nil, nil
end

