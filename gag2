Modules.SeedPackClaimer = {}
do
    local M = Modules.SeedPackClaimer
    local SeedPack = M
    SeedPack._running = false
    SeedPack._thread = nil
    SeedPack._connections = {}
    SeedPack._stats = { claimed = 0, rainbow = 0, gold = 0, regular = 0, scanned = 0, errors = 0 }
    SeedPack._claimed = setmetatable({}, { __mode = "k" })
    SeedPack._claiming = setmetatable({}, { __mode = "k" })
    SeedPack._failedUntil = setmetatable({}, { __mode = "k" })

    function SeedPack._getClaimPart(instance)
        if not instance then return nil end
        if instance:IsA("BasePart") then return instance end
        if instance:IsA("Model") then
            return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
        end
        return instance:FindFirstChildWhichIsA("BasePart", true)
    end

    function SeedPack._classify(instance, claimPart)
        local label = _himonoLower(tostring(instance and instance:GetAttribute("SeedPack") or "")
            .. " " .. tostring(claimPart and claimPart:GetAttribute("SeedPack") or "")
            .. " " .. tostring(instance and instance.Name or "")
            .. " " .. tostring(claimPart and claimPart.Name or ""))
        local isRainbow = (instance and _himonoTruthy(instance:GetAttribute("RainbowSeed"), false))
            or (claimPart and _himonoTruthy(claimPart:GetAttribute("RainbowSeed"), false))
            or string.find(label, "rainbow", 1, true) ~= nil
        local isGold = (instance and _himonoTruthy(instance:GetAttribute("GoldSeed"), false))
            or (claimPart and _himonoTruthy(claimPart:GetAttribute("GoldSeed"), false))
            or string.find(label, "gold", 1, true) ~= nil
        return isRainbow, isGold
    end

    function SeedPack._isClaimed(instance, claimPart)
        return (instance and (_himonoTruthy(instance:GetAttribute("Claimed"), false)
                or _himonoTruthy(instance:GetAttribute("Collected"), false)))
            or (claimPart and (_himonoTruthy(claimPart:GetAttribute("Claimed"), false)
                or _himonoTruthy(claimPart:GetAttribute("Collected"), false)))
            or false
    end

    ---------------------------------------------------------------
    -- SCAN & CLAIM
    ---------------------------------------------------------------

    function SeedPack._scanAndClaim(config, Net, Utils)
        SeedPack._stats.scanned = SeedPack._stats.scanned + 1
        local LP = Utils.getLocalPlayer()
        if not LP or not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end

        local root = LP.Character.HumanoidRootPart
        local map = _himonoFindChildAny(workspace, { "Map", "World" })
        local spawnFolder = map and _himonoFindChildAny(map, { "SeedPackSpawnServerLocations", "SeedPackSpawns", "SeedPackSpawnLocations", "SeedPacks" })
        if not spawnFolder then return end

        -- Collect all spawn parts, sort by priority (Rainbow > Gold > Regular)
        local spawns = {}
        for _, entry in ipairs(spawnFolder:GetChildren()) do
            local part = SeedPack._getClaimPart(entry)
            local claimKey = part or entry
            local claimingAt = SeedPack._claiming[claimKey]
            if claimingAt and os.clock() - claimingAt > 30 then
                SeedPack._claiming[claimKey] = nil
                claimingAt = nil
            end
            local onCooldown = (SeedPack._failedUntil[claimKey] or 0) > os.clock()
            local alreadyClaimed = SeedPack._isClaimed(entry, part)
            if part and not SeedPack._claimed[claimKey] and not claimingAt
                and not onCooldown and not alreadyClaimed then
                local isRainbow, isGold = SeedPack._classify(entry, part)
                local packName = entry:GetAttribute("SeedPack") or part:GetAttribute("SeedPack")
                local priority = isRainbow and 3 or (isGold and 2 or 1)
                table.insert(spawns, {
                    instance = entry,
                    part = part,
                    key = claimKey,
                    rainbow = isRainbow,
                    gold = isGold,
                    pack = packName,
                    priority = priority,
                    dist = (part.Position - root.Position).Magnitude,
                })
            end
        end

        if #spawns == 0 then return end

        -- Sort: priority desc, then distance asc
        table.sort(spawns, function(a, b)
            if a.priority ~= b.priority then return a.priority > b.priority end
            return a.dist < b.dist
        end)

        local processed = 0
        local maxPerCycle = math.floor(_himonoClampNumber(config.SeedPack and config.SeedPack.MaxPerCycle, 3, 1, 20))
        for _, spawn in ipairs(spawns) do
            if not SeedPack._running then break end
            if processed >= maxPerCycle then break end
            local acquired = _himonoWithLock("movement", "SeedPackClaimer", 0.5, function()
                SeedPack._claimOne(spawn, Net, root, config)
            end)
            if acquired then processed = processed + 1 end
        end
    end

    function SeedPack._claimOne(spawn, Net, root, config)
        if not SeedPack._running then return false end
        local part = spawn and spawn.part
        local instance = spawn and (spawn.instance or part)
        local claimKey = spawn and (spawn.key or instance or part)
        if not part or not part.Parent then return false end
        local claimingAt = SeedPack._claiming[claimKey]
        if claimingAt and os.clock() - claimingAt <= 30 then return false end
        if SeedPack._isClaimed(instance, part) then return false end
        if (SeedPack._failedUntil[claimKey] or 0) > os.clock() then return false end
        if not root or not root.Parent then
            SeedPack._stats.errors = SeedPack._stats.errors + 1
            warn("[himono Hub] SeedPack claim skipped: missing HumanoidRootPart")
            return false
        end
        SeedPack._claiming[claimKey] = os.clock()

        local packId = instance:GetAttribute("SeedPack") or part:GetAttribute("SeedPack") or ""
        local claimed = false

        -- Save original position, teleport near part for server distance check
        local origCFrame = root.CFrame
        _himonoRememberMovement("SeedPackClaimer", root)
        local moved = Utils.tweenRootTo(root, part.CFrame * CFrame.new(0, 3, 0),
            config.SeedPack and config.SeedPack.TweenSpeed, config.SeedPack and config.SeedPack.MaxTweenTime)
        if not SeedPack._running then
            _himonoForgetMovement("SeedPackClaimer")
            SeedPack._claiming[claimKey] = nil
            return false
        end
        if not moved then
            Utils.tweenRootTo(root, origCFrame, config.SeedPack and config.SeedPack.TweenSpeed,
                config.SeedPack and config.SeedPack.MaxTweenTime)
            _himonoForgetMovement("SeedPackClaimer")
            SeedPack._claiming[claimKey] = nil
            SeedPack._stats.errors = SeedPack._stats.errors + 1
            return false
        end
        task.wait(0.3)
        if not SeedPack._running then
            _himonoForgetMovement("SeedPackClaimer")
            SeedPack._claiming[claimKey] = nil
            return false
        end

        -- Method 1: Fire ProximityPrompt (search recursively)
        local prompt = (instance and instance:FindFirstChildWhichIsA("ProximityPrompt", true))
            or part:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            local pOk = pcall(function()
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                else
                    prompt:InputHoldBegin()
                    task.wait(math.max(0.1, prompt.HoldDuration + 0.05))
                    if prompt:IsDescendantOf(workspace) then prompt:InputHoldEnd() end
                end
            end)
            if pOk then
                print("[himono Hub] SeedPack ProximityPrompt fired:", spawn.pack or part.Name)
                task.wait(0.25)
                claimed = (not instance.Parent) or (not part.Parent) or SeedPack._isClaimed(instance, part)
            end
        end

        -- Method 2: ClickPack remote (fallback). Confirm with despawn/claimed markers where possible.
        if SeedPack._running and not claimed then
            local fired = _himonoRemoteOk(Net, "SeedPack.ClickPack", part)
            if fired then
                task.wait(0.45)
                claimed = (not instance.Parent) or (not part.Parent) or SeedPack._isClaimed(instance, part)
            end
        end

        -- Method 3: OpenSeedPack invoke (fallback). Invoke returning a value is the strongest available confirmation here.
        if SeedPack._running and not claimed and packId ~= "" then
            local invoked, result = _himonoInvokeOk(Net, "SeedPack.OpenSeedPack", packId)
            if type(result) == "table" and result.Success ~= nil then
                claimed = result.Success == true
            else
                claimed = invoked == true
            end
        end

        task.wait(0.1)
        if not SeedPack._running then
            _himonoForgetMovement("SeedPackClaimer")
            SeedPack._claiming[claimKey] = nil
            return false
        end

        -- Return to original position before updating stats
        if config.SeedPack == nil or config.SeedPack.ReturnAfterCollect ~= false then
            Utils.tweenRootTo(root, origCFrame, config.SeedPack and config.SeedPack.TweenSpeed,
                config.SeedPack and config.SeedPack.MaxTweenTime)
        end
        _himonoForgetMovement("SeedPackClaimer")

        if not claimed then
            SeedPack._stats.errors = SeedPack._stats.errors + 1
            SeedPack._claiming[claimKey] = nil
            local cooldown = _himonoClampNumber(config.SeedPack and config.SeedPack.FailureCooldown, 10, 2, 120)
            SeedPack._failedUntil[claimKey] = os.clock() + cooldown
            return false
        end

        SeedPack._claimed[claimKey] = true
        SeedPack._claiming[claimKey] = nil
        SeedPack._failedUntil[claimKey] = nil

        -- Track stats
        if spawn.rainbow then
            SeedPack._stats.rainbow = SeedPack._stats.rainbow + 1
            SeedPack._stats.claimed = SeedPack._stats.claimed + 1
            print("[himono Hub] RAINBOW SEED claimed!")
            Config.Notify("Rainbow Seed!", "Rainbow Seed pack claimed!", 10)
            if Config.Webhook.OnRareSeed == true then
                Webhook.send("seed:rainbow", "Rainbow Seed claimed", "A Rainbow Seed pack was collected.", 16711935)
            end
        elseif spawn.gold then
            SeedPack._stats.gold = SeedPack._stats.gold + 1
            SeedPack._stats.claimed = SeedPack._stats.claimed + 1
            print("[himono Hub] GOLD SEED claimed!")
            Config.Notify("Gold Seed!", "Gold Seed pack claimed!", 10)
            if Config.Webhook.OnRareSeed == true then
                Webhook.send("seed:gold", "Gold Seed claimed", "A Gold Seed pack was collected.", 15844367)
            end
        else
            SeedPack._stats.regular = SeedPack._stats.regular + 1
            SeedPack._stats.claimed = SeedPack._stats.claimed + 1
            if packId ~= "" then
                print("[himono Hub] Seed pack claimed:", packId)
            end
        end

        -- Cleanup: remove from claimed list after part despawns
        task.spawn(function()
            local deadline = os.clock() + 120
            while instance and instance.Parent and os.clock() < deadline do
                task.wait(1)
            end
            SeedPack._claimed[claimKey] = nil
        end)

        return true
    end

    ---------------------------------------------------------------
    -- LISTEN FOR NEW SPAWNS (real-time)
    ---------------------------------------------------------------

    function SeedPack._listenSpawns(config, Net, Utils)
        local function onAdded(instance)
            if not SeedPack._running then return end

            -- Wait for attributes to replicate
            task.wait(0.5)
            if not SeedPack._running or not instance.Parent then return end
            local part = SeedPack._getClaimPart(instance)
            local claimKey = part or instance
            if not part then return end
            if SeedPack._claimed[claimKey] or SeedPack._claiming[claimKey] then return end

            local isRainbow, isGold = SeedPack._classify(instance, part)

            local LP = Utils.getLocalPlayer()
            local root = LP and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if not root then return end
            runModuleStep("SeedPackClaimer", SeedPack, function()
                if not SeedPack._running then return end
                _himonoWithLock("movement", "SeedPackClaimer", 0.5, function()
                    if not SeedPack._running then return end
                    SeedPack._claimOne({
                        instance = instance,
                        part = part,
                        key = claimKey,
                        rainbow = isRainbow,
                        gold = isGold,
                        pack = instance:GetAttribute("SeedPack") or part:GetAttribute("SeedPack") or "",
                        priority = isRainbow and 3 or (isGold and 2 or 1),
                    }, Net, root, config)
                end)
            end)
        end

        local listenedFolders = setmetatable({}, { __mode = "k" })
        local listenedMaps = setmetatable({}, { __mode = "k" })
        local function attachFolder(folder)
            if not SeedPack._running or not folder or listenedFolders[folder] then return end
            local folderName = _himonoLower(folder.Name)
            if folderName ~= "seedpackspawnserverlocations" and folderName ~= "seedpackspawns"
                and folderName ~= "seedpackspawnlocations" and folderName ~= "seedpacks" then return end
            listenedFolders[folder] = true
            table.insert(SeedPack._connections, folder.ChildAdded:Connect(onAdded))
        end
        local function attachMap(map)
            if not SeedPack._running or not map or listenedMaps[map] then return end
            local mapName = _himonoLower(map.Name)
            if mapName ~= "map" and mapName ~= "world" then return end
            listenedMaps[map] = true
            table.insert(SeedPack._connections, map.ChildAdded:Connect(attachFolder))
            attachFolder(_himonoFindChildAny(map, { "SeedPackSpawnServerLocations", "SeedPackSpawns", "SeedPackSpawnLocations", "SeedPacks" }))
        end
        table.insert(SeedPack._connections, workspace.ChildAdded:Connect(attachMap))
        attachMap(_himonoFindChildAny(workspace, { "Map", "World" }))
    end

    ---------------------------------------------------------------
    -- START / STOP / STATS
    ---------------------------------------------------------------

    function SeedPack.start(config, Net, Utils)
        if SeedPack._running then return end
