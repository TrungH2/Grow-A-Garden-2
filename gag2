function Plant._getMyPlot()
    return Utils.getMyGarden()
end

---------------------------------------------------------------
-- CHECK IF POSITION IS EMPTY (no existing plant within range)
-- Returns true if position is clear
---------------------------------------------------------------

function Plant._isPosEmpty(pos, myPlot, minDist)
    minDist = minDist or 2.5 -- minimum spacing between plants
    local plantsFolder = _himonoFindChildAny(myPlot, { "Plants", "Plant", "GardenPlants" })
    if not plantsFolder then return true end
    for _, plantModel in ipairs(plantsFolder:GetChildren()) do
        if plantModel:IsA("Model") then
            local root = plantModel.PrimaryPart or plantModel:FindFirstChildWhichIsA("BasePart", true)
            if root then
                local dist = (Vector2.new(root.Position.X, root.Position.Z) - Vector2.new(pos.X, pos.Z)).Magnitude
                if dist < minDist then
                    return false
                end
            end
        end
    end
    return true
end

function Plant._getPlantCount(myPlot)
    local plants = myPlot and _himonoFindChildAny(myPlot, { "Plants", "Plant", "GardenPlants" })
    return plants and #plants:GetChildren() or 0
end

function Plant._confirmPlanted(pos, myPlot, beforeCount)
    if beforeCount ~= nil then
        local deadline = os.clock() + 1.5
        repeat
            task.wait(0.1)
            if Plant._getPlantCount(myPlot) > beforeCount then return true end
        until os.clock() >= deadline
        return false
    end
    task.wait(0.3)
    return myPlot and (not Plant._isPosEmpty(pos, myPlot, 2.5))
end

function Plant._getPlantSeedName(plant)
    if typeof(plant) ~= "Instance" then return nil end
    local seedName = plant:GetAttribute("SeedName")
        or plant:GetAttribute("PlantName")
        or plant:GetAttribute("CropName")
        or plant:GetAttribute("FruitName")
        or plant.Name
    if type(seedName) ~= "string" then return nil end
    seedName = seedName:gsub("%s*%b[]", ""):gsub("%s+[Pp]lant$", ""):gsub("^%s*(.-)%s*$", "%1")
    return seedName ~= "" and seedName or nil
end

function Plant._getSeedUpgradeScore(seedName)
    local eventScore = _himonoLookupNumber(Resources.EventSeedScores, seedName, 0)
    if eventScore > 0 then return eventScore end
    local price = _himonoLookupNumber(Resources.SeedPrices, seedName, 0)
    if price > 0 then return price end
    return _himonoLookupNumber(Resources.SellValues, seedName, 0)
end

function Plant._getBestAvailableSeed(plantConfig)
    local bestName, bestScore = nil, 0
    local lp = Players.LocalPlayer
    local function scan(container)
        if not container then return end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local seedName = _himonoGetSeedName(tool)
                if seedName and not Plant._shouldSkipSeed(seedName, plantConfig or {}, tool) then
                    local score = Plant._getSeedUpgradeScore(seedName)
                    if score > bestScore then
                        bestName, bestScore = seedName, score
                    end
                end
            end
        end
    end
    scan(lp and lp.Character)
    scan(lp and lp:FindFirstChild("Backpack"))
    return bestName, bestScore
end

function Plant._findShovelTool()
    local lp = Players.LocalPlayer
    local function scan(container)
        if not container then return nil end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local gearName = tool:GetAttribute("GearName") or tool:GetAttribute("ItemName") or tool.Name
                if string.find(_himonoLower(gearName), "shovel", 1, true) then
                    return tool
                end
            end
        end
        return nil
    end
    return scan(lp and lp.Character) or scan(lp and lp:FindFirstChild("Backpack"))
end

function Plant._equipTool(tool)
    local lp = Players.LocalPlayer
    local char = lp and lp.Character
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if not tool or not humanoid then return false end
    if tool.Parent == char then return true end
    pcall(function() humanoid:EquipTool(tool) end)
    local deadline = os.clock() + 1
    repeat
        task.wait(0.05)
        if tool.Parent == char then return true end
    until os.clock() >= deadline
    return tool.Parent == char
end

function Plant._tryPromptShovel(plant)
    for _, desc in ipairs(plant and plant:GetDescendants() or {}) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local action = _himonoLower(desc.ActionText or desc.Name)
            if string.find(action, "shovel", 1, true)
                or string.find(action, "remove", 1, true)
                or string.find(action, "destroy", 1, true) then
                if type(fireproximityprompt) == "function" then
                    local ok = pcall(function() fireproximityprompt(desc) end)
                    if ok then return true end
                end
            end
        elseif desc:IsA("ClickDetector") then
            if type(fireclickdetector) == "function" then
                local ok = pcall(function() fireclickdetector(desc) end)
                if ok then return true end
            end
        end
    end
    return false
end

function Plant._tryRemoteShovel(Net, plant)
    if Plant._shovelRemotePath == nil and os.clock() < (Plant._nextShovelRemoteProbe or 0) then return false end
    local plantId = plant:GetAttribute("PlantId") or plant:GetAttribute("Id") or plant:GetAttribute("ID") or plant.Name
    local seedName = Plant._getPlantSeedName(plant)
    local root = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
    local pos = root and root.Position or nil
    local paths = Plant._shovelRemotePath and { Plant._shovelRemotePath } or {
        "Shovel.ShovelPlant", "Shovel.RemovePlant", "Shovel.RequestShovel", "Shovel.UseShovel",
        "Plant.ShovelPlant", "Plant.RemovePlant", "Plant.DeletePlant",
        "Garden.ShovelPlant", "Garden.RemovePlant", "Garden.DeletePlant",
        "Plants.ShovelPlant", "Plants.RemovePlant",
    }
    local argSets = {
        { plantId },
        { plant },
        { plantId, seedName },
        { plantId, plant },
        pos and { plantId, pos } or nil,
        pos and { pos, plantId } or nil,
    }
    for _, path in ipairs(paths) do
        local pathExists = Plant._shovelRemotePath ~= nil
        if not pathExists and Net and type(Net.exists) == "function" then
            pathExists = Net.exists(path)
        end
        if pathExists then
            for _, args in ipairs(argSets) do
                if args then
                    if _himonoRemoteOk(Net, path, unpack(args)) then
                        Plant._shovelRemotePath = path
                        return true
                    end
                    local invoked = _himonoInvokeOk(Net, path, unpack(args))
                    if invoked then
                        Plant._shovelRemotePath = path
                        return true
                    end
                end
            end
        end
    end
    if Plant._shovelRemotePath == nil then Plant._nextShovelRemoteProbe = os.clock() + 30 end
    return false
end

function Plant._confirmRemoved(plant, myPlot, beforeCount)
    local deadline = os.clock() + 1.5
    repeat
        task.wait(0.1)
        if not plant or not plant.Parent then return true end
        if beforeCount and Plant._getPlantCount(myPlot) < beforeCount then return true end
    until os.clock() >= deadline
    return false
end

function Plant._shovelWeakPlants(plantConfig, Net, Utils, myPlot, blocked)
    if plantConfig.AutoShovelWeakPlants ~= true or not myPlot then return 0 end
    local currentPlants = Plant._getPlantCount(myPlot)
    local maxPlants = math.floor(_himonoClampNumber(plantConfig.MaxPlants, 200, 1, 1000))
    if plantConfig.ShovelOnlyWhenFull ~= false and not blocked and currentPlants < maxPlants then return 0 end

    local bestSeedName, bestSeedScore = Plant._getBestAvailableSeed(plantConfig)
    local minUpgrade = _himonoClampNumber(plantConfig.ShovelMinUpgradePrice, 1000, 0, 1000000000)
    if not bestSeedName or bestSeedScore < minUpgrade then
        Plant._stats.shovelSkipped = Plant._stats.shovelSkipped + 1
        return 0
    end

    local threshold = bestSeedScore * _himonoClampNumber(plantConfig.ShovelThresholdRatio, 0.5, 0.05, 0.95)
    local plants = Utils.getPlantsInGarden(myPlot)
    table.sort(plants, function(a, b)
        local aScore = Plant._getSeedUpgradeScore(Plant._getPlantSeedName(a))
        local bScore = Plant._getSeedUpgradeScore(Plant._getPlantSeedName(b))
        if aScore ~= bScore then return aScore < bScore end
        return _himonoLower(a.Name) < _himonoLower(b.Name)
    end)

    local protected = {}
    local keepBest = math.floor(_himonoClampNumber(plantConfig.ShovelKeepBestPlants, 10, 0, 1000))
    if keepBest > 0 and #plants > keepBest then
        local byBest = table.clone(plants)
        table.sort(byBest, function(a, b)
            return Plant._getSeedUpgradeScore(Plant._getPlantSeedName(a)) > Plant._getSeedUpgradeScore(Plant._getPlantSeedName(b))
        end)
        for index = 1, math.min(keepBest, #byBest) do
            protected[byBest[index]] = true
        end
    end

    local shovelTool = Plant._findShovelTool()
    if shovelTool then Plant._equipTool(shovelTool) end

    local root = Utils.getHumanoidRootPart()
    local shoveled = 0
    local maxPerCycle = math.floor(_himonoClampNumber(plantConfig.ShovelMaxPerCycle, 3, 1, 25))
    for _, plant in ipairs(plants) do
        if shoveled >= maxPerCycle or not Plant._running then break end
        local mutation = plant:GetAttribute("Mutation") or plant:GetAttribute("MutationName") or plant:GetAttribute("Mutations")
        local seedName = Plant._getPlantSeedName(plant)
        local score = Plant._getSeedUpgradeScore(seedName)
        local shouldShovel = not protected[plant]
            and (mutation == nil or tostring(mutation) == "")
            and score > 0
            and score < threshold

        if shouldShovel then
            local beforeCount = Plant._getPlantCount(myPlot)
            local plantRoot = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
            if root and plantRoot then
                _himonoRememberMovement("AutoPlant", root)
                Utils.tweenRootTo(root, plantRoot.CFrame * CFrame.new(0, 3, 0), 250, 2)
            end
            local sent = Plant._tryPromptShovel(plant) or Plant._tryRemoteShovel(Net, plant)
            if sent and Plant._confirmRemoved(plant, myPlot, beforeCount) then
                shoveled = shoveled + 1
                Plant._stats.shoveled = Plant._stats.shoveled + 1
                print("[himono Hub] Shoveled weak plant:", tostring(seedName), "for upgrade seed:", bestSeedName)
            else
                Plant._stats.errors = Plant._stats.errors + 1
            end
            task.wait(0.25)
        end
    end
    _himonoRestoreMovement("AutoPlant")
    if shoveled == 0 then Plant._stats.shovelSkipped = Plant._stats.shovelSkipped + 1 end
    return shoveled
end

---------------------------------------------------------------
-- GENERATE GRID POSITIONS FROM A PLANTAREA PART
-- Covers the entire part surface with evenly spaced points
-- spacing: studs between each grid point (default 3)
---------------------------------------------------------------

function Plant._generateGridFromPart(part, spacing)
    if not part or not part:IsA("BasePart") then return {} end
    spacing = _himonoClampNumber(spacing, 3, 1, 20)
    local positions = {}
    local size = part.Size
    local cf = part.CFrame

    -- Calculate grid steps in local X and Z axes
    local halfX = size.X / 2
    local halfZ = size.Z / 2
    local stepsX = math.max(1, math.floor(size.X / spacing))
    local stepsZ = math.max(1, math.floor(size.Z / spacing))

    -- Use cell centers instead of exact edges; edge points are often rejected as outside the plot.
    for ix = 1, stepsX do
        for iz = 1, stepsZ do
            local localX = -halfX + ((ix - 0.5) / stepsX) * size.X
            local localZ = -halfZ + ((iz - 0.5) / stepsZ) * size.Z
            -- Transform to world position (use top surface Y)
            local worldPos = cf * Vector3.new(localX, size.Y / 2, localZ)
            table.insert(positions, worldPos)
        end
    end
    return positions
end

---------------------------------------------------------------
-- FIND ALL EMPTY PLANT POSITIONS
-- 1. Get all PlantArea parts in my plot
-- 2. Generate grid across each part's surface
-- 3. Filter out positions too close to existing plants
-- Returns sorted list of empty world positions
---------------------------------------------------------------

function Plant._findEmptySpots(myPlot, spacing, sortMode)
    spacing = _himonoClampNumber(spacing, 3, 1, 20)

    -- Collect all PlantArea parts belonging to my plot
    local plantAreaParts = {}
    for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
        if part:IsA("BasePart") and part:IsDescendantOf(myPlot) then
            table.insert(plantAreaParts, part)
        end
    end

    -- Also check for PlantArea tagged via attribute (some plots use this)
    for _, desc in ipairs(myPlot:GetDescendants()) do
        if desc:IsA("BasePart") and desc:GetAttribute("PlantArea") then
            if not table.find(plantAreaParts, desc) then
                table.insert(plantAreaParts, desc)
            end
        end
    end

    if #plantAreaParts == 0 then
        -- Fallback: use GardenTotalArea if no PlantArea found
        for _, part in ipairs(CollectionService:GetTagged("GardenTotalArea")) do
            if part:IsA("BasePart") and part:IsDescendantOf(myPlot) then
                table.insert(plantAreaParts, part)
            end
        end
    end

    -- Current GAG2 plots expose the plantable surface directly as PlotSizeReference.
    if #plantAreaParts == 0 then
        for _, name in ipairs({ "PlotSizeReference", "PlantArea", "GardenTotalArea" }) do
            local part = myPlot:FindFirstChild(name, true)
            if part and part:IsA("BasePart") then
                table.insert(plantAreaParts, part)
                break
            end
        end
    end

    -- Generate grid positions across all parts
    local allPositions = {}
    for _, part in ipairs(plantAreaParts) do
        local grid = Plant._generateGridFromPart(part, spacing)
        for _, pos in ipairs(grid) do
            table.insert(allPositions, pos)
        end
    end

    -- Filter: only keep empty positions
    local emptySpots = {}
    for _, pos in ipairs(allPositions) do
        local duplicate = false
        for _, accepted in ipairs(emptySpots) do
            if (Vector2.new(accepted.X, accepted.Z) - Vector2.new(pos.X, pos.Z)).Magnitude < spacing * 0.5 then
                duplicate = true
                break
            end
        end
        if not duplicate and Plant._isPosEmpty(pos, myPlot) then
            table.insert(emptySpots, pos)
        end
    end

    -- Sort based on mode
    sortMode = sortMode or "Top"
    local pivot = myPlot:IsA("Model") and myPlot:GetPivot() or CFrame.new()
    local function localPosition(pos)
        return pivot:PointToObjectSpace(pos)
    end
    if sortMode == "Top" then
        table.sort(emptySpots, function(a, b)
            local la, lb = localPosition(a), localPosition(b)
            if la.Z == lb.Z then return la.X < lb.X end
            return la.Z < lb.Z
        end)
    elseif sortMode == "Bottom" then
        table.sort(emptySpots, function(a, b)
            local la, lb = localPosition(a), localPosition(b)
            if la.Z == lb.Z then return la.X > lb.X end
            return la.Z > lb.Z
        end)
    else -- Random
        for i = #emptySpots, 2, -1 do
            local j = math.random(1, i)
            emptySpots[i], emptySpots[j] = emptySpots[j], emptySpots[i]
        end
    end

    return emptySpots
end

function Plant._getSingleSpot(myPlot)
    local bestPart = nil
    local bestArea = 0
    for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
        if part:IsA("BasePart") and part:IsDescendantOf(myPlot) then
            local area = part.Size.X * part.Size.Z
            if area > bestArea then bestPart, bestArea = part, area end
        end
    end
    if not bestPart then
        bestPart = myPlot:FindFirstChild("PlotSizeReference", true)
            or myPlot:FindFirstChild("PlantArea", true)
            or myPlot:FindFirstChild("GardenTotalArea", true)
    end
    if bestPart and bestPart:IsA("BasePart") then
        return bestPart.CFrame * Vector3.new(0, bestPart.Size.Y / 2, 0)
    end
    return myPlot:IsA("Model") and myPlot:GetPivot().Position or nil
end

