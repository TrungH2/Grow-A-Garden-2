            PerformanceLowQuality = Config.Performance.LowQuality == true,
            PerformanceHidePlayers = Config.Performance.HideOtherPlayers == true,
            PerformanceScreen = Config.Performance.ScreenEnabled == true,
            PerformanceDisable3D = Config.Performance.Disable3DRendering == true,
        }) do
            local toggle = FeatureToggles[toggleName]
            if toggle and toggle.Set then pcall(function() toggle:Set(value) end) end
        end
        local sellMode = UIControls.SellMode
        if sellMode and sellMode.Set then pcall(function() sellMode:Set({ Config.Sell.Mode }) end) end
        for controlName, value in pairs({
            RequiredCan = { Config.Water.RequiredCan == "" and "Any" or Config.Water.RequiredCan },
            RestockTargets = table.clone(Config.Restock.TargetSeeds),
            RestockBlacklist = table.clone(Config.Restock.BlacklistedSeeds),
            GearTargets = table.clone(Config.Gear.TargetGears),
            SprinklerTargets = table.clone(Config.Water.TargetSprinklers),
            ScreenColor = { Config.Performance.ScreenColor },
        }) do
            local control = UIControls[controlName]
            if control and control.Set then pcall(function() control:Set(value) end) end
        end
        local modeToggle = FeatureToggles.KaitunOneClick
        if modeToggle and modeToggle.Set then pcall(function() modeToggle:Set(Config.Kaitun.OneClick == true) end) end
    end
    ApplyingOneClickPolicy = false
end

local function applyOptimizeAll(syncUI, startRuntime)
    local refreshPerformance = Performance._boostEnabled
    Config.Kaitun.OneClick = true
    -- Treat this as a one-shot preset so later per-feature choices survive rejoin serialization.
    Config.Kaitun.OptimizeAll = false
    for _, name in ipairs(OneClickFeatures) do Config.Features[name] = true end
    Config.Features.AntiAfk = true
    Config.Server.AutoRejoin = true
    Config.Sell.Mode = "all"
    Config.Restock.WealthScaling = true
    Config.Restock.PreferHighestAffordable = true
    Config.Plant.SkipGoldSeeds = true
    Config.Plant.SkipRainbowSeeds = true
    Config.Plant.SkipMegaSeeds = true
    Config.Plant.AutoShovelWeakPlants = true
    Config.Water.AutoSprinkler = true
    Config.Inventory.FavoriteRare = true
    Config.Performance.BoostFPS = true
    Config.Performance.MuteSounds = true
    Config.Performance.LowQuality = true
    forceOneClickFeaturePolicy(syncUI == true, true)

    if startRuntime == true then
        Performance.start()
        if refreshPerformance then Performance.refreshBoost() end
        Webhook.start()
        if Config.Features.AntiAfk then AntiAfk.start(Config) end
        if Config.Server.AutoRejoin then AntiAfk.startAutoRejoin(Config) end
        task.spawn(function()
            if ensureOneClickModules then ensureOneClickModules() end
            if startOneClickWatchdog then startOneClickWatchdog() end
        end)
    end
end

