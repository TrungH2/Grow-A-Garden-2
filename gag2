function Stats.getSeedSummary(limit)
    local counts = {}
    local total = 0
    Stats._iterTools(function(tool)
        local seed = _himonoGetSeedName(tool)
        if seed then
            counts[seed] = (counts[seed] or 0) + 1
            total = total + 1
        end
    end)
    local rows = {}
    for seed, n in pairs(counts) do
        table.insert(rows, { seed = seed, count = n })
    end
    table.sort(rows, function(a, b)
        if a.count == b.count then return a.seed < b.seed end
        return a.count > b.count
    end)
    return total, rows
end

function Stats.getGardenDetails()
    local garden = Utils.getMyGarden()
    local plants, sprinklers, decaying = 0, 0, 0
    if not garden then return plants, sprinklers, decaying end

    local plantsFolder = _himonoFindChildAny(garden, { "Plants", "Plant", "GardenPlants" })
    if plantsFolder then
        plants = #plantsFolder:GetChildren()
        for _, plant in ipairs(plantsFolder:GetChildren()) do
            if _himonoTruthy(plant:GetAttribute("Decaying"), false)
                or _himonoTruthy(plant:GetAttribute("IsDecaying"), false)
                or tonumber(plant:GetAttribute("Decay")) and tonumber(plant:GetAttribute("Decay")) > 0 then
                decaying = decaying + 1
            end
        end
    end

    local seenSprinklers = setmetatable({}, { __mode = "k" })
    for _, desc in ipairs(garden:GetDescendants()) do
        local lowerName = _himonoLower(desc.Name)
        if string.find(lowerName, "sprinkler", 1, true) or _himonoLower(desc:GetAttribute("ItemType")) == "sprinkler" then
            local root = desc
            if desc:IsA("BasePart") or desc:IsA("Attachment") then
                root = desc:FindFirstAncestorWhichIsA("Model") or desc
            end
            if not seenSprinklers[root] then
                seenSprinklers[root] = true
                sprinklers = sprinklers + 1
            end
        end
    end
    return plants, sprinklers, decaying
end

function Stats.getMailCount()
    local lp = Players and Players.LocalPlayer
    local candidates = {}
    if lp then
        table.insert(candidates, lp)
        local pg = lp:FindFirstChild("PlayerGui")
        if pg then table.insert(candidates, pg) end
    end
    table.insert(candidates, game:GetService("ReplicatedStorage"))
    for _, root in ipairs(candidates) do
        local mail = root:FindFirstChild("Mail") or root:FindFirstChild("Mails") or root:FindFirstChild("Mailbox")
        if mail then
            if mail:IsA("ValueBase") then return tonumber(mail.Value) or 0 end
            return #mail:GetChildren()
        end
    end
    return 0
end

