local function _himonoGetSeedName(tool)
    if typeof(tool) ~= "Instance" or not tool:IsA("Tool") then return nil end
    local category = tool:GetAttribute("MainCategory")
    local categoryLower = _himonoLower(category)
    if category ~= nil and categoryLower ~= "seed" and categoryLower ~= "seeds" and categoryLower ~= "seedtool" then return nil end

    local seedName = tool:GetAttribute("SeedTool")
        or tool:GetAttribute("SeedName")
        or tool:GetAttribute("PlantName")
    if type(seedName) == "string" and seedName ~= "" then return seedName end

    local plantName = tool:FindFirstChild("Plant_Name")
    if plantName and plantName:IsA("ValueBase") then
        seedName = plantName.Value
        if type(seedName) == "string" and seedName ~= "" then return seedName end
    end
    return nil
end

local function _himonoShouldSkipSeed(seedName, plantConfig, seedTool)
    plantConfig = type(plantConfig) == "table" and plantConfig or {}
    local values = { tostring(seedName or "") }
    if seedTool then
        table.insert(values, tostring(seedTool.Name or ""))
        table.insert(values, tostring(seedTool:GetAttribute("Mutation") or seedTool:GetAttribute("MutationName")
            or seedTool:GetAttribute("SeedMutation") or ""))
    end
    local isGold = seedTool and _himonoTruthy(seedTool:GetAttribute("GoldSeed"), false) or false
    local isRainbow = seedTool and _himonoTruthy(seedTool:GetAttribute("RainbowSeed"), false) or false
    local isMega = seedTool and _himonoTruthy(seedTool:GetAttribute("MegaSeed"), false) or false
    for _, value in ipairs(values) do
        local lower = _himonoLower(value)
        if lower == "gold" or string.find(lower, "gold", 1, true) ~= nil then isGold = true end
        if lower == "rainbow" or string.find(lower, "rainbow", 1, true) ~= nil then isRainbow = true end
        if lower == "mega" or string.find(lower, "mega", 1, true) ~= nil then isMega = true end
    end
    if plantConfig.BlacklistMutated and (isGold or isRainbow or isMega) then return true end
    if plantConfig.SkipGoldSeeds and isGold then return true end
    if plantConfig.SkipRainbowSeeds and isRainbow then return true end
    if plantConfig.SkipMegaSeeds and isMega then return true end
    return false
end

local function _himonoOptionList(value)
    local result = {}
    if type(value) == "table" then
        for _, item in ipairs(value) do
            if type(item) == "string" and item ~= "" then table.insert(result, item) end
        end
    elseif type(value) == "string" and value ~= "" then
        table.insert(result, value)
    end
    return result
end

local function _himonoDisconnectList(list)
    if type(list) ~= "table" then return {} end
    for _, conn in ipairs(list) do
        pcall(function()
            if conn and conn.Disconnect then conn:Disconnect() end
        end)
    end
