local Modules = {}
local Running = {}
local ModuleErrors = {}
local RuntimeErrorState = {}

local Webhook = {
    _lastSent = {},
    _thread = nil,
    _running = false,
    _stats = { sent = 0, errors = 0, rateLimited = 0 },
}

function Webhook._requestFunction()
    local environment = type(getgenv) == "function" and getgenv() or _G
    if type(environment.request) == "function" then return environment.request end
    if type(environment.http_request) == "function" then return environment.http_request end
    if type(environment.http) == "table" and type(environment.http.request) == "function" then return environment.http.request end
    if type(environment.syn) == "table" and type(environment.syn.request) == "function" then return environment.syn.request end
    if type(environment.fluxus) == "table" and type(environment.fluxus.request) == "function" then return environment.fluxus.request end
    return nil
end

function Webhook._validUrl(url)
    local normalized = _himonoLower(url)
    return string.match(normalized, "^https://discord%.com/api/webhooks/%d+/.+") ~= nil
        or string.match(normalized, "^https://discordapp%.com/api/webhooks/%d+/.+") ~= nil
end

function Webhook.send(eventKey, title, description, color)
    local webhookConfig = Config.Webhook or {}
    if webhookConfig.Enabled ~= true then return false, "disabled" end
    local url = _himonoTrimString(webhookConfig.URL)
    if not Webhook._validUrl(url) then return false, "invalid_url" end
    local requestFunction = Webhook._requestFunction()
    if not requestFunction then return false, "request_unavailable" end

    local key = tostring(eventKey or title or "event")
    local now = os.clock()
    local rateLimit = _himonoClampNumber(webhookConfig.RateLimitSeconds, 30, 1, 600)
    if now - (Webhook._lastSent[key] or -math.huge) < rateLimit then
        Webhook._stats.rateLimited = Webhook._stats.rateLimited + 1
        return false, "rate_limited"
    end
    Webhook._lastSent[key] = now

    local payload = {
        username = tostring(webhookConfig.Username or "himono OneClick GAG2"),
        embeds = {{
            title = string.sub(tostring(title or "GAG2 notification"), 1, 200),
            description = string.sub(tostring(description or ""), 1, 3500),
            color = tonumber(color) or 3066993,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }},
    }
    local encodeOk, encoded = pcall(function()
        return game:GetService("HttpService"):JSONEncode(payload)
    end)
    if not encodeOk then
        if Webhook._lastSent[key] == now then Webhook._lastSent[key] = nil end
        Webhook._stats.errors = Webhook._stats.errors + 1
        return false, "encode_failed"
    end
    local ok, response = pcall(requestFunction, {
        Url = url,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = encoded,
    })
    local statusCode = ok and type(response) == "table" and tonumber(response.StatusCode or response.Status) or nil
    if ok and (statusCode == nil or (statusCode >= 200 and statusCode < 300)) then
        Webhook._stats.sent = Webhook._stats.sent + 1
        return true
    end
    if Webhook._lastSent[key] == now then Webhook._lastSent[key] = nil end
    Webhook._stats.errors = Webhook._stats.errors + 1
    return false, statusCode and ("http_" .. tostring(statusCode)) or "request_failed"
end

function Webhook.notifyRarePet(petName, rarity, price, source)
    if Config.Webhook.OnRarePet ~= true then return false end
    local rarityEnabled = false
    for rarityName, enabled in pairs(type(Config.Webhook.PetRarities) == "table" and Config.Webhook.PetRarities or {}) do
        if enabled == true and _himonoLower(rarityName) == _himonoLower(rarity) then
            rarityEnabled = true
            break
        end
    end
    local numericPrice = math.max(tonumber(price) or 0, 0)
    if not rarityEnabled and numericPrice < math.max(tonumber(Config.Webhook.PetMinPrice) or 1000000, 0) then return false end
    local detail = tostring(petName) .. " (" .. tostring(rarity or "Unknown") .. ")"
    if numericPrice > 0 then detail = detail .. " for " .. Utils.formatNumber(numericPrice) .. " sheckles" end
    if source then detail = detail .. "\nSource: " .. tostring(source) end
    return Webhook.send("pet:" .. tostring(petName) .. ":" .. tostring(rarity), "Rare pet obtained", detail, 15105570)
end

function Webhook.sendProfile()
    local lp = Players.LocalPlayer
    local fruitCount, fruitMax = Utils.getFruitCapacity()
    local active = 0
    for name, isRunning in pairs(Running) do
        if isRunning and Modules[name] then active = active + 1 end
    end
    local description = table.concat({
        "Player: " .. tostring(lp and lp.Name or "Unknown"),
        "Sheckles: " .. Utils.formatNumber(Utils.getSheckles()),
        string.format("Fruit inventory: %d / %d", fruitCount, fruitMax),
        "Active modules: " .. tostring(active),
        "JobId: " .. tostring(game.JobId),
    }, "\n")
    return Webhook.send("profile", "GAG2 profile report", description, 3447003)
end

function Webhook.start()
    Webhook.stop()
    if Config.Webhook.Enabled ~= true or Config.Webhook.ProfileReport ~= true then return end
    Webhook._running = true
    Webhook._thread = task.spawn(function()
        while Webhook._running do
            local interval = _himonoClampNumber(Config.Webhook.ProfileIntervalMinutes, 30, 1, 1440) * 60
            task.wait(interval)
            if Webhook._running then Webhook.sendProfile() end
        end
    end)
end

function Webhook.stop()
    Webhook._running = false
    Webhook._thread = _himonoCancelThread(Webhook._thread)
end

local function runModuleStep(name, mod, callback)
    local ok, err = xpcall(callback, function(message)
        local text = tostring(message)
        if debug and type(debug.traceback) == "function" then
            return debug.traceback(text, 2)
        end
        return text
    end)

    if ok then
        local previous = RuntimeErrorState[name]
        if previous and ModuleErrors[name] == previous.message then
            ModuleErrors[name] = nil
        end
        RuntimeErrorState[name] = nil
        return true
    end

    local message = tostring(err)
    local now = os.clock()
    local previous = RuntimeErrorState[name]
    if not previous or previous.message ~= message or now - previous.lastWarn >= 10 then
        warn("[himono Hub] Runtime error in", name, message)
        RuntimeErrorState[name] = { message = message, lastWarn = now }
    end
    ModuleErrors[name] = message
    _himonoRestoreMovement(name)
    _himonoReleaseLocks(name)
    if mod and type(mod._stats) == "table" then
        mod._stats.errors = (tonumber(mod._stats.errors) or 0) + 1
    end
    return false
end

-- Startup progress is shown in the Status tab and console.
local StartupProgress = { state = "Booting", total = 0, done = 0, current = "", log = {} }

local KaitunStartOrder = {
    "AutoCenterPlot", "InventoryOptimizer", "AutoSell", "AutoHarvest", "RestockSniper",
    "AutoPlant", "GearBuyer", "AutoWater",
    "AutoBuyPet", "SeedPackClaimer", "GenericEventCollector", "AutoPetCatch",
    "MutationTracker", "WeatherBot", "AutoJoinServer", "ServerHop", "StealBot",
}

local OneClickFeatures = {
    "AutoCenterPlot", "AutoSell", "AutoHarvest", "RestockSniper",
    "AutoPlant", "GearBuyer", "AutoWater", "InventoryOptimizer",
    "AutoBuyPet", "SeedPackClaimer", "GenericEventCollector", "AutoPetCatch",
    "MutationTracker", "WeatherBot",
}

local RestrictedAutoStart = {
    -- Left disabled by default: these can be disruptive or against other games' rules.
    StealBot = true,
}

local function pushStartupProgress(state, message)
    StartupProgress.state = state or StartupProgress.state
    StartupProgress.current = message or StartupProgress.current
    table.insert(StartupProgress.log, 1, os.date("%H:%M:%S") .. " - " .. tostring(message or state or ""))
    while #StartupProgress.log > 12 do
        table.remove(StartupProgress.log)
    end
    print("[himono Hub][Startup] " .. tostring(state or "") .. " - " .. tostring(message or ""))
end

local function countEnabledStartupFeatures()
    local count = 0
    if Config.Features.AntiAfk then count = count + 1 end
    for _, name in ipairs(KaitunStartOrder) do
        if Config.Features[name] and not RestrictedAutoStart[name] then
            count = count + 1
        end
    end
    return count
end

local function startModule(name)
    if Running[name] then
        local existing = Modules[name]
        if not existing or existing._running == nil or existing._running == true then return true end
        if type(existing.stop) == "function" then pcall(existing.stop) end
        Running[name] = false
    end

    local mod = Modules[name]
    if not mod or type(mod.start) ~= "function" then
        ModuleErrors[name] = "Module has no start()"
        warn("[himono Hub] Cannot start", name, "-", ModuleErrors[name])
        Running[name] = false
        return false
    end

    -- Recover a partially-started module left behind by an earlier start error.
    if mod._running == true and not Running[name] then
        if type(mod.stop) == "function" then pcall(mod.stop) end
        mod._running = false
    end

    local ok, err = pcall(function()
        mod.start(Config, Networking, Utils)
    end)

    if not ok then
        ModuleErrors[name] = tostring(err)
        Running[name] = false
        if type(mod.stop) == "function" then pcall(mod.stop) end
        if mod._running ~= nil then mod._running = false end
        warn("[himono Hub] Start failed:", name, err)
        Config.Notify("Module failed", name .. ": " .. tostring(err), 6)
        return false
    end

    ModuleErrors[name] = nil
    if mod._running ~= nil then
        Running[name] = mod._running == true
    else
        Running[name] = true
    end
    if Running[name] then
        Config.Features[name] = true
        print("[himono Hub] Started:", name)
        return true
    end
    warn("[himono Hub] Module did not remain running:", name)
    return false
end

local function stopModule(name)
    local mod = Modules[name]
    if mod and type(mod.stop) == "function" then
        local ok, err = pcall(function()
            mod.stop()
        end)
        if not ok then
            ModuleErrors[name] = tostring(err)
            warn("[himono Hub] Stop failed:", name, err)
        end
    end
    _himonoRestoreMovement(name)
    local runtimeError = RuntimeErrorState[name]
    if runtimeError and ModuleErrors[name] == runtimeError.message then
        ModuleErrors[name] = nil
    end
    RuntimeErrorState[name] = nil
    _himonoReleaseLocks(name)
    Running[name] = false
    Config.Features[name] = false
    print("[himono Hub] Stopped:", name)
    return true
end

local function toggleModule(name)
    if Running[name] then stopModule(name) else startModule(name) end
    return Running[name]
end

