local function _himonoTableHasNumericKey(value)
    for key in pairs(value) do
        if type(key) == "number" then return true end
    end
    return false
end

local function _himonoCopyConfigValue(value, seen)
    if type(value) ~= "table" then return value end
    seen = seen or {}
    if seen[value] then return seen[value] end
    local copy = {}
    seen[value] = copy
    for key, child in pairs(value) do
        copy[_himonoCopyConfigValue(key, seen)] = _himonoCopyConfigValue(child, seen)
    end
    return copy
end

local _himonoClearableConfigMaps = {
    ["Config.Mutation.PriceMultipliers"] = true,
    ["Config.Webhook.PetRarities"] = true,
    ["Config.Webhook.MutationNames"] = true,
}

local function _himonoMergeConfig(target, source, path)
    if type(target) ~= "table" or type(source) ~= "table" then return end
    path = path or "Config"
    for key, value in pairs(source) do
        local current = target[key]
        local keyPath = path .. "." .. tostring(key)
        if current == nil then
            warn("[himono Hub] Ignoring unknown external setting: " .. keyPath)
        elseif type(current) == "table" then
            if type(value) ~= "table" then
                warn("[himono Hub] Ignoring invalid table setting: " .. keyPath)
            elseif next(value) == nil then
                if next(current) == nil or _himonoTableHasNumericKey(current) or _himonoClearableConfigMaps[keyPath] then
                    target[key] = {}
                end
            elseif _himonoTableHasNumericKey(value) then
                target[key] = _himonoCopyConfigValue(value)
            else
                _himonoMergeConfig(current, value, keyPath)
            end
        elseif type(value) == type(current) then
            target[key] = value
        else
            warn("[himono Hub] Ignoring invalid setting type: " .. keyPath)
        end
    end
end

