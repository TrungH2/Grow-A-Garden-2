function Inventory.favoriteAll(Net, Utils, threshold)
    local count = 0
    local lp = Utils.getLocalPlayer()
    local backpack = lp and lp:FindFirstChild("Backpack")
    if not backpack then return 0 end

    for _, tool in ipairs(backpack:GetChildren()) do
        local value = Inventory._estimateFruitToolValue(tool, Config)
        if value and value >= (tonumber(threshold) or 0) then
            if _himonoRemoteOk(Net, "Backpack.SetFruitFavorite", tool.Name, true) then
                count = count + 1
            end
        end
    end
    Inventory._stats.favorited = Inventory._stats.favorited + count
    return count
end

function Inventory.dropAllLowValue(Net, Utils, threshold)
    local count = 0
    local lp = Utils.getLocalPlayer()
    local backpack = lp and lp:FindFirstChild("Backpack")
    if not backpack then return 0 end

    for _, tool in ipairs(backpack:GetChildren()) do
        local value = Inventory._estimateFruitToolValue(tool, Config)
        if value and value < (tonumber(threshold) or 0) then
            if _himonoRemoteOk(Net, "DroppedItem.RequestDrop", tool.Name, 1) then
                count = count + 1
            end
        end
    end
    Inventory._stats.dropped = Inventory._stats.dropped + count
    return count
end

