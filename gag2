    destroyStatusOverlay = destroyKaitunStatusOverlay,
    stopStatusLoop = function()
        _G.himonoHubStatusLoopRunning = false
        _G.himonoHubStatusLoopToken = nil
        _G.himonoHubStatusOverlayRunning = false
    end,
    destroyUI = function()
        if _G.himonoHubRayfield and type(_G.himonoHubRayfield.Destroy) == "function" then
            pcall(function() _G.himonoHubRayfield:Destroy() end)
        end
        _G.himonoHubRayfield = nil
    end,
}

---------------------------------------------------------------
-- STARTUP
---------------------------------------------------------------

Stats.init()

-- Anti-idle handler is managed by AntiAfk.start() to avoid duplicated Idled connections.

-- Load compact looping status overlay first, then Rayfield control UI.
pushStartupProgress("Booting", "Loading compact loop status overlay")
createKaitunStatusOverlay()
task.wait(0.1)
pushStartupProgress("Booting", "Loading UI")
task.spawn(function()
    local ok, err = pcall(createUI)
    KaitunUIHydrating = false
    KaitunUIReady = true
    if not ok then
        warn("[himono Hub] UI bootstrap failed:", err)
        if not StatusOverlay.gui or not StatusOverlay.gui.Parent then createFallbackUI() end
    end
end)

-- Kaitun auto-execution loop
task.spawn(function()
    local uiDeadline = os.clock() + 20
    while not KaitunUIReady and os.clock() < uiDeadline do task.wait(0.1) end
    applyExternalConfig()
    if Config.Kaitun.OptimizeAll == true then
        applyOptimizeAll(KaitunUIReady, false)
    elseif shouldForceOneClickPreset() then
        forceOneClickFeaturePolicy(KaitunUIReady, true)
    end
    Performance.start()
    Webhook.start()
    if not Config.Kaitun.OneClick then
        pushStartupProgress("Paused", "OneClick is disabled by config")
        return
    end
    local needsGameReadiness = false
    for _, name in ipairs(KaitunStartOrder) do
        if Config.Features[name] and not RestrictedAutoStart[name] then
            needsGameReadiness = true
            break
        end
    end
    if needsGameReadiness then waitForKaitunReadiness() end
    if not Config.Kaitun.OneClick then return end

    StartupProgress.total = countEnabledStartupFeatures()
    StartupProgress.done = 0
    pushStartupProgress("Starting", "Preparing Kaitun auto-execution")

    print("[himono Hub] Launching auto-execution routine...")
    Config.Notify("[himono Hub] Auto-start active", "Activating enabled Kaitun features...", 4)

    -- Start AntiAFK if configured.
    if Config.Features.AntiAfk then
        pushStartupProgress("Starting", "AntiAfk")
        local ok, err = pcall(function()
            AntiAfk.start(Config)
        end)
        if not ok then
            ModuleErrors.AntiAfk = tostring(err)
            pushStartupProgress("Error", "AntiAfk: " .. tostring(err))
        else
            StartupProgress.done = StartupProgress.done + 1
            pushStartupProgress("OK", "AntiAfk started")
        end
        task.wait(0.2)
    end
    if Config.Server.AutoRejoin then
        local ok, err = pcall(function() AntiAfk.startAutoRejoin(Config) end)
        if not ok then ModuleErrors.AutoRejoin = tostring(err) end
    end

    -- Stagger-start each enabled feature in a deterministic order.
    for _, name in ipairs(KaitunStartOrder) do
        if Config.Features[name] then
            if RestrictedAutoStart[name] then
                pushStartupProgress("Skipped", name .. " is disabled from auto-start for safety")
            else
                pushStartupProgress("Starting", name)
                local ok = startModule(name)
                if ok and Running[name] then
                    StartupProgress.done = StartupProgress.done + 1
                    pushStartupProgress("OK", name .. " started")
                else
                    pushStartupProgress("Error", name .. " failed: " .. tostring(ModuleErrors[name] or "not running"))
                end
                task.wait(0.2)
            end
        end
    end

    startOneClickWatchdog()
    pushStartupProgress("Complete", "Kaitun auto-execution finished")
    Config.Notify("OneClick Active!", "Core farm loops are running with automatic recovery.", 5)
    print("[himono Hub] OneClick kaitun active. Check _G.himonoHub.status() for details.")
end)

print("himono Hub [ONECLICK] loaded! Console API: _G.himonoHub")
