Modules.MutationTracker = {}
do
    local M = Modules.MutationTracker
    local Mutation = M
Mutation._running = false
Mutation._thread  = nil
Mutation._connections = {}
Mutation._stats = { tracked = 0, alerts = 0 }
Mutation._mutationLog = {}
Mutation._lastMutationByEntity = {}

---------------------------------------------------------------
-- START
---------------------------------------------------------------

function Mutation.start(config, Net, Utils)
    if Mutation._running then return end
    Mutation._running = true

    local mutConfig = config.Mutation or {}

    -- Listen for real-time mutation events
    local plantMutConn = Net.on("Garden.PlantMutationUpdated",
        function(plantId, mutation)
            if not Mutation._running then return end
            Mutation._onMutation("plant", "plant:" .. tostring(plantId), mutation, mutConfig, Utils, plantId)
        end
    )
    if plantMutConn then
        table.insert(Mutation._connections, plantMutConn)
    end

    local fruitMutConn = Net.on("Garden.FruitMutationUpdated",
        function(plantId, fruitId, mutation)
            if not Mutation._running then return end
            local entityKey = "fruit:" .. tostring(plantId) .. ":" .. tostring(fruitId)
            Mutation._onMutation("fruit", entityKey, mutation, mutConfig, Utils, plantId)
        end
    )
    if fruitMutConn then
        table.insert(Mutation._connections, fruitMutConn)
    end

    -- Also listen for plant growth (sometimes mutation comes with growth update)
    local growthConn = Net.on("Garden.PlantGrowthUpdated",
        function(plantId, growth, size, mutation)
            if not Mutation._running then return end
            if mutation and mutation ~= "" then
                Mutation._onMutation("growth", "plant:" .. tostring(plantId), mutation, mutConfig, Utils, plantId)
            end
        end
    )
    if growthConn then
        table.insert(Mutation._connections, growthConn)
    end

    -- Periodic scan of own garden
    Mutation._thread = task.spawn(function()
        while Mutation._running do
            runModuleStep("MutationTracker", Mutation, function()
                Mutation._scanGarden(mutConfig, Utils)
            end)
            task.wait(_himonoClampNumber(config.Timings.MutationScanInterval, 3, 1, 60))
        end
    end)

    print("[himono Hub] Mutation Tracker started")
end

---------------------------------------------------------------
-- ON MUTATION EVENT
---------------------------------------------------------------

function Mutation._onMutation(source, entityKey, mutation, config, Utils, displayId)
    if not mutation or mutation == "" then
        if entityKey then Mutation._lastMutationByEntity[entityKey] = nil end
        return
    end
    entityKey = tostring(entityKey or displayId or "unknown")
    if Mutation._lastMutationByEntity[entityKey] == mutation then return end
    Mutation._lastMutationByEntity[entityKey] = mutation

    Mutation._stats.tracked = Mutation._stats.tracked + 1
    local multipliers = config.PriceMultipliers or {}

    local entry = {
        source   = source,
        plantId  = displayId or entityKey,
        entityKey = entityKey,
        mutation = mutation,
        time     = os.time(),
        priceMult = multipliers[mutation] or 1,
    }

    table.insert(Mutation._mutationLog, entry)

    -- Keep log manageable
    if #Mutation._mutationLog > 500 then
        table.remove(Mutation._mutationLog, 1)
    end

    -- Check if this is an alert-worthy mutation
    local isAlert = false
    if config.AlertAll then
        isAlert = true
    else
        for _, name in ipairs(config.AlertMutations or {}) do
            if _himonoLower(name) == _himonoLower(mutation) then
                isAlert = true
                break
            end
        end
    end

    local mult = multipliers[mutation] or 1
    local msg = string.format("[%s] %s mutation: %s (x%s value)",
        tostring(source), tostring(displayId or entityKey), tostring(mutation), tostring(mult))

    if isAlert then
        Mutation._stats.alerts = Mutation._stats.alerts + 1
        if config.LogToConsole then
            print("[himono Hub] Mutation: " .. msg)
        end

        Config.Notify("Mutation Detected!", msg, 8)

        if config.PlaySound then
            pcall(function()
                local SoundService = game:GetService("SoundService")
                local sound = Instance.new("Sound")
                sound.SoundId = "rbxassetid://6518811702"
                sound.Volume = 0.5
                sound.Parent = SoundService
                sound:Play()
                game:GetService("Debris"):AddItem(sound, 3)
            end)
        end
    end

    local webhookMutations = Config.Webhook and Config.Webhook.MutationNames or {}
    local notifyWebhook = false
    for mutationName, enabled in pairs(type(webhookMutations) == "table" and webhookMutations or {}) do
        if enabled == true and _himonoLower(mutationName) == _himonoLower(mutation) then
            notifyWebhook = true
            break
        end
    end
    if Config.Webhook.OnRareMutation == true and notifyWebhook then
        Webhook.send("mutation:" .. tostring(mutation), "Rare mutation detected", msg, 10181046)
    end
end

---------------------------------------------------------------
-- SCAN GARDEN FOR EXISTING MUTATIONS
---------------------------------------------------------------

function Mutation._scanGarden(config, Utils)
    local garden = Utils.getMyGarden()
    if not garden then return end

    local plants = Utils.getPlantsInGarden(garden)
    local seen = {}
    for _, plant in ipairs(plants) do
        local info = Utils.getPlantInfo(plant)
        local plantId = plant:GetAttribute("PlantId") or plant:GetFullName()
        local plantKey = "plant:" .. tostring(plantId)
        seen[plantKey] = true
        Mutation._onMutation("scan", plantKey, info and info.Mutation, config, Utils, plantId)

        local fruitsFolder = _himonoFindChildAny(plant, { "Fruits", "Fruit", "Produce", "Harvestables" })
        if fruitsFolder then
            for _, fruit in ipairs(fruitsFolder:GetChildren()) do
                local fruitPlantId = fruit:GetAttribute("PlantId") or plantId
                local fruitId = fruit:GetAttribute("FruitId") or fruit:GetFullName()
                local fruitKey = "fruit:" .. tostring(fruitPlantId) .. ":" .. tostring(fruitId)
                seen[fruitKey] = true
                local fruitMutation = fruit:GetAttribute("Mutation") or fruit:GetAttribute("MutationName")
                    or fruit:GetAttribute("Mutations")
                Mutation._onMutation("scan", fruitKey, fruitMutation, config, Utils, fruitPlantId)
            end
        end
    end
    for entityKey in pairs(Mutation._lastMutationByEntity) do
        if (entityKey:match("^plant:") or entityKey:match("^fruit:")) and not seen[entityKey] then
            Mutation._lastMutationByEntity[entityKey] = nil
        end
    end
end

---------------------------------------------------------------
-- GET MUTATION PRICE MULTIPLIER
---------------------------------------------------------------

function Mutation.getPriceMultiplier(mutationName, config)
    if config and config.PriceMultipliers then
        return _himonoLookupNumber(config.PriceMultipliers, mutationName, 1)
    end
    return 1
end

---------------------------------------------------------------
-- GET MUTATION LOG
---------------------------------------------------------------

function Mutation.getLog()
    return Mutation._mutationLog
end

function Mutation.getLogByMutation(mutationName)
    local filtered = {}
    for _, entry in ipairs(Mutation._mutationLog) do
        if entry.mutation == mutationName then
            table.insert(filtered, entry)
        end
    end
    return filtered
end

