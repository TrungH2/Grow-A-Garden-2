---------------------------------------------------------------
-- VALUE CALCULATOR
---------------------------------------------------------------

-- Calculate fruit sell value (mirrors FruitValueCalc)
-- baseValue * size^exponent * mutationMult * sizeMult
function Utils.calculateFruitValue(seedName, size, mutation, sellData, mutationData)
    local baseEntry = sellData and _himonoLookup(sellData, seedName) or 0
    local base = tonumber(baseEntry)
    if type(baseEntry) == "table" then
        base = tonumber(baseEntry.BaseValue or baseEntry.SellValue or baseEntry.Value or baseEntry.Price)
    end
    base = base or 0
    size = tonumber(size) or 1
    if size <= 0 then size = 1 end
    local sizeExponent = 2.65
    local sizeMult = 1
    local mutationMult = 1

    if mutation and mutationData then
        local mData = _himonoLookup(mutationData, mutation)
        if type(mData) == "table" then
            mutationMult = tonumber(mData.PriceMultiplier or mData.Multiplier) or 1
        else
            mutationMult = tonumber(mData) or 1
        end
    end

    local value = base * (size ^ sizeExponent) * sizeMult * mutationMult
    return math.floor(value)
end

